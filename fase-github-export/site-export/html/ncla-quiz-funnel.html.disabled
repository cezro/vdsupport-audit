ad":32,"backgroundSettingsClass":31,"schemaMarkup":150,"isGeolocationNeeded":25},[6,10,40,61,87],{"id":7,"child":8},"hl_main",[9],"section-Frh5Cib-cw",{"id":9,"type":11,"child":12,"class":14,"styles":17,"extra":20,"meta":11,"tagName":38,"title":39,"_id":9},"section",[13],"row-1j9Ad-msKD",{"width":15},{"value":16},"fullSection",{"borderWidth":18},{"value":19},"0px",{"sticky":21,"visibility":23,"bgImage":26,"allowRowMaxWidth":33,"customClass":34,"elementScreenshot":36},{"value":22},"noneSticky",{"value":24},{"hideDesktop":25,"hideMobile":25},false,{"value":27},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop":32},"image","","1","bgCover",true,{"value":25},{"value":35},[],{"value":37},[],"c-section","Section",{"id":13,"type":41,"child":42,"class":44,"styles":47,"extra":49,"tagName":59,"meta":41,"title":60},"row",[43],"col-_Dix0apOgC",{"alignRow":45},{"value":46},"row-align-center",{"borderWidth":48},{"value":19},{"visibility":50,"bgImage":52,"rowWidth":54,"customClass":57},{"value":51},{"hideDesktop":25,"hideMobile":25},{"value":53},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop":32},{"value":55,"unit":56},100,"%",{"value":58},[],"c-row","1 Column Row",{"id":43,"type":62,"child":63,"class":65,"styles":66,"extra":68,"tagName":84,"meta":62,"title":85,"noOfColumns":86},"col",[64],"custom-code-XrPvXlJg70",{},{"borderWidth":67},{"value":19},{"visibility":69,"bgImage":71,"columnLayout":73,"justifyContentColumnLayout":75,"alignContentColumnLayout":77,"forceColumnLayoutForMobile":79,"customClass":80,"elementVersion":82},{"value":70},{"hideDesktop":25,"hideMobile":25},{"value":72},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop":32},{"value":74},"column",{"value":76},"center",{"value":78},"inherit",{"value":32},{"value":81},[],{"value":83},2,"c-column","1st Column",1,{"extra":88,"id":64,"meta":97,"tagName":98,"class":99},{"visibility":89,"customCode":91,"customClass":94,"nodeId":96},{"value":90},{"hideMobile":29,"hideDesktop":29},{"value":92},{"rawCustomCode":93},"\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n\u003Cmeta charset=\"UTF-8\"/>\n\u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n\u003Ctitle>Full Arch Revenue Audit — Full Arch Sales Experts\u003C/title>\n\u003Cmeta name=\"description\" content=\"5 questions. 90 seconds. Find out exactly where your full arch consult process is breaking — and get a personalized diagnostic report.\">\n\u003Clink rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n\u003Clink rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n\u003Clink href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\u003Cstyle>\n:root {\n  --charcoal:  #040417;\n  --navy:      #0A0A28;\n  --navy2:     #10102E;\n  --blue:      #1667E8;\n  --blue-dk:   #0F4FB5;\n  --blue-bg:   rgba(22,103,232,0.12);\n  --blue-glow: rgba(22,103,232,0.22);\n  --blue-bdr:  rgba(22,103,232,0.30);\n  --gold:      #F0B429;\n  --white:     #FFFFFF;\n  --text-p:    #FFFFFF;\n  --text-s:    rgba(255,255,255,0.62);\n  --text-m:    rgba(255,255,255,0.38);\n  --border:    rgba(255,255,255,0.09);\n  --red:       #EF4444;\n  --amber:     #F59E0B;\n  --green:     #10B981;\n  --font:      'Manrope', sans-serif;\n  --lbg:       #F4F5FF;\n  --lbg2:      #ECEEFF;\n  --lcard:     #FFFFFF;\n  --ltext:     #0D0E2A;\n  --ltext2:    #3D3F5A;\n  --ltext3:    #8082A0;\n  --lborder:   #E0E1F0;\n  /* results light theme */\n  --r-bg:          #F4F5FF;\n  --r-card:        #FFFFFF;\n  --r-border:      #E4E6F4;\n  --r-text:        #1A1A3E;\n  --r-text2:       #4A4C6A;\n  --r-text3:       #9496B8;\n  --r-section-num: #E8EAFF;\n}\n*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }\nhtml, body { background: #040417; margin: 0; padding: 0; }\nhtml { scroll-behavior: smooth; }\nbody { font-family: var(--font); font-size: 15px; line-height: 1.6; min-height: 100vh; display: flex; flex-direction: column; }\nbody > nav, body > .progress-outer, body > script { flex: 0 0 auto; }\nbody > #splashScreen, body > #questionFlow, body > #optInScreen, body > #analyzingScreen, body > #resultsScreen { flex: 1 0 auto; }\nbody > #nlca-footer { flex: 0 0 auto; margin-top: auto; }\nbody.results-active { background: #F4F5FF; }\nbody.questions-active { background: #F4F5FF; }\n\n/* ── GHL CONTAINER OVERRIDE ── */\n.page-wrapper, .container, .row,\n[data-section], [data-element] {\n  width: 100% !important;\n  max-width: none !important;\n  padding: 0 !important;\n  margin-left: 0 !important;\n  margin-right: 0 !important;\n  float: none !important;\n  box-sizing: border-box !important;\n}\n#splashScreen, #questionFlow, #optInScreen,\n#analyzingScreen, #resultsScreen {\n  position: relative;\n  width: 100vw !important;\n  margin-left: calc(-50vw + 50%) !important;\n  left: 0 !important;\n}\n\n/* ── CUSTOM NAV ── */\n:root { --nav-h: 66px; }\n@media (max-width: 860px) { :root { --nav-h: 54px; } }\n\nnav {\n  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;\n  background: rgb(29, 32, 39);\n  border-bottom: 1px solid rgba(255,255,255,0.06); padding: 6px 0;\n  font-family: 'Manrope', sans-serif;\n  transition: transform 0.3s ease;\n}\nbody.quiz-active nav { transform: translateY(-100%); }\nbody.quiz-active .progress-outer { top: 0; }\nbody.quiz-active #questionFlow { padding-top: 3px; }\nbody.quiz-active #optInScreen  { padding-top: 0; }\nbody.quiz-active #analyzingScreen { padding-top: 0; }\n.nav-inner {\n  display: flex; align-items: center; justify-content: space-between;\n  max-width: 1080px; margin: 0 auto; padding: 0 20px;\n}\n.nav-logo {\n  display: flex; align-items: center; text-decoration: none;\n  cursor: pointer; height: 54px;\n}\n.header-logo-img { height: 100%; width: auto; display: block; object-fit: contain; }\n.nav-cta-btn {\n  font-weight: 800; font-size: 12px; background: #1667E8; color: #FFFFFF;\n  padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer;\n  transition: all .2s; letter-spacing: 0.3px; font-family: 'Manrope', sans-serif;\n  white-space: nowrap;\n}\n.nav-cta-btn:hover { background: #0F4FB5; transform: translateY(-1px); }\n@media (max-width: 860px) {\n  .nav-cta-btn { padding: 8px 14px; font-size: 11px; }\n  .nav-logo { height: 42px; }\n  .nav-inner { padding: 0 15px; }\n}\n\n/* ── PROGRESS ── */\n.progress-outer {\n  position: fixed; top: var(--nav-h); left: 0; right: 0;\n  height: 3px; background: rgba(255,255,255,0.08); z-index: 999;\n  transition: opacity 0.3s;\n}\n.progress-outer.hidden { opacity: 0; }\n.progress-fill {\n  height: 100%; background: var(--blue);\n  transition: width 0.45s cubic-bezier(.4,0,.2,1);\n  border-radius: 0 2px 2px 0;\n}\n\n/* ══ SPLASH ══ */\n#splashScreen {\n  background: var(--charcoal);\n  display: flex; flex-direction: column;\n  position: relative; overflow: hidden;\n  padding-top: var(--nav-h);\n}\n#splashScreen::before {\n  content: ''; position: absolute; inset: 0; pointer-events: none;\n  background-image: radial-gradient(circle, rgba(22,103,232,0.055) 1px, transparent 1px);\n  background-size: 30px 30px;\n}\n#splashScreen::after {\n  content: ''; position: absolute; inset: 0; pointer-events: none;\n  background:\n    radial-gradient(ellipse 60% 60% at 30% 10%, rgba(22,103,232,0.10) 0%, transparent 60%),\n    radial-gradient(ellipse 40% 50% at 80% 90%, rgba(22,103,232,0.06) 0%, transparent 60%);\n}\n.sp-nav {\n  position: relative; z-index: 2;\n  display: flex; justify-content: space-between; align-items: center;\n  padding: 0 48px; height: 64px;\n  border-bottom: 1px solid var(--border);\n}\n.sp-brand {\n  font-size: 15px; font-weight: 800; color: var(--text-p);\n  display: flex; align-items: center; gap: 10px;\n  text-decoration: none; letter-spacing: -0.02em;\n}\n.sp-brand-mark {\n  width: 30px; height: 30px; border-radius: 8px; background: var(--blue);\n  display: flex; align-items: center; justify-content: center;\n  font-weight: 900; font-size: 13px; color: #fff; flex-shrink: 0;\n}\n.sp-nav-trust {\n  font-size: 11px; font-weight: 700; color: var(--text-m);\n  text-transform: uppercase; letter-spacing: 0.08em;\n  display: flex; align-items: center; gap: 7px;\n}\n.sp-nav-trust svg { color: var(--blue); flex-shrink: 0; }\n@media (max-width: 600px) { .sp-nav { padding: 0 20px; } .sp-nav-trust { display: none; } }\n\n.sp-hero {\n  position: relative; z-index: 1; flex: 1;\n  display: flex; flex-direction: column;\n  align-items: center; justify-content: center;\n  text-align: center; padding: 48px 40px 72px;\n  max-width: 1080px; margin: 0 auto; width: 100%;\n}\n@media (max-width: 600px) { .sp-hero { padding: 32px 20px 56px; } }\n.sp-eyebrow {\n  display: inline-flex; align-items: center; gap: 10px;\n  font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 3px;\n  color: var(--blue); padding-left: 18px; position: relative; margin-bottom: 28px;\n}\n.sp-eyebrow::before {\n  content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);\n  width: 10px; height: 2px; background: var(--blue);\n}\n.sp-h1 {\n  font-size: clamp(36px, 5.5vw, 66px); font-weight: 900; color: var(--text-p);\n  line-height: 1.02; letter-spacing: -0.04em; margin-bottom: 22px;\n}\n.sp-h1 em { font-style: normal; color: var(--blue); }\n.sp-sub {\n  font-size: clamp(15px, 2vw, 18px); color: var(--text-s);\n  line-height: 1.7; max-width: 580px; margin: 0 auto 44px;\n}\n.sp-stats {\n  display: flex; gap: 0; margin-bottom: 48px; padding: 18px 24px;\n  background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 12px;\n}\n.sp-stat {\n  display: flex; flex-direction: column; align-items: center;\n  padding: 0 28px; border-right: 1px solid var(--border);\n}\n.sp-stat:last-child { border-right: none; }\n.sp-stat-num {\n  font-size: 28px; font-weight: 900; color: var(--gold);\n  letter-spacing: -1px; line-height: 1; margin-bottom: 4px;\n}\n.sp-stat-label {\n  font-size: 11px; color: var(--text-m); font-weight: 600;\n  text-transform: uppercase; letter-spacing: 0.06em; text-align: center; line-height: 1.3;\n}\n@media (max-width: 560px) { .sp-stats { padding: 14px 12px; } .sp-stat { padding: 0 14px; } .sp-stat-num { font-size: 22px; } }\n\n.sp-benefits {\n  display: flex; flex-wrap: wrap; gap: 10px;\n  justify-content: center; margin-bottom: 48px; max-width: 640px;\n}\n.sp-benefit-chip {\n  display: inline-flex; align-items: center; gap: 8px;\n  background: var(--blue-bg); border: 1px solid var(--blue-bdr); border-radius: 999px;\n  padding: 7px 16px; font-size: 13px; color: var(--text-s); font-weight: 600;\n}\n.sp-benefit-chip svg { color: var(--blue); flex-shrink: 0; }\n\n.sp-start-btn {\n  display: inline-flex; align-items: center; gap: 10px;\n  background: var(--blue); color: #fff; font-family: var(--font);\n  font-size: 17px; font-weight: 800; padding: 18px 40px; border-radius: 12px;\n  border: none; cursor: pointer; letter-spacing: -0.02em;\n  box-shadow: 0 4px 24px var(--blue-glow);\n  transition: background .15s, transform .1s, box-shadow .2s; margin-bottom: 16px;\n}\n.sp-start-btn:hover { background: var(--blue-dk); box-shadow: 0 8px 36px var(--blue-glow); transform: translateY(-2px); }\n.sp-start-note {\n  font-size: 12px; color: var(--text-m);\n  display: flex; align-items: center; gap: 5px; justify-content: center;\n}\n\n/* ══ QUESTION FLOW ══ */\n#questionFlow {\n  display: none; padding-top: calc(var(--nav-h) + 3px);\n  background: var(--lbg); flex-direction: column;\n  align-items: center; justify-content: center;\n}\n#questionFlow.active { display: flex; }\n.step-panel {\n  display: none; width: 100%; max-width: 620px;\n  padding: 52px 32px 44px; flex-direction: column; gap: 22px;\n  animation: riseIn 0.36s cubic-bezier(.22,1,.36,1) forwards;\n}\n.step-panel.active { display: flex; }\n@keyframes riseIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }\n\n.q-meta { display: flex; align-items: center; gap: 10px; }\n.q-num-pill {\n  font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;\n  color: var(--blue); background: var(--blue-bg); padding: 4px 13px;\n  border-radius: 20px; border: 1px solid var(--blue-bdr);\n}\n.q-progress-text { font-size: 12px; color: var(--ltext3); }\n.q-text { font-size: clamp(20px, 3.5vw, 27px); font-weight: 800; color: var(--ltext); line-height: 1.2; letter-spacing: -0.03em; }\n.q-context {\n  font-size: 13px; color: var(--ltext3); font-style: italic; line-height: 1.6;\n  padding: 10px 14px; background: var(--lbg2);\n  border-left: 3px solid var(--blue); border-radius: 0 6px 6px 0;\n}\n\n/* ── CROSS-BROWSER BUTTON RESET ──\n   Forces consistent click behavior across Safari macOS/iOS and Mac browsers.\n   Without -webkit-appearance:none, Safari draws native button chrome that can\n   intercept clicks. touch-action prevents trackpad/scroll conflicts. */\nbutton, .choice-btn, .btn-next, .btn-back, .rg-submit,\n.nav-cta-btn, .sp-start-btn {\n  -webkit-appearance: none !important;\n  -moz-appearance: none !important;\n  appearance: none !important;\n  -webkit-user-select: none;\n  user-select: none;\n  -webkit-tap-highlight-color: rgba(22,103,232,0.18);\n  touch-action: manipulation;\n}\nbutton:focus-visible, .choice-btn:focus-visible, .btn-next:focus-visible,\n.btn-back:focus-visible, .rg-submit:focus-visible, .nav-cta-btn:focus-visible,\n.sp-start-btn:focus-visible {\n  outline: 2px solid var(--blue);\n  outline-offset: 2px;\n}\n\n.choices { display: flex; flex-direction: column; gap: 10px; }\n.choice-btn {\n  width: 100%; padding: 14px 18px; background: var(--lcard);\n  border: 1.5px solid var(--lborder); border-radius: 10px;\n  font-family: var(--font); font-size: 14.5px; font-weight: 600;\n  color: var(--ltext2); cursor: pointer; text-align: left;\n  transition: all .13s; display: flex; align-items: center; gap: 12px;\n}\n.choice-btn:hover { border-color: var(--blue); color: var(--ltext); background: var(--lbg2); transform: translateX(3px); }\n.choice-btn.selected { border-color: var(--blue); color: var(--navy); background: var(--blue-bg); font-weight: 700; }\n.choice-indicator {\n  width: 20px; height: 20px; border-radius: 50%; border: 2px solid var(--lborder);\n  flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all .13s;\n}\n.choice-btn.selected .choice-indicator { border-color: var(--blue); background: var(--blue); }\n.choice-btn.selected .choice-indicator::after { content: ''; width: 7px; height: 7px; border-radius: 50%; background: #fff; }\n\n.slider-wrap { display: flex; flex-direction: column; gap: 20px; }\n.slider-value-row { display: flex; align-items: baseline; gap: 10px; }\n.slider-big-val { font-size: clamp(48px, 9vw, 72px); font-weight: 900; color: var(--blue); letter-spacing: -0.04em; line-height: 1; }\n.slider-unit { font-size: 14px; font-weight: 600; color: var(--ltext3); line-height: 1.3; max-width: 120px; }\n.slider-track-wrap { position: relative; padding: 6px 0; }\ninput[type=range].q-slider {\n  -webkit-appearance: none; appearance: none; width: 100%; height: 6px;\n  border-radius: 3px; background: var(--lborder); outline: none; cursor: pointer;\n}\ninput[type=range].q-slider::-webkit-slider-thumb {\n  -webkit-appearance: none; width: 28px; height: 28px; border-radius: 50%;\n  background: var(--blue); border: 3px solid #fff;\n  box-shadow: 0 2px 10px rgba(22,103,232,0.40); cursor: pointer;\n}\ninput[type=range].q-slider::-moz-range-thumb {\n  width: 28px; height: 28px; border-radius: 50%; background: var(--blue);\n  border: 3px solid #fff; box-shadow: 0 2px 10px rgba(22,103,232,0.40); cursor: pointer;\n}\n.slider-rail-labels { display: flex; justify-content: space-between; margin-top: 8px; font-size: 11px; font-weight: 600; color: var(--ltext3); }\n.slider-benchmark {\n  display: inline-flex; align-items: center; gap: 7px;\n  font-size: 12px; font-weight: 600; color: var(--ltext3);\n  background: var(--lbg2); border: 1px solid var(--lborder); border-radius: 20px;\n  padding: 5px 14px; align-self: flex-start;\n}\n.slider-benchmark-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--blue); flex-shrink: 0; }\n\n.btn-next {\n  width: 100%; padding: 14px 24px; background: var(--blue); color: #fff;\n  font-family: var(--font); font-weight: 800; font-size: 15px;\n  border: none; border-radius: 10px; cursor: pointer; letter-spacing: -0.01em;\n  transition: background .2s, transform .1s, box-shadow .2s;\n  display: flex; align-items: center; justify-content: center; gap: 6px;\n  box-shadow: 0 4px 16px var(--blue-glow);\n}\n.btn-next:hover:not(:disabled) { background: var(--blue-dk); box-shadow: 0 6px 24px var(--blue-glow); transform: translateY(-1px); }\n.btn-next:disabled { background: var(--lborder); color: var(--ltext3); cursor: not-allowed; box-shadow: none; }\n.btn-back { background: none; border: none; font-family: var(--font); font-size: 13px; color: var(--ltext3); cursor: pointer; padding: 4px 0; text-align: center; transition: color .15s; }\n.btn-back:hover { color: var(--ltext2); }\n\n/* ══ ANALYZING ══ */\n#analyzingScreen {\n  display: none; background: var(--charcoal);\n  flex-direction: column; align-items: center; justify-content: center;\n  position: relative; overflow: hidden; padding-top: var(--nav-h);\n}\n#analyzingScreen::before {\n  content: ''; position: absolute; inset: 0; pointer-events: none;\n  background: radial-gradient(ellipse 60% 60% at 50% 40%, rgba(22,103,232,0.09) 0%, transparent 70%);\n}\n#analyzingScreen.active { display: flex; }\n.analyzing-wrap {\n  display: flex; flex-direction: column; align-items: center; text-align: center; gap: 32px;\n  padding: 40px 24px; max-width: 460px;\n  animation: riseIn 0.38s cubic-bezier(.22,1,.36,1) forwards; position: relative;\n}\n.spinner-ring {\n  width: 54px; height: 54px; border: 3px solid rgba(255,255,255,0.07);\n  border-top-color: var(--blue); border-radius: 50%; animation: spin .75s linear infinite;\n}\n@keyframes spin { to { transform: rotate(360deg); } }\n.analyzing-h { font-size: 26px; font-weight: 800; color: var(--text-p); letter-spacing: -0.03em; }\n.analyzing-sub { font-size: 14px; color: var(--text-m); }\n.check-list { display: flex; flex-direction: column; gap: 12px; text-align: left; min-width: 280px; }\n.check-item { display: flex; align-items: center; gap: 12px; font-size: 13.5px; color: var(--text-s); opacity: 0; animation: fadeUp .45s ease forwards; }\n.check-item:nth-child(1) { animation-delay: .30s; }\n.check-item:nth-child(2) { animation-delay: .90s; }\n.check-item:nth-child(3) { animation-delay: 1.50s; }\n.check-icon { width: 24px; height: 24px; background: var(--blue-bg); border: 1px solid var(--blue-bdr); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--blue); flex-shrink: 0; }\n@keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }\n\n/* ══ OPT-IN SCREEN ══ */\n#optInScreen {\n  display: none; background: var(--charcoal);\n  flex-direction: column; align-items: center; justify-content: center;\n  position: relative; overflow: hidden; padding-top: var(--nav-h);\n}\n#optInScreen::before {\n  content: ''; position: absolute; inset: 0; pointer-events: none;\n  background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(22,103,232,0.10) 0%, transparent 70%);\n}\n#optInScreen.active { display: flex; }\n.optin-card {\n  position: relative; z-index: 1;\n  max-width: 560px; width: 100%; padding: 48px 32px;\n  text-align: center;\n  animation: riseIn 0.38s cubic-bezier(.22,1,.36,1) forwards;\n}\n.optin-badge { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; color: var(--blue); background: var(--blue-bg); border: 1px solid var(--blue-bdr); border-radius: 999px; padding: 5px 14px; margin-bottom: 20px; }\n.optin-h { font-size: clamp(22px, 4vw, 30px); font-weight: 900; color: var(--text-p); letter-spacing: -0.03em; margin-bottom: 10px; line-height: 1.2; }\n.optin-sub { font-size: 15px; color: var(--text-s); line-height: 1.7; max-width: 440px; margin: 0 auto 28px; }\n@media (max-width: 600px) { .optin-card { padding: 40px 20px; } }\n\n.rg-form { max-width: 420px; margin: 0 auto; }\n.rg-fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }\n.rg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }\n@media (max-width: 480px) { .rg-row { grid-template-columns: 1fr; } }\n.rg-field { display: flex; flex-direction: column; gap: 4px; text-align: left; }\n.rg-label { font-size: 11.5px; font-weight: 700; color: var(--text-s); }\n.req-star { color: var(--red); margin-right: 2px; }\n.rg-input {\n  height: 46px; padding: 0 14px;\n  background: rgba(255,255,255,0.06); border: 1.5px solid var(--border);\n  border-radius: 9px; font-family: var(--font); font-size: 14px; color: var(--text-p);\n  outline: none; width: 100%; transition: border-color .2s, box-shadow .2s;\n}\n.rg-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px var(--blue-glow); }\n.rg-input::placeholder { color: var(--text-m); }\n.rg-field.has-error .rg-input { border-color: var(--red); box-shadow: 0 0 0 3px rgba(239,68,68,0.12); }\n.rg-field-err { font-size: 11px; color: var(--red); display: none; }\n.rg-field.has-error .rg-field-err { display: block; }\n.rg-submit {\n  width: 100%; padding: 15px; background: var(--blue); color: #fff;\n  font-family: var(--font); font-weight: 800; font-size: 15px;\n  border: none; border-radius: 10px; cursor: pointer;\n  display: flex; align-items: center; justify-content: center; gap: 9px;\n  letter-spacing: -0.01em; transition: background .15s, transform .1s, box-shadow .2s;\n  box-shadow: 0 4px 18px var(--blue-glow); margin-bottom: 12px;\n}\n.rg-submit:hover { background: var(--blue-dk); box-shadow: 0 8px 30px var(--blue-glow); transform: translateY(-1px); }\n.rg-fine { font-size: 11px; color: var(--text-m); display: flex; align-items: center; justify-content: center; gap: 5px; }\n.consent-wrap { display: flex; flex-direction: column; gap: 10px; margin: 16px 0 4px; }\n.consent-item { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; }\n.consent-item input[type=\"checkbox\"] { width: 18px; height: 18px; min-width: 18px; margin-top: 2px; cursor: pointer; accent-color: var(--blue); }\n.consent-item span { font-size: 11.5px; color: var(--text-s); line-height: 1.55; }\n.consent-item.has-error span { color: #ff6b6b; }\n.consent-item.has-error input[type=\"checkbox\"] { outline: 2px solid #ff6b6b; border-radius: 2px; }\n.consent-err { display: none; font-size: 11px; color: #ff6b6b; font-weight: 700; margin-top: 4px; padding-left: 28px; }\n.consent-item.has-error + .consent-err { display: block; }\n.rg-thankyou { display: none; flex-direction: column; align-items: center; gap: 14px; padding: 10px 0; }\n.rg-thankyou.visible { display: flex; }\n.rg-ty-icon { width: 52px; height: 52px; border-radius: 50%; background: var(--blue-bg); border: 2px solid var(--blue-bdr); display: flex; align-items: center; justify-content: center; font-size: 20px; }\n.rg-ty-title { font-size: 19px; font-weight: 900; color: var(--text-p); letter-spacing: -0.03em; }\n.rg-ty-sub { font-size: 14px; color: var(--text-s); line-height: 1.65; max-width: 380px; text-align: center; }\n\n/* ══ RESULTS ══ */\n\n#resultsScreen { display: none; background: var(--r-bg); flex-direction: column; align-items: center; }\n#resultsScreen.active { display: flex; }\n.res-nav {\n  width: 100%; background: #fff; border-bottom: 1px solid var(--r-border);\n  padding: 0 44px; height: 64px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;\n  box-shadow: 0 1px 0 var(--r-border);\n}\n.res-brand { font-size: 15px; font-weight: 800; color: var(--r-text); display: flex; align-items: center; gap: 10px; text-decoration: none; letter-spacing: -0.02em; }\n.res-brand-mark { width: 30px; height: 30px; border-radius: 8px; background: var(--blue); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 12px; color: #fff; flex-shrink: 0; }\n@media (max-width: 600px) { .res-nav { padding: 0 20px; } }\n\n.results-body {\n  width: 100%; max-width: 800px; padding: 0;\n  display: flex; flex-direction: column; gap: 0;\n  animation: riseIn 0.5s cubic-bezier(.22,1,.36,1) forwards;\n}\n@media (max-width: 600px) { .results-body { padding: 0; } }\n\n/* ── Results header (replaces gap-hero) ── */\n.results-header {\n  background: linear-gradient(160deg, #1667E8 0%, #0F4FB5 100%);\n  padding: 56px 48px 48px;\n  color: white;\n  position: relative;\n  overflow: hidden;\n}\n.results-header::before {\n  content: ''; position: absolute; inset: 0; pointer-events: none;\n  background-image: radial-gradient(circle, rgba(255,255,255,0.05) 1px, transparent 1px);\n  background-size: 28px 28px;\n}\n.results-header::after {\n  content: ''; position: absolute; inset: 0; pointer-events: none;\n  background: radial-gradient(ellipse 60% 80% at 100% 0%, rgba(255,255,255,0.06) 0%, transparent 60%);\n}\n.rh-inner { position: relative; z-index: 1; }\n.rh-eyebrow {\n  font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;\n  color: rgba(255,255,255,0.70); margin-bottom: 16px; display: block;\n}\n.rh-title {\n  font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff;\n  line-height: 1.06; letter-spacing: -0.04em; margin-bottom: 12px;\n}\n.rh-title em { font-style: normal; color: #93C5FD; }\n.rh-sub { opacity: 0.75; font-size: 15px; line-height: 1.6; }\n.rh-cta-btn {\n  display: inline-flex; align-items: center; gap: 8px;\n  background: rgba(255,255,255,0.15); color: #fff; font-family: var(--font);\n  font-weight: 800; font-size: 15px; padding: 13px 26px; border-radius: 10px;\n  text-decoration: none; cursor: pointer; border: 1.5px solid rgba(255,255,255,0.30);\n  transition: background .15s, transform .1s; margin-top: 28px; letter-spacing: -0.01em;\n  -webkit-backdrop-filter: blur(6px);\n  backdrop-filter: blur(6px);\n}\n.rh-cta-btn:hover { background: rgba(255,255,255,0.22); transform: translateY(-1px); }\n@media (max-width: 600px) { .results-header { padding: 36px 24px 32px; } }\n\n/* ── Numbered report sections ── */\n.report-section {\n  background: #fff;\n  border-bottom: 1px solid var(--r-border);\n  padding: 48px 48px;\n  box-shadow: 0 2px 12px rgba(0,0,0,0.03);\n}\n@media (max-width: 600px) { .report-section { padding: 32px 20px; } }\n.section-num-row { display: flex; align-items: center; gap: 14px; margin-bottom: 6px; }\n.section-num {\n  width: 38px; height: 38px; border-radius: 50%;\n  background: var(--r-section-num); color: var(--blue);\n  font-weight: 900; font-size: 17px;\n  display: flex; align-items: center; justify-content: center; flex-shrink: 0;\n}\n.section-label-tag {\n  font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;\n  color: var(--r-text3);\n}\n.section-heading {\n  font-size: clamp(22px, 3vw, 30px); font-weight: 900; color: var(--r-text);\n  letter-spacing: -0.03em; margin-bottom: 8px; line-height: 1.1;\n}\n.section-intro { font-size: 15px; color: var(--r-text2); line-height: 1.7; margin-bottom: 32px; }\n\n/* ── Trait bars (section ①) ── */\n.trait-bars { display: flex; flex-direction: column; gap: 16px; }\n.trait-row { display: grid; grid-template-columns: 170px 1fr auto; align-items: center; gap: 16px; }\n@media (max-width: 560px) { .trait-row { grid-template-columns: 1fr; gap: 6px; } }\n.trait-label { font-size: 14px; font-weight: 600; color: var(--r-text2); }\n.trait-track { height: 10px; background: var(--r-border); border-radius: 5px; overflow: hidden; }\n.trait-fill { height: 100%; border-radius: 5px; transition: width 0.8s cubic-bezier(.4,0,.2,1); }\n.trait-fill.sev-critical { background: linear-gradient(90deg, #EF4444, #F87171); width: 18%; }\n.trait-fill.sev-warning  { background: linear-gradient(90deg, #F59E0B, #FCD34D); width: 52%; }\n.trait-fill.sev-ok       { background: linear-gradient(90deg, #10B981, #34D399); width: 88%; }\n.trait-badge {\n  font-size: 12px; font-weight: 700; white-space: nowrap;\n  padding: 3px 12px; border-radius: 20px;\n}\n.trait-badge.sev-critical { color: #DC2626; background: #FEE2E2; }\n.trait-badge.sev-warning  { color: #D97706; background: #FEF3C7; }\n.trait-badge.sev-ok       { color: #059669; background: #D1FAE5; }\n\n/* ── Math rows (section ②) ── */\n.math-block { background: var(--r-card); border: 1px solid var(--r-border); border-radius: 14px; padding: 28px 32px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }\n.math-block-title { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--r-text2); margin-bottom: 20px; }\n.math-rows { display: flex; flex-direction: column; }\n.math-row { display: flex; justify-content: space-between; align-items: center; padding: 13px 0; border-bottom: 1px solid var(--r-border); font-size: 14px; }\n.math-row:last-child { border-bottom: none; }\n.math-label { color: var(--r-text2); font-weight: 500; }\n.math-value { font-weight: 800; color: var(--r-text); font-size: 15px; }\n.math-row.gap-row {\n  padding: 20px 18px;\n  margin: 8px -18px;\n  background: linear-gradient(135deg, rgba(22,103,232,0.06) 0%, rgba(22,103,232,0.02) 100%);\n  border-radius: 10px;\n  border-bottom: none;\n  border-top: none;\n}\n.math-row.gap-row .math-label {\n  font-size: 13px; font-weight: 700; color: var(--r-text); letter-spacing: -0.01em;\n}\n.math-value.highlight {\n  font-size: clamp(28px, 5vw, 38px);\n  font-weight: 900;\n  letter-spacing: -0.04em;\n  line-height: 1;\n  background: linear-gradient(90deg, var(--blue) 0%, #4D9BF8 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n.math-assumption { margin-top: 16px; font-size: 12px; color: var(--r-text3); line-height: 1.6; font-style: italic; }\n\n/* ── Section cards (section ③) ── */\n.section-cards-wrap { display: flex; flex-direction: column; gap: 16px; }\n.section-card {\n  background: var(--r-card);\n  border: 1px solid var(--r-border);\n  border-left: 4px solid var(--r-border);\n  border-radius: 0 14px 14px 0;\n  overflow: hidden;\n  transition: box-shadow 0.2s;\n  box-shadow: 0 2px 12px rgba(0,0,0,0.04);\n}\n.section-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.09); }\n.section-card[data-sev=\"critical\"] { border-left-color: var(--red); }\n.section-card[data-sev=\"warning\"]  { border-left-color: var(--amber); }\n.card-inner { padding: 24px 28px; display: flex; flex-direction: column; gap: 16px; }\n@media (max-width: 600px) { .card-inner { padding: 18px 18px; } }\n.section-badge-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }\n.sev-chip { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; padding: 3px 10px; border-radius: 20px; }\n.sev-chip.sev-critical { background: #FEE2E2; color: #B91C1C; border: 1px solid rgba(239,68,68,0.20); }\n.sev-chip.sev-warning  { background: #FEF3C7; color: #92400E; border: 1px solid rgba(245,158,11,0.22); }\n.section-area { font-size: 13px; font-weight: 700; color: var(--r-text3); letter-spacing: 0.02em; text-transform: uppercase; }\n.section-problem { font-size: clamp(16px, 2.5vw, 19px); font-weight: 800; color: var(--r-text); line-height: 1.28; letter-spacing: -0.025em; }\n.section-impact {\n  background: var(--r-bg);\n  border-left: 3px solid rgba(239,68,68,0.28);\n  padding: 13px 15px;\n  border-radius: 0 7px 7px 0;\n  font-size: 14px; color: var(--r-text2); line-height: 1.68;\n}\n.section-card[data-sev=\"warning\"] .section-impact { border-left-color: rgba(245,158,11,0.32); }\n.manual-toggle { border: 1px solid var(--r-border); border-radius: 8px; overflow: hidden; }\n.manual-toggle summary { padding: 11px 16px; font-size: 13px; font-weight: 700; color: var(--r-text2); cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; -webkit-user-select: none; user-select: none; transition: background .12s; }\n.manual-toggle summary::-webkit-details-marker { display: none; }\n.manual-toggle summary::after { content: '▸'; font-size: 11px; color: var(--r-text3); transition: transform 0.2s; flex-shrink: 0; }\n.manual-toggle[open] summary::after { transform: rotate(90deg); }\n.manual-toggle summary:hover { background: var(--r-bg); }\n.fix-steps { padding: 12px 16px 14px 34px; display: flex; flex-direction: column; gap: 8px; border-top: 1px solid var(--r-border); list-style: disc; }\n.fix-steps li { font-size: 13px; color: var(--r-text2); line-height: 1.6; }\n.card-toggles { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }\n@media (max-width: 620px) { .card-toggles { grid-template-columns: 1fr; } }\n.nlca-toggle { border-color: var(--blue-bdr); }\n.nlca-toggle summary { color: var(--blue); background: var(--blue-bg); }\n.nlca-toggle summary:hover { background: rgba(22,103,232,0.18); }\n.nlca-toggle summary::after { color: var(--blue); }\n.nlca-detail { padding: 12px 16px 14px; font-size: 13px; color: var(--r-text2); line-height: 1.65; border-top: 1px solid var(--blue-bdr); background: rgba(22,103,232,0.03); }\n\n/* print compat stub */\n.full-report { display: flex; flex-direction: column; gap: 0; }\n.full-report-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 24px; }\n.full-report-label { font-size: 17px; font-weight: 800; color: var(--r-text); letter-spacing: -0.03em; }\n.pdf-btn {\n  display: inline-flex; align-items: center; gap: 7px;\n  background: var(--r-card); border: 1.5px solid var(--r-border);\n  border-radius: 8px; padding: 9px 18px;\n  font-family: var(--font); font-size: 13px; font-weight: 700;\n  color: var(--r-text2); cursor: pointer; transition: all .15s;\n}\n.pdf-btn:hover { border-color: var(--blue); color: var(--blue); }\n\n/* ── Learning Path (section ④) — white card style ── */\n.learning-path { background: #fff; border-bottom: 1px solid var(--r-border); padding: 48px 48px; }\n@media (max-width: 600px) { .learning-path { padding: 32px 20px; } }\n.lp-inner { position: relative; }\n.lp-eyebrow {\n  font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;\n  color: var(--r-text3); margin-bottom: 6px; display: block;\n}\n.lp-headline { font-size: clamp(22px, 3.5vw, 30px); font-weight: 900; color: var(--r-text); letter-spacing: -0.04em; line-height: 1.1; margin-bottom: 8px; }\n.lp-sub { font-size: 15px; color: var(--r-text2); line-height: 1.65; margin-bottom: 32px; max-width: 520px; }\n.lp-steps { display: flex; flex-direction: column; gap: 0; margin-bottom: 36px; }\n.lp-step {\n  display: flex; align-items: flex-start; gap: 20px;\n  padding: 22px 0; border-bottom: 1px solid var(--r-border);\n}\n.lp-step:last-child { border-bottom: none; }\n.lp-step-num {\n  width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0;\n  background: var(--r-section-num); color: var(--blue);\n  font-weight: 900; font-size: 16px;\n  display: flex; align-items: center; justify-content: center;\n  margin-top: 2px;\n}\n.lp-step-body { flex: 1; }\n.lp-step-name { font-size: 16px; font-weight: 800; color: var(--r-text); letter-spacing: -0.02em; margin-bottom: 6px; }\n.lp-step-desc { font-size: 14px; color: var(--r-text2); line-height: 1.68; margin-bottom: 10px; }\n.lp-step-tags { display: flex; flex-wrap: wrap; gap: 6px; }\n.lp-tag { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; padding: 3px 10px; border-radius: 20px; }\n.lp-tag.lp-critical { background: #FEE2E2; color: #DC2626; border: 1px solid rgba(239,68,68,0.20); }\n.lp-tag.lp-warning  { background: #FEF3C7; color: #D97706; border: 1px solid rgba(245,158,11,0.20); }\n.lp-cta-wrap { text-align: center; padding-top: 8px; }\n.lp-cta-btn {\n  display: inline-flex; align-items: center; gap: 8px;\n  background: var(--blue); color: #fff; font-family: var(--font);\n  font-weight: 800; font-size: 16px; padding: 16px 36px; border-radius: 10px;\n  text-decoration: none; letter-spacing: -0.01em; margin-bottom: 12px;\n  transition: background .15s, transform .1s, box-shadow .2s;\n  box-shadow: 0 4px 24px var(--blue-glow);\n}\n.lp-cta-btn:hover { background: var(--blue-dk); box-shadow: 0 8px 36px var(--blue-glow); transform: translateY(-1px); }\n.lp-fine { font-size: 12px; color: var(--r-text3); margin-top: 10px; }\n\n/* ── Social proof band ── */\n.social-proof-band { background: #fff; border-bottom: 1px solid var(--r-border); padding: 48px 48px; }\n@media (max-width: 600px) { .social-proof-band { padding: 32px 20px; } }\n\n/* stacy pull quote — light version */\n.stacy-pull {\n  background: var(--r-bg);\n  border-radius: 14px;\n  padding: 32px 36px 28px;\n  position: relative;\n  overflow: hidden;\n  border: 1px solid var(--r-border);\n  margin-bottom: 24px;\n}\n.stacy-pull-mark {\n  font-size: clamp(64px, 10vw, 96px);\n  color: var(--blue);\n  opacity: 0.13;\n  line-height: 0.8;\n  font-family: Georgia, 'Times New Roman', serif;\n  margin-bottom: -12px;\n  display: block;\n  letter-spacing: -0.05em;\n  position: relative;\n}\n.stacy-pull-text {\n  font-size: clamp(16px, 2.2vw, 19px);\n  color: var(--r-text2);\n  line-height: 1.68;\n  font-style: italic;\n  margin-bottom: 18px;\n  position: relative;\n  font-weight: 500;\n}\n.stacy-pull-attr { font-size: 12px; color: var(--r-text3); font-style: normal; position: relative; }\n.stacy-pull-attr strong { color: var(--blue); font-weight: 700; }\n\n/* stacy's take — light card */\n.stacy-take { background: var(--r-card); border: 1px solid var(--r-border); border-radius: 14px; padding: 32px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }\n.st-inner { position: relative; }\n.st-header { display: flex; align-items: flex-start; gap: 18px; margin-bottom: 22px; }\n.st-avatar { width: 52px; height: 52px; border-radius: 50%; flex-shrink: 0; background: var(--r-section-num); border: 2px solid var(--r-border); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 16px; color: var(--blue); }\n.st-meta { flex: 1; padding-top: 4px; }\n.st-name { font-size: 14px; font-weight: 800; color: var(--r-text); margin-bottom: 2px; }\n.st-role { font-size: 12px; color: var(--r-text3); }\n.st-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; display: block; }\n.st-headline { font-size: clamp(18px, 2.5vw, 22px); font-weight: 900; color: var(--r-text); letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 14px; }\n.st-body { font-size: 15px; color: var(--r-text2); line-height: 1.72; font-style: italic; }\n\n/* testimonials — light grid */\n.testimonials { display: flex; flex-direction: column; gap: 12px; }\n.testimonial-card {\n  border: 1px solid var(--r-border);\n  border-radius: 12px;\n  padding: 22px 24px;\n  display: grid;\n  grid-template-rows: auto 1fr auto;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.04);\n}\n.testimonial-card:nth-child(1) { background: var(--r-card); }\n.testimonial-card:nth-child(2) { background: #F0F4FF; border-color: rgba(22,103,232,0.12); }\n.testimonial-card:nth-child(3) { background: #FFFBEB; border-color: rgba(245,158,11,0.15); }\n.t-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }\n.t-avatar {\n  width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;\n  display: flex; align-items: center; justify-content: center;\n  font-size: 12px; font-weight: 900; letter-spacing: -0.02em;\n}\n.testimonial-card:nth-child(1) .t-avatar { background: var(--blue-bg); color: var(--blue); border: 1px solid var(--blue-bdr); }\n.testimonial-card:nth-child(2) .t-avatar { background: rgba(16,185,129,0.10); color: var(--green); border: 1px solid rgba(16,185,129,0.20); }\n.testimonial-card:nth-child(3) .t-avatar { background: rgba(245,158,11,0.12); color: #D97706; border: 1px solid rgba(245,158,11,0.22); }\n.t-stars { color: var(--gold); font-size: 13px; letter-spacing: 1.5px; line-height: 1; }\n.t-quote { font-size: 14.5px; color: var(--r-text2); line-height: 1.6; margin-bottom: 12px; }\n.t-footer { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; }\n.t-attr { font-size: 12px; font-weight: 700; color: var(--r-text3); }\n.t-result { display: inline-flex; align-items: center; gap: 5px; font-size: 11.5px; font-weight: 700; color: var(--green); background: rgba(16,185,129,0.08); padding: 3px 10px; border-radius: 20px; border: 1px solid rgba(16,185,129,0.15); }\n\n/* video testimonials — light */\n.video-testimonials { background: var(--r-bg); border-top: 1px solid var(--r-border); padding: 48px 48px; }\n@media (max-width: 640px) { .video-testimonials { padding: 32px 20px; } }\n.vt-header { margin-bottom: 28px; }\n.vt-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: var(--r-text3); margin-bottom: 6px; display: block; }\n.vt-headline { font-size: clamp(20px, 3vw, 26px); font-weight: 900; color: var(--r-text); letter-spacing: -0.04em; line-height: 1.1; }\n.vt-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }\n@media (max-width: 640px) { .vt-grid { grid-template-columns: 1fr; } }\n.vt-tile { background: var(--r-card); border: 1px solid var(--r-border); border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }\n.vt-video { width: 100%; display: block; background: #000; aspect-ratio: 16/9; }\n.vt-info { padding: 14px 16px 18px; }\n.vt-quote { font-size: 13px; color: var(--r-text2); line-height: 1.62; font-style: italic; margin-bottom: 10px; }\n.vt-name { font-size: 13px; font-weight: 800; color: var(--r-text); letter-spacing: -0.01em; }\n.vt-role { font-size: 11px; color: var(--r-text3); margin-top: 3px; }\n\n/* cta section — dark exception (stays dark, standard practice) */\n.cta-section { background: var(--charcoal); padding: 56px 48px; text-align: center; position: relative; overflow: hidden; }\n.cta-section::before { content: ''; position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(22,103,232,0.10) 0%, transparent 70%); }\n.cta-section-content { position: relative; z-index: 1; }\n.cta-section h2 { font-size: clamp(22px, 3.5vw, 32px); font-weight: 900; color: var(--text-p); letter-spacing: -0.04em; line-height: 1.12; margin-bottom: 12px; }\n.cta-section p { font-size: 15px; color: var(--text-s); line-height: 1.7; max-width: 480px; margin: 0 auto 28px; }\n.cta-section-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--blue); color: #fff; font-family: var(--font); font-weight: 800; font-size: 16px; padding: 16px 36px; border-radius: 10px; text-decoration: none; letter-spacing: -0.01em; transition: background .15s, transform .1s, box-shadow .2s; box-shadow: 0 4px 24px var(--blue-glow); }\n.cta-section-btn:hover { background: var(--blue-dk); box-shadow: 0 8px 36px var(--blue-glow); transform: translateY(-1px); }\n.cta-fine { margin-top: 14px; font-size: 12px; color: var(--text-m); }\n@media (max-width: 600px) { .cta-section { padding: 40px 24px; } }\n\n/* low vol */\n.low-intent-block { background: var(--r-card); border: 1px solid var(--r-border); border-radius: 14px; padding: 36px 40px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin: 40px 48px; }\n@media (max-width: 600px) { .low-intent-block { margin: 24px 20px; padding: 24px; } }\n.li-eyebrow { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 3px; color: var(--blue); padding-left: 18px; position: relative; margin-bottom: 14px; display: block; }\n.li-eyebrow::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 10px; height: 2px; background: var(--blue); }\n.li-headline { font-size: 22px; font-weight: 900; color: var(--r-text); letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 12px; }\n.li-body { font-size: 15px; color: var(--r-text2); line-height: 1.7; }\n\n\n@keyframes shake { 0%,100% { transform: translateX(0); } 20% { transform: translateX(-5px); } 40% { transform: translateX(5px); } 60% { transform: translateX(-3px); } 80% { transform: translateX(3px); } }\n.shaking { animation: shake 0.32s ease; }\n\n/* ── VIDEO TESTIMONIALS ── */\n.video-testimonials {\n  background: var(--charcoal); border-radius: 18px; padding: 44px 40px;\n  position: relative; overflow: hidden;\n}\n.video-testimonials::before {\n  content: ''; position: absolute; inset: 0; pointer-events: none;\n  background: radial-gradient(ellipse 60% 60% at 50% 0%, rgba(22,103,232,0.07) 0%, transparent 70%);\n}\n.vt-header { position: relative; z-index: 1; margin-bottom: 32px; }\n.vt-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--blue); padding-left: 18px; position: relative; margin-bottom: 14px; display: block; }\n.vt-eyebrow::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 10px; height: 2px; background: var(--blue); }\n.vt-headline { font-size: clamp(20px, 3vw, 26px); font-weight: 900; color: var(--text-p); letter-spacing: -0.04em; line-height: 1.1; }\n.vt-grid {\n  position: relative; z-index: 1;\n  display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px;\n}\n.vt-tile {\n  background: rgba(255,255,255,0.04);\n  border: 1px solid rgba(255,255,255,0.08);\n  border-radius: 12px; overflow: hidden;\n}\n.vt-video { width: 100%; display: block; background: #000; aspect-ratio: 16/9; }\n.vt-info { padding: 14px 16px 18px; }\n.vt-quote { font-size: 13px; color: var(--text-s); line-height: 1.62; font-style: italic; margin-bottom: 10px; }\n.vt-name { font-size: 13px; font-weight: 800; color: var(--text-p); letter-spacing: -0.01em; }\n.vt-role { font-size: 11px; color: var(--text-m); margin-top: 3px; }\n@media (max-width: 640px) { .video-testimonials { padding: 28px 20px; } .vt-grid { grid-template-columns: 1fr; } }\n\n/* ── PRINT ── */\n@media print {\n  .progress-outer,.topbar,#splashScreen,#questionFlow,#analyzingScreen,#optInScreen,\n  .res-nav,.rh-cta-btn,.cta-section,.results-footer,\n  .pdf-btn,.video-testimonials { display: none !important; }\n  body { background: #fff !important; }\n  #resultsScreen { display: block !important; background: #fff !important; }\n  .results-body { max-width: 100% !important; padding: 0 !important; }\n  .results-header { background: #1667E8 !important; padding: 28px 32px !important; }\n  .math-value.highlight { background: none !important; -webkit-text-fill-color: #1667E8 !important; color: #1667E8 !important; font-size: 24px !important; }\n  .math-row.gap-row { background: #EEF2FF !important; margin: 4px -10px !important; padding: 14px 10px !important; }\n  .section-card { break-inside: avoid; page-break-inside: avoid; }\n  .report-section { border: none !important; box-shadow: none !important; }\n  .learning-path { border: none !important; }\n  .social-proof-band { border: none !important; }\n  .full-report { display: flex !important; }\n  * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }\n}\n\u003C/style>\n\u003C/head>\n\u003Cbody>\n\u003Cscript>\n(function(){\n  var OURS = 'SCRIPT,NAV,FOOTER,#splashScreen,#questionFlow,#optInScreen,#analyzingScreen,#resultsScreen,#nlca-footer,.progress-outer';\n  function isOurs(el){\n    if(!el||el.nodeType!==1)return false;\n    if(el.tagName==='SCRIPT'||el.tagName==='STYLE')return true;\n    var id=el.id||'';\n    if(id==='splashScreen'||id==='questionFlow'||id==='optInScreen'||id==='analyzingScreen'||id==='resultsScreen'||id==='nlca-footer'||id==='progressOuter')return true;\n    if(el.classList&&(el.classList.contains('progress-outer')||el.classList.contains('nav-inner')))return true;\n    /* Our top nav: \u003Cnav> with class nav-inner inside, or first nav element with our logo */\n    if(el.tagName==='NAV'&&el.querySelector&&el.querySelector('.nav-inner,.nav-logo,.nav-cta-btn'))return true;\n    /* Our own injected footer */\n    if(el.tagName==='FOOTER'&&id==='nlca-footer')return true;\n    if(el.querySelector&&el.querySelector('#splashScreen,#questionFlow,#optInScreen,#analyzingScreen,#resultsScreen,#nlca-footer'))return true;\n    return false;\n  }\n  function escapeGHL(){\n    var body=document.body;\n    var anchor=document.getElementById('resultsScreen')||document.getElementById('splashScreen');\n    if(anchor&&anchor.parentElement!==body){\n      var wrap=anchor.parentElement;\n      while(wrap&&wrap.parentElement!==body)wrap=wrap.parentElement;\n      if(wrap){\n        var frag=document.createDocumentFragment();\n        while(wrap.firstChild)frag.appendChild(wrap.firstChild);\n        body.insertBefore(frag,wrap);\n        wrap.parentNode.removeChild(wrap);\n      }\n    }\n    /* Remove any GHL sibling sections (white strips above/below our content) */\n    Array.prototype.slice.call(body.children).forEach(function(child){\n      if(!isOurs(child)){\n        try{child.parentNode.removeChild(child);}catch(e){}\n      }\n    });\n  }\n  window.__nlcaEscapeGHL=escapeGHL;\n  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',escapeGHL);}\n  else{escapeGHL();}\n  /* Catch GHL late-injected elements */\n  setTimeout(escapeGHL,100);\n  setTimeout(escapeGHL,500);\n  setTimeout(escapeGHL,1500);\n  if(window.MutationObserver){\n    var mo=new MutationObserver(function(){escapeGHL();});\n    mo.observe(document.body,{childList:true});\n  }\n})();\n\u003C/script>\n\n\u003Cnav>\n  \u003Cdiv class=\"nav-inner\">\n    \u003Cdiv onclick=\"window.scrollTo({top: 0, behavior: 'smooth'})\" class=\"nav-logo\">\n      \u003Cimg src=\"https://assets.cdn.filesafe.space/vdi6H8skwmbrWBAz1f6X/media/69cf03afbbe1310051fedf42.jpg\" alt=\"Full Arch Sales Experts\" class=\"header-logo-img\">\n    \u003C/div>\n    \u003Cbutton type=\"button\" class=\"nav-cta-btn\">\n      Start Assessment\n      \u003Csvg width=\"13\" height=\"13\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\" style=\"vertical-align:middle;margin-left:4px\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\"/>\u003C/svg>\n    \u003C/button>\n  \u003C/div>\n\u003C/nav>\n\n\u003Cdiv class=\"progress-outer hidden\" id=\"progressOuter\">\n  \u003Cdiv class=\"progress-fill\" id=\"progressFill\" style=\"width:0%\">\u003C/div>\n\u003C/div>\n\n\u003C!-- SPLASH -->\n\u003Cdiv id=\"splashScreen\">\n  \u003Cdiv class=\"sp-hero\">\n    \u003Cdiv class=\"sp-eyebrow\">Free Revenue Audit\u003C/div>\n    \u003Ch1 class=\"sp-h1\">Your consult process has\u003Cbr>a leak. Find out exactly\u003Cbr>\u003Cem>where it is.\u003C/em>\u003C/h1>\n    \u003Cp class=\"sp-sub\">5 questions. 90 seconds. Get a personalized diagnostic report that maps where your full arch cases are breaking down — and which NLCA module fixes it.\u003C/p>\n    \u003Cdiv class=\"sp-stats\">\n      \u003Cdiv class=\"sp-stat\">\u003Cdiv class=\"sp-stat-num\">70%\u003C/div>\u003Cdiv class=\"sp-stat-label\">Close rate\u003Cbr>proven\u003C/div>\u003C/div>\n      \u003Cdiv class=\"sp-stat\">\u003Cdiv class=\"sp-stat-num\">$8M\u003C/div>\u003Cdiv class=\"sp-stat-label\">Revenue\u003Cbr>built\u003C/div>\u003C/div>\n      \u003Cdiv class=\"sp-stat\">\u003Cdiv class=\"sp-stat-num\">5%\u003C/div>\u003Cdiv class=\"sp-stat-label\">Marketing\u003Cbr>spend\u003C/div>\u003C/div>\n    \u003C/div>\n    \u003Cdiv class=\"sp-benefits\">\n      \u003Cspan class=\"sp-benefit-chip\">\u003Csvg width=\"12\" height=\"12\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/>\u003C/svg>Your revenue gap in dollars\u003C/span>\n      \u003Cspan class=\"sp-benefit-chip\">\u003Csvg width=\"12\" height=\"12\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/>\u003C/svg>Where cases are breaking down\u003C/span>\n      \u003Cspan class=\"sp-benefit-chip\">\u003Csvg width=\"12\" height=\"12\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/>\u003C/svg>Why the financing objection keeps coming back\u003C/span>\n      \u003Cspan class=\"sp-benefit-chip\">\u003Csvg width=\"12\" height=\"12\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/>\u003C/svg>Personalized to your numbers\u003C/span>\n    \u003C/div>\n    \u003Cbutton type=\"button\" class=\"sp-start-btn\">\n      Start the Assessment\n      \u003Csvg width=\"18\" height=\"18\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\"/>\u003C/svg>\n    \u003C/button>\n    \u003Cp class=\"sp-start-note\">\n      \u003Csvg width=\"12\" height=\"12\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\"/>\u003C/svg>\n      Free · 5 questions · Report unlocks after\n    \u003C/p>\n  \u003C/div>\n\u003C/div>\n\n\u003C!-- QUESTIONS -->\n\u003Cdiv id=\"questionFlow\">\u003C/div>\n\n\u003C!-- OPT-IN -->\n\u003Cdiv id=\"optInScreen\">\n  \u003Cdiv class=\"optin-card\">\n    \u003Cdiv class=\"optin-badge\">ALMOST THERE\u003C/div>\n    \u003Ch2 class=\"optin-h\">Your revenue audit is ready to generate.\u003C/h2>\n    \u003Cp class=\"optin-sub\">Enter your details below — we'll build your personalized full arch diagnostic right now.\u003C/p>\n    \u003Cdiv class=\"rg-form\">\n      \u003Cdiv class=\"rg-fields\">\n        \u003Cdiv class=\"rg-row\">\n          \u003Cdiv class=\"rg-field\" id=\"rgf-name\">\n            \u003Clabel class=\"rg-label\" for=\"rgName\">\u003Cspan class=\"req-star\">*\u003C/span>Your name\u003C/label>\n            \u003Cinput class=\"rg-input\" type=\"text\" id=\"rgName\" placeholder=\"Dr. Johnson\" autocomplete=\"name\" autocorrect=\"off\"/>\n            \u003Cspan class=\"rg-field-err\">Required\u003C/span>\n          \u003C/div>\n          \u003Cdiv class=\"rg-field\" id=\"rgf-email\">\n            \u003Clabel class=\"rg-label\" for=\"rgEmail\">\u003Cspan class=\"req-star\">*\u003C/span>Email address\u003C/label>\n            \u003Cinput class=\"rg-input\" type=\"email\" id=\"rgEmail\" placeholder=\"you@yourpractice.com\" autocomplete=\"email\"/>\n            \u003Cspan class=\"rg-field-err\">Required\u003C/span>\n          \u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"rg-row\">\n          \u003Cdiv class=\"rg-field\">\n            \u003Clabel class=\"rg-label\" for=\"rgPhone\">Phone number\u003C/label>\n            \u003Cinput class=\"rg-input\" type=\"tel\" id=\"rgPhone\" placeholder=\"+1 512 555 0100\" autocomplete=\"tel\"/>\n          \u003C/div>\n          \u003Cdiv class=\"rg-field\">\n            \u003Clabel class=\"rg-label\" for=\"rgPractice\">Practice name\u003C/label>\n            \u003Cinput class=\"rg-input\" type=\"text\" id=\"rgPractice\" placeholder=\"Johnson Implant Center\" autocomplete=\"organization\" autocorrect=\"off\"/>\n          \u003C/div>\n        \u003C/div>\n      \u003C/div>\n      \u003Cdiv class=\"consent-wrap\">\n        \u003Clabel class=\"consent-item\" id=\"consent1-wrap\">\n          \u003Cinput type=\"checkbox\" id=\"consent1\" onchange=\"document.getElementById('consent1-wrap').classList.remove('has-error');document.getElementById('consent1-err').style.display='none';\"/>\n          \u003Cspan>By checking this box, I consent to receive marketing campaigns from Full Arch Sales Experts. These messages may include appointment reminders, marketing campaigns, order confirmations, and account notifications among others. Message frequency may vary. Message &amp; Data rates may apply. Reply STOP to opt-out. View our \u003Ca href=\"https://fullarchsalesexperts.com/privacy-policy-page\" target=\"_blank\" rel=\"noopener noreferrer\">Privacy Policy\u003C/a>.\u003C/span>\n        \u003C/label>\n        \u003Cdiv class=\"consent-err\" id=\"consent1-err\">Please read the consent above and check the box if you agree.\u003C/div>\n        \u003Clabel class=\"consent-item\" id=\"consent2-wrap\">\n          \u003Cinput type=\"checkbox\" id=\"consent2\" onchange=\"document.getElementById('consent2-wrap').classList.remove('has-error');document.getElementById('consent2-err').style.display='none';\"/>\n          \u003Cspan>I agree to the \u003Ca href=\"https://fullarchsalesexperts.com/terms-of-use\" target=\"_blank\" rel=\"noopener noreferrer\">Terms &amp; Conditions\u003C/a> provided by the company. By providing my phone number, I agree to receive text messages from Full Arch Sales Experts.\u003C/span>\n        \u003C/label>\n        \u003Cdiv class=\"consent-err\" id=\"consent2-err\">Please read the terms above and check the box if you agree.\u003C/div>\n      \u003C/div>\n      \u003Cbutton type=\"button\" class=\"rg-submit\">\n        Generate My Report\n        \u003Csvg width=\"17\" height=\"17\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\"/>\u003C/svg>\n      \u003C/button>\n      \u003Cp class=\"rg-fine\">\n        \u003Csvg width=\"12\" height=\"12\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\"/>\u003C/svg>\n        No spam. You can unsubscribe anytime.\n      \u003C/p>\n    \u003C/div>\n  \u003C/div>\n\u003C/div>\n\n\u003C!-- ANALYZING -->\n\u003Cdiv id=\"analyzingScreen\">\n  \u003Cdiv class=\"analyzing-wrap\">\n    \u003Cdiv class=\"spinner-ring\">\u003C/div>\n    \u003Cdiv>\n      \u003Cdiv class=\"analyzing-h\">Building your report…\u003C/div>\n      \u003Cdiv class=\"analyzing-sub\">Mapping your answers to Stacy's framework\u003C/div>\n    \u003C/div>\n    \u003Cdiv class=\"check-list\">\n      \u003Cdiv class=\"check-item\">\u003Cdiv class=\"check-icon\">✓\u003C/div>Benchmarking close rate against Stacy's 70%\u003C/div>\n      \u003Cdiv class=\"check-item\">\u003Cdiv class=\"check-icon\">✓\u003C/div>Identifying the phase where your cases are breaking\u003C/div>\n      \u003Cdiv class=\"check-item\">\u003Cdiv class=\"check-icon\">✓\u003C/div>Calculating your monthly and annual revenue gap\u003C/div>\n    \u003C/div>\n  \u003C/div>\n\u003C/div>\n\n\u003C!-- RESULTS -->\n\u003Cdiv id=\"resultsScreen\">\n  \u003Cnav class=\"res-nav\">\n    \u003Ca href=\"#\" class=\"res-brand\">\n      \u003Cdiv class=\"res-brand-mark\">FA\u003C/div>Full Arch Sales Experts\n    \u003C/a>\n  \u003C/nav>\n  \u003Cdiv class=\"results-body\" id=\"resultsBody\">\u003C/div>\n\u003C/div>\n\n\n\u003Cscript>\n/* ── CONFIG (fill in before going live) ── */\nconst N8N_WEBHOOK_URL = 'https://n8n.cvinson.cloud/webhook/60d73060-bc82-4484-a5cf-52b0400937c3';\nconst GHL_WEBHOOK_URL = 'YOUR_GHL_WEBHOOK_URL_HERE'; // ← GHL Settings > Integrations > Webhooks (optional fallback)\nconst REPORT_PAGE_URL = 'https://fullarchsalesexperts.com/result-page';\n\n/* ── QUESTIONS ── */\nconst QUESTIONS = [\n  {\n    type: 'slider',\n    text: \"How many full arch new patient consultations does your practice schedule each month?\",\n    ctx:  \"Count every consult where you present a full arch treatment plan — in-person or virtual.\",\n    sliderMin: 0, sliderMax: 50, sliderDefault: 10, sliderStep: 1,\n    sliderUnit: \"consultations / month\",\n    sliderBenchmark: \"Minimum for close rate training to move the needle: 8/month\",\n    sliderRailLeft: \"0\", sliderRailRight: \"50+\",\n    sliderBin: v => v \u003C= 14 ? '5-14' : v \u003C= 29 ? '15-29' : v \u003C= 49 ? '30-49' : '50plus'\n  },\n  {\n    type: 'slider',\n    text: \"What percentage of those consultations show up to the consultation?\",\n    ctx:  \"Best estimate is fine — think about your last 30 days. How many booked vs. how many actually sat down?\",\n    sliderMin: 0, sliderMax: 100, sliderDefault: 80, sliderStep: 1,\n    sliderUnit: \"% show-up rate\",\n    sliderBenchmark: \"\",\n    sliderRailLeft: \"0%\", sliderRailRight: \"100%\",\n    sliderBin: v => v \u003C 60 ? 'u60' : v \u003C= 79 ? '61-79' : '80plus'\n  },\n  {\n    type: 'slider',\n    text: \"What percentage of those consultations start treatment?\",\n    ctx:  \"Best estimate is fine — think about your last 30 days. How many sat down vs. how many signed?\",\n    sliderMin: 0, sliderMax: 100, sliderDefault: 30, sliderStep: 1,\n    sliderUnit: \"% close rate\",\n    sliderBenchmark: \"Stacy's proven benchmark: 70%\",\n    sliderRailLeft: \"0%\", sliderRailRight: \"100%\",\n    sliderBin: v => v \u003C 20 ? 'u20' : v \u003C= 40 ? '20-40' : v \u003C= 60 ? '41-60' : '61plus'\n  },\n  {\n    type: 'choices',\n    text: \"How does the money conversation typically happen in your consultation process?\",\n    ctx:  \"Think about your last 10 full arch consultations — who drove the financial piece and how was it structured?\",\n    choices: [\n      { label: \"The doctor covers treatment options and pricing in the same conversation\",        val: \"doctor-full\" },\n      { label: \"The doctor presents treatment, then introduces cost before handing off to staff\", val: \"doctor-led-fin\" },\n      { label: \"A team member handles the financial conversation — no set script or process\",     val: \"tc-no-script\" },\n      { label: \"We have a structured financial presentation our team follows consistently\",       val: \"tc-scripted\" }\n    ]\n  },\n  {\n    type: 'slider',\n    text: \"What does your practice spend on marketing as a percentage of monthly revenue?\",\n    ctx:  \"Include paid ads, SEO, agency fees, events, and referral programs. Use 0 if you don't currently track this.\",\n    sliderMin: 0, sliderMax: 30, sliderDefault: 8, sliderStep: 1,\n    sliderUnit: \"% of monthly revenue\",\n    sliderBenchmark: \"Stacy's model: 5% marketing spend, 70% close rate\",\n    sliderRailLeft: \"0%\", sliderRailRight: \"30%+\",\n    sliderBin: v => v \u003C 5 ? 'u5' : v \u003C= 15 ? '5-15' : 'o15'\n  }\n];\n\n/* ── STATE ── */\nconst state = { step: 0, answers: {}, lead: null };\n\n/* ── SCREENS ── */\nfunction _hideAll() {\n  document.getElementById('splashScreen').style.display = 'none';\n  document.getElementById('questionFlow').classList.remove('active');\n  document.getElementById('optInScreen').classList.remove('active');\n  document.getElementById('analyzingScreen').classList.remove('active');\n  document.getElementById('resultsScreen').classList.remove('active');\n}\nconst PRICING_URL = 'https://fullarchsalesexperts.com/nextlevel-124405'; // ← update if needed\nfunction goToPricing() { window.open(PRICING_URL, '_blank'); }\n\nfunction showSplash() {\n  _hideAll();\n  document.body.classList.remove('results-active');\n  document.body.classList.remove('quiz-active');\n  document.body.classList.remove('questions-active');\n  _resetHtmlBg();\n  document.getElementById('splashScreen').style.display = '';\n  document.getElementById('progressOuter').classList.add('hidden');\n}\nfunction showQuestions() {\n  _hideAll();\n  document.body.classList.remove('results-active');\n  document.body.classList.add('quiz-active');\n  document.body.classList.add('questions-active');\n  document.documentElement.style.background = '#F4F5FF';\n  document.getElementById('questionFlow').classList.add('active');\n  document.getElementById('progressOuter').classList.remove('hidden');\n}\nfunction showOptIn() {\n  _hideAll();\n  document.body.classList.remove('results-active');\n  document.body.classList.remove('questions-active');\n  document.body.classList.add('quiz-active');\n  _resetHtmlBg();\n  document.getElementById('optInScreen').classList.add('active');\n  document.getElementById('progressFill').style.width = '100%';\n  document.getElementById('progressOuter').classList.remove('hidden');\n  window.scrollTo({ top: 0, behavior: 'instant' });\n  setTimeout(() => document.getElementById('rgName').focus(), 200);\n}\nfunction showAnalyzing() {\n  _hideAll();\n  document.body.classList.remove('results-active');\n  document.body.classList.remove('questions-active');\n  document.body.classList.add('quiz-active');\n  _resetHtmlBg();\n  document.getElementById('analyzingScreen').classList.add('active');\n  document.getElementById('progressFill').style.width = '100%';\n}\nfunction showResults() {\n  _hideAll();\n  document.body.classList.add('results-active');\n  document.body.classList.remove('quiz-active');\n  document.documentElement.style.background = '#F4F5FF';\n  document.getElementById('resultsScreen').classList.add('active');\n  document.getElementById('progressOuter').classList.add('hidden');\n  window.scrollTo({ top: 0, behavior: 'instant' });\n}\nfunction _resetHtmlBg() { document.documentElement.style.background = ''; }\n\nfunction startAssessment() {\n  /* Clear any stale localStorage so a fresh attempt doesn't see old answers */\n  try {\n    localStorage.removeItem('nlca_report');\n    if (window.top && window.top !== window) {\n      try { window.top.localStorage.removeItem('nlca_report'); } catch(_) {}\n    }\n  } catch(e) {}\n  state.answers = {};\n  /* Re-initialize slider defaults so user can click Next without touching the slider */\n  QUESTIONS.forEach(function(q, idx) {\n    if (q.type === 'slider') {\n      state.answers['q' + (idx + 1)] = q.sliderBin(q.sliderDefault);\n    }\n  });\n  showQuestions();\n  show(1);\n}\n\n/* ── QUESTION ENGINE ── */\nfunction buildQuestions() {\n  const flow = document.getElementById('questionFlow');\n  QUESTIONS.forEach((q, i) => {\n    const n = i + 1;\n    const isLast = n === QUESTIONS.length;\n    const panel = document.createElement('div');\n    panel.className = 'step-panel'; panel.id = 'step-' + n;\n    let inputHtml;\n    if (q.type === 'slider') {\n      state.answers['q' + n] = q.sliderBin(q.sliderDefault);\n      inputHtml = `\u003Cdiv class=\"slider-wrap\">\n        \u003Cdiv class=\"slider-value-row\">\n          \u003Cdiv class=\"slider-big-val\" id=\"slval-${n}\">${q.sliderDefault}\u003C/div>\n          \u003Cdiv class=\"slider-unit\">${q.sliderUnit}\u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"slider-track-wrap\">\n          \u003Cinput type=\"range\" class=\"q-slider\" id=\"sl-${n}\" min=\"${q.sliderMin}\" max=\"${q.sliderMax}\" value=\"${q.sliderDefault}\" step=\"${q.sliderStep}\">\n        \u003C/div>\n        \u003Cdiv class=\"slider-rail-labels\">\u003Cspan>${q.sliderRailLeft}\u003C/span>\u003Cspan>${q.sliderRailRight}\u003C/span>\u003C/div>\n        \u003Cdiv class=\"slider-benchmark\">\u003Cspan class=\"slider-benchmark-dot\">\u003C/span>${q.sliderBenchmark}\u003C/div>\n      \u003C/div>`;\n    } else {\n      inputHtml = `\u003Cdiv class=\"choices\" id=\"choices-${n}\">\n        ${q.choices.map(c => `\u003Cbutton type=\"button\" class=\"choice-btn\" data-val=\"${c.val}\">\u003Cdiv class=\"choice-indicator\">\u003C/div>${c.label}\u003C/button>`).join('')}\n      \u003C/div>`;\n    }\n    panel.innerHTML = `\n      \u003Cdiv class=\"q-meta\">\u003Cspan class=\"q-num-pill\">Question ${n}\u003C/span>\u003Cspan class=\"q-progress-text\">${n} of ${QUESTIONS.length}\u003C/span>\u003C/div>\n      \u003Cdiv class=\"q-text\">${q.text}\u003C/div>\n      \u003Cp class=\"q-context\">${q.ctx}\u003C/p>\n      ${inputHtml}\n      \u003Cbutton type=\"button\" class=\"btn-next\" id=\"nxt-${n}\" ${q.type === 'slider' ? '' : 'disabled'}>\n        ${isLast ? 'See My Results' : 'Next Question'}\n        \u003Csvg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\u003Cpath d=\"M3 8h10M9 4l4 4-4 4\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\u003C/svg>\n      \u003C/button>\n      ${n > 1 ? `\u003Cbutton type=\"button\" class=\"btn-back\">← Back\u003C/button>` : ''}`;\n    flow.appendChild(panel);\n    if (q.type === 'slider') requestAnimationFrame(() => paintSlider(n, q.sliderDefault, q.sliderMin, q.sliderMax));\n  });\n}\n\nfunction paintSlider(n, val, min, max) {\n  const el = document.getElementById('sl-' + n); if (!el) return;\n  const pct = ((val - min) / (max - min)) * 100;\n  el.style.background = `linear-gradient(to right, var(--blue) 0%, var(--blue) ${pct}%, var(--lborder) ${pct}%)`;\n}\nfunction sliderMove(n, el) {\n  const q = QUESTIONS[n - 1]; const val = parseInt(el.value, 10);\n  document.getElementById('slval-' + n).textContent = val;\n  paintSlider(n, val, q.sliderMin, q.sliderMax);\n  state.answers['q' + n] = q.sliderBin(val);\n}\nfunction show(n) {\n  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));\n  const t = document.getElementById('step-' + n);\n  if (t) { t.classList.add('active'); window.scrollTo({ top: 0, behavior: 'smooth' }); }\n  state.step = n;\n  const pct = (n / QUESTIONS.length) * 90;\n  document.getElementById('progressFill').style.width = pct + '%';\n  const q = QUESTIONS[n - 1];\n  if (q.type === 'slider') { const el = document.getElementById('sl-' + n); if (el) paintSlider(n, parseInt(el.value, 10), q.sliderMin, q.sliderMax); }\n}\nfunction pick(step, val, btn) {\n  state.answers['q' + step] = val;\n  document.querySelectorAll('#choices-' + step + ' .choice-btn').forEach(b => b.classList.toggle('selected', b === btn));\n  document.getElementById('nxt-' + step).disabled = false;\n}\nfunction advance(step) {\n  /* Safety net: ensure slider questions have an answer recorded.\n     If state.answers got cleared somehow, fall back to the slider's current value. */\n  if (!state.answers['q' + step]) {\n    var q = QUESTIONS[step - 1];\n    if (q && q.type === 'slider') {\n      var el = document.getElementById('sl-' + step);\n      var val = el ? parseInt(el.value, 10) : q.sliderDefault;\n      state.answers['q' + step] = q.sliderBin(val);\n    } else {\n      /* Choice question with no answer — button should still be disabled; bail safely */\n      return;\n    }\n  }\n  if (step \u003C QUESTIONS.length) show(step + 1); else showOptIn();\n}\nfunction back(step) { if (step \u003C= 1) showSplash(); else show(step - 1); }\nfunction runAnalysis() {\n  showAnalyzing();\n  const a = state.answers;\n  // Redirect with remapped keys so report pages receive consistent format\n  const remapped = { q1: a.q1, q2: a.q3, q3: a.q4, q4: 'close', q5: a.q5, q6: a.q2 };\n  const params = new URLSearchParams(remapped).toString();\n  /* Use BOTH ?query and #hash so GHL can't strip the data — hash is client-only */\n  const target = REPORT_PAGE_URL + '?' + params + '#' + params;\n  console.log('[NLCA] Will redirect to:', target);\n\n  /* Also write to top-window localStorage in case iframe origin differs */\n  try {\n    const payload = JSON.stringify(state.lead || { answers: remapped, savedAt: Date.now() });\n    localStorage.setItem('nlca_report', payload);\n    if (window.top && window.top !== window) {\n      try { window.top.localStorage.setItem('nlca_report', payload); } catch(_) {}\n    }\n  } catch(e) { console.warn('[NLCA] localStorage write failed:', e); }\n\n  setTimeout(() => {\n    console.log('[NLCA] Redirecting now...');\n    try {\n      /* Try top-level navigation first (escapes iframe if GHL preview/embed) */\n      if (window.top && window.top !== window) {\n        window.top.location.href = target;\n      } else {\n        window.location.href = target;\n      }\n    } catch(e) {\n      console.warn('[NLCA] Top-level redirect blocked, falling back to window.location:', e);\n      window.location.href = target;\n    }\n  }, 2800);\n}\n\n/* ── RESULT BUILD ── */\nfunction buildResults() {\n  const a = state.answers;\n  const volMap  = { '5-14': 10, '15-29': 22, '30-49': 40, '50plus': 60 };\n  const rateMap = { 'u20': 0.15, '20-40': 0.30, '41-60': 0.50, '61plus': 0.65 };\n  const vol     = volMap[a.q1]  || 10;\n  const rate    = rateMap[a.q3] || 0.30;  // q3 = close rate in raw quiz state\n  const caseVal = 25000;\n  const isLowVol        = a.q1 === '5-14';\n  const isHighPerformer = rate >= 0.65;\n  const monthlyGap      = Math.round(Math.max(0, 0.70 - rate) * vol * caseVal);\n  const annualGap       = monthlyGap * 12;\n\n  const SEV = {\n    vol:   a.q1 === '5-14' ? 'warning' : 'ok',\n    rate:  (a.q3 === 'u20' || a.q3 === '20-40') ? 'critical' : a.q3 === '41-60' ? 'warning' : 'ok',\n    pres:  (a.q4 === 'doctor-full' || a.q4 === 'doctor-led-fin') ? 'critical' : a.q4 === 'tc-no-script' ? 'warning' : 'ok',\n    block: 'ok',  // case loss question removed from new quiz — no data to score\n    mkt:   a.q5 === 'o15' ? 'warning' : 'ok'\n  };\n  const SEV_LABEL = { critical: 'Critical', warning: 'Needs Work', ok: 'Strong' };\n  const ARROW = `\u003Csvg width=\"13\" height=\"13\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\"/>\u003C/svg>`;\n\n  /* Trait bars — 16personalities horizontal bar style */\n  const TRAIT_META = [\n    { key: 'rate',  label: 'Close Rate' },\n    { key: 'pres',  label: 'Presentation Quality' },\n    { key: 'block', label: 'Financial Handoff' },\n    { key: 'vol',   label: 'Case Loss Pattern' },\n    { key: 'mkt',   label: 'Ad Spend Ratio' }\n  ];\n  function buildTraitBars() {\n    return `\u003Cdiv class=\"trait-bars\">` +\n      TRAIT_META.map(m => {\n        const sev = SEV[m.key];\n        return `\u003Cdiv class=\"trait-row\">\n          \u003Cdiv class=\"trait-label\">${m.label}\u003C/div>\n          \u003Cdiv class=\"trait-track\">\u003Cdiv class=\"trait-fill sev-${sev}\">\u003C/div>\u003C/div>\n          \u003Cdiv class=\"trait-badge sev-${sev}\">${SEV_LABEL[sev]}\u003C/div>\n        \u003C/div>`;\n      }).join('') +\n    `\u003C/div>`;\n  }\n\n  /* Track modules for consolidated learning path */\n  const moduleMap = new Map();\n  const MODULE_SHORT = {\n    'Module 1: Foundations & Psychology': 'Builds the psychology, lead-qualification filter, and the exact handoff structure that separates clinical from financial presentations — so your TC enters the room with authority.',\n    'Module 2: 8-Step Consult Flow': 'All eight steps of the financial consultation scripted from open to signed plan. Value anchoring, investment presentation, financing pivot, and the same-day close — drilled live every session.',\n    'Module 3: Objection Mastery': 'Word-for-word responses to every hesitation that ends a case: the financing objection, the spouse conversation, \"let me think about it,\" and the patient who leaves without a clear reason.'\n  };\n\n  function card(sev, area, problem, impact, fixSteps, moduleName, nlcaDesc) {\n    /* Register this finding under its module */\n    if (!moduleMap.has(moduleName)) moduleMap.set(moduleName, []);\n    moduleMap.get(moduleName).push({ sev, area });\n\n    const li = fixSteps.map(s => `\u003Cli>${s}\u003C/li>`).join('');\n    const nlcaBlock = nlcaDesc ? `\n        \u003Cdetails class=\"manual-toggle nlca-toggle\" open>\n          \u003Csummary>What you get with NLCA\u003C/summary>\n          \u003Cdiv class=\"nlca-detail\">${nlcaDesc}\u003C/div>\n        \u003C/details>` : '';\n    return `\u003Cdiv class=\"section-card\" data-sev=\"${sev}\">\n      \u003Cdiv class=\"card-inner\">\n        \u003Cdiv class=\"section-badge-row\">\n          \u003Cspan class=\"sev-chip sev-${sev}\">${SEV_LABEL[sev]}\u003C/span>\n          \u003Cspan class=\"section-area\">${area}\u003C/span>\n        \u003C/div>\n        \u003Cdiv class=\"section-problem\">${problem}\u003C/div>\n        \u003Cdiv class=\"section-impact\">${impact}\u003C/div>\n        \u003Cdiv class=\"card-toggles\">\n          \u003Cdetails class=\"manual-toggle\">\n            \u003Csummary>What you can fix yourself\u003C/summary>\n            \u003Cul class=\"fix-steps\">${li}\u003C/ul>\n          \u003C/details>${nlcaBlock}\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>`;\n  }\n\n  function buildLearningPath() {\n    if (moduleMap.size === 0) return '';\n    const ORDER = ['Module 1: Foundations & Psychology', 'Module 2: 8-Step Consult Flow', 'Module 3: Objection Mastery'];\n    const sorted = ORDER.filter(m => moduleMap.has(m));\n    const steps = sorted.map((name, i) => {\n      const findings = moduleMap.get(name);\n      const tags = findings.map(f =>\n        `\u003Cspan class=\"lp-tag lp-${f.sev}\">${f.area}\u003C/span>`\n      ).join('');\n      return `\u003Cdiv class=\"lp-step\">\n        \u003Cdiv class=\"lp-step-num\">${String(i + 1).padStart(2, '0')}\u003C/div>\n        \u003Cdiv class=\"lp-step-body\">\n          \u003Cdiv class=\"lp-step-name\">${name}\u003C/div>\n          \u003Cp class=\"lp-step-desc\">${MODULE_SHORT[name]}\u003C/p>\n          \u003Cdiv class=\"lp-step-tags\">${tags}\u003C/div>\n        \u003C/div>\n      \u003C/div>`;\n    }).join('');\n    return `\u003Cdiv class=\"learning-path\">\n      \u003Cdiv class=\"lp-inner\">\n        \u003Cdiv class=\"section-num-row\">\n          \u003Cdiv class=\"section-num\">4\u003C/div>\n          \u003Cdiv class=\"section-label-tag\">Your Growth Path\u003C/div>\n        \u003C/div>\n        \u003Ch2 class=\"section-heading\">Your Recommended Learning Path\u003C/h2>\n        \u003Cp class=\"section-intro\">These modules, in this order, close the specific gaps in your consult process. Each builds on the last.\u003C/p>\n        \u003Cdiv class=\"lp-steps\">${steps}\u003C/div>\n        \u003Cdiv class=\"lp-cta-wrap\">\n          \u003Ca href=\"https://fullarchsalesexperts.com/nextlevel-124405\" target=\"_blank\" class=\"lp-cta-btn\">\n            Join NLCA — $295/Month ${ARROW}\n          \u003C/a>\n          \u003Cp class=\"lp-fine\">$295/month · Live with Stacy twice a month · No long-term contract\u003C/p>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>`;\n  }\n\n  function stacyPull(quote, attr) {\n    return `\u003Cdiv class=\"stacy-pull\">\n      \u003Cspan class=\"stacy-pull-mark\">\"\u003C/span>\n      \u003Cp class=\"stacy-pull-text\">${quote}\u003C/p>\n      \u003Cdiv class=\"stacy-pull-attr\">\u003Cstrong>${attr}\u003C/strong> — Full Arch Sales Experts\u003C/div>\n    \u003C/div>`;\n  }\n\n  /* ── Cards ── */\n  const cards = [];\n\n  /* Volume */\n  if (SEV.vol === 'warning') {\n    cards.push(card('warning', 'Full Arch Volume',\n      'You have consultations coming in — but not enough runway to absorb a leaky close rate.',\n      `At 10 consultations/month, the difference between your current close rate and Stacy's 70% benchmark is \u003Cstrong>$${Math.round((0.70 - rate) * 10 * caseVal).toLocaleString()}/month\u003C/strong>. Fixing conversion now means every new consultation you add compounds at 70% instead of your current rate.`,\n      [\n        'Activate referral partnerships with local implant reps and oral surgeons — they see viable full arch candidates daily',\n        'Run a reactivation campaign to your existing patient base: offer a no-cost full arch evaluation for 30 days',\n        'Tighten your lead call to screen for the Three Cs — Cash, Credit, or Co-signer — before booking a consultation slot'\n      ],\n      'Module 1: Foundations & Psychology',\n      'In NLCA, we start where most practices never look — the belief system driving decisions before anyone sits down. Stacy works with your team on the qualification framework that makes every additional consultation worth having. When you fix this layer first, volume stops being the bottleneck.'\n    ));\n  }\n\n  /* Close Rate */\n  if (SEV.rate === 'critical') {\n    const pct = Math.round(rate * 100);\n    cards.push(card('critical', 'Plan Close Rate',\n      `${pct}% close rate means ${100 - pct}% of qualified patients are leaving without a signed plan.`,\n      `This is almost never a marketing problem. At ${vol} consultations/month, every point you gain toward 70% is worth \u003Cstrong>$${(vol * 0.01 * caseVal).toLocaleString()}/month\u003C/strong>. The full gap is \u003Cstrong>$${monthlyGap.toLocaleString()}/month\u003C/strong> — none of which requires a single additional lead to capture.`,\n      [\n        'Listen to three recent consults and identify where the conversation loses energy — handoff, presentation, or objection stage',\n        'Write one scripted response to your most common objection and run it with your TC before next week\\'s consults',\n        'Install a same-day decision protocol: give patients a concrete next step, not an open-ended \"let us know\"'\n      ],\n      'Module 2: 8-Step Consult Flow',\n      'In NLCA, Stacy works through the full consultation with your TC — live, every session. Not a training video. Not a workbook. A coached rehearsal of the real conversation, drilled until it becomes automatic. This is how a practice closes 30% one month and 70% six months later.'\n    ));\n  } else if (SEV.rate === 'warning') {\n    cards.push(card('warning', 'Plan Close Rate',\n      'You\\'re above average — but still leaving significant revenue on the table against the 70% benchmark.',\n      `The jump from 50% to 70% at your volume is worth \u003Cstrong>$${(vol * 0.20 * caseVal).toLocaleString()}/month\u003C/strong>. At this stage the gap is almost always in objection handling and the financing sequence — not the presentation itself.`,\n      [\n        'Map your objection frequency: which hesitations come up most, and do you have a word-for-word response for each?',\n        'Review your financing sequence — are you anchoring the monthly payment before the total case investment, or after?',\n        'Add a structured follow-up protocol for every patient who leaves without a decision'\n      ],\n      'Module 3: Objection Mastery',\n      'At 50%, the gap is almost never the presentation — it\\'s the 10 seconds after the patient hesitates. In NLCA, Stacy works with your TC on exactly those moments. The specific hesitations costing you cases right now, with real responses, drilled live every session until they\\'re second nature.'\n    ));\n  }\n\n  /* Financial Handoff */\n  if (SEV.pres === 'critical') {\n    const docFull = a.q3 === 'doctor-full';\n    cards.push(card('critical', 'Financial Handoff',\n      docFull\n        ? 'When the doctor runs both clinical and financial conversations, patients defer — even when they want to say yes.'\n        : 'Having a TC in the room while the doctor leads the financial talk creates confusion about who to respond to — and leaves the TC unable to step in.',\n      docFull\n        ? `Research proves that people are less likely to trust advice when the advisor stands to gain financially. Stacy's dad converted at 30%. She converted at 70%. Same patients. Same practice. Same leads. Different person in the room for the financial conversation.`\n        : `When the doctor leads and the TC is present, the patient directs all responses to the doctor. The TC can't close what the doctor is opening. The handoff isn't a detail — it's the mechanism that changes the math.`,\n      docFull\n        ? [\n            'Separate the clinical assessment (doctor presents diagnosis and two treatment options) from the financial presentation (TC handles investment, financing, and the close) — in two rooms',\n            'Brief your TC on the treatment plan before the financial conversation so they can anchor value accurately in patient language',\n            'Track close rate separately for doctor-only vs. TC-led financial presentations to see the gap in real time'\n          ]\n        : [\n            'Give the TC a clean handoff: doctor presents clinical findings and exits — TC enters and owns the financial conversation',\n            'Script the handoff line for the doctor: \"My team coordinator is going to walk you through your options and what this looks like financially — she\\'ll take great care of you.\"',\n            'Measure close rate per presentation type this month to isolate the gap'\n          ],\n      'Module 1: Foundations & Psychology',\n      docFull\n        ? 'In NLCA, we work through why the room dynamic changes everything — and how to restructure it so your TC steps in with full authority. Stacy has done this inside dental practices for over 20 years. The shift is faster than most practices expect once the structure is right.'\n        : 'In NLCA, we address the handoff directly — the exact language your doctor uses to hand off, the setup that puts your TC in control, and the patient dynamic that follows. It\\'s a structural fix. Once it\\'s in place, the close rate reflects it immediately.'\n    ));\n  } else if (SEV.pres === 'warning') {\n    cards.push(card('warning', 'Financial Handoff',\n      'Your TC handles the financial conversation — but without a defined framework, results depend on how confident they feel that day.',\n      `A strong day produces 3 closes. A rough day produces 1. The difference isn't the patient — it's the system. Scripts don't remove personality; they give the TC a floor to operate from so results stay consistent regardless of how the day is going.`,\n      [\n        'Add word-for-word scripts for your two most common objections — the ones that come up in almost every consult',\n        'Record one successful close and one that didn\\'t close. Map the difference in the conversation — that gap is what to script next',\n        'Drill the financial presentation out loud with your TC once a week outside of live consults'\n      ],\n      'Module 2: 8-Step Consult Flow',\n      'In NLCA, Stacy works with your TC to replace the improvisation with a system — same personality, real floor underneath it. A rough week stops costing you four cases. Live drilling every session, with real objections, until consistent becomes the new baseline.'\n    ));\n  }\n\n  /* Case Loss Pattern */\n  if (SEV.block === 'critical') {\n    let prob, impact, fix, nlcaMod, nlcaDesc;\n    if (a.q4 === 'financing') {\n      prob     = 'The financing objection is almost never about money — it\\'s a value conversation that didn\\'t finish.';\n      impact   = `Stacy's rule: \u003Cem>\"If they want to do this bad enough, they will find a way to get the money.\"\u003C/em> The patient who stopped after one financing decline wasn't lost to credit. They were lost to uncertainty about whether the outcome was worth it. Nine out of ten times, the approval process made the decision they weren't ready to make themselves.`;\n      fix      = [\n        'Offer at least four financing options with different term lengths — patients need options, not a single declined application',\n        'Present the monthly payment first, not the total case investment — anchor on \"this is what it costs per day to have a functioning mouth for the rest of your life\"',\n        'When financing is declined, pause the close and return to value: \"Let\\'s make sure you have everything you need to find a path forward\" before offering alternatives'\n      ];\n      nlcaMod  = 'Module 3: Objection Mastery';\n      nlcaDesc = 'In NLCA, Stacy works through the financing conversation live — the sequencing, the language, how to respond when an application is declined, how to use alternatives as a path forward rather than a fallback. This is one of the highest-impact sessions in the program. Your TC will never handle it the same way again.';\n    } else if (a.q4 === 'spouse') {\n      prob     = 'A patient who needs to \"talk to their spouse\" almost never comes back with a yes.';\n      impact   = `The spouse got a 5-minute summary of a 60-minute conversation. They weren't in the room when the value was built. Every follow-up call after this moment is trying to close a case that was already lost at the appointment. The fix isn't a better callback — it's preventing the unchaperoned exit.`;\n      fix      = [\n        'On the lead call, ask: \"Is there anyone whose input you\\'d want before making a decision about this? If so, let\\'s make sure they\\'re at the consult.\" Book them together.',\n        'During the financial conversation: \"Before I walk you through the investment, is your partner someone you typically make decisions like this with together? Let\\'s get them on a quick call right now — I want them to hear this directly.\"',\n        'If they\\'re alone and want to include a spouse: do a live 10-minute call in the consult room before they leave, not a follow-up call after'\n      ];\n      nlcaMod  = 'Module 3: Objection Mastery';\n      nlcaDesc = 'In NLCA, Stacy works through the spouse conversation as something you see coming — and address before it becomes an exit. Your TC leaves with a clear approach from the lead call forward. The goal is to never be caught off guard by this objection again.';\n    } else if (a.q4 === 'sameday') {\n      prob     = '\"Let me think about it\" is the most expensive phrase in full arch sales.';\n      impact   = `Patients who leave without deciding close at under 5% — regardless of how warm the conversation felt. \"Let me think about it\" is rarely about time. Stacy's rule: \u003Cem>cost is only an issue in the absence of value.\u003C/em> When a patient defers, the value conversation wasn't complete — or there's an unspoken concern that wasn't surfaced before they walked out.`;\n      fix      = [\n        'When a patient says \"let me think about it,\" respond: \"Of course — what\\'s the main thing you\\'d want to think through?\" This surfaces the real objection while they\\'re still in front of you',\n        'Add urgency anchors at the right moment: treatment timelines, bone deterioration windows, or financing terms with an expiration date',\n        'Create a 48-hour follow-up protocol: same-day text, next-morning call, day-three email — each personalized to the specific conversation, not a generic check-in'\n      ];\n      nlcaMod  = 'Module 3: Objection Mastery';\n      nlcaDesc = 'In NLCA, Stacy works through what\\'s actually happening when a patient defers — and what to say in that moment to open the real conversation instead of accepting the exit. Your TC will have a clear response, practiced until it\\'s instinct. And a follow-up protocol for the ones who do walk out.';\n    } else {\n      prob     = 'Patient sat through the whole consult but left without a clear reason — which means the value conversation didn\\'t land.';\n      impact   = `Stacy's principle: \u003Cem>patients don't say no to implants — they say no to uncertainty.\u003C/em> When a patient exits without a specific objection, they didn't feel certain enough to commit. The fix is almost always in the sequencing — value has to be complete before price is introduced, or the price is the last thing they remember walking out.`;\n      fix      = [\n        'Identify whether the breakdown is in the value sequence (patient doesn\\'t see the outcome clearly enough) or after price is stated (patient shuts down when the number lands)',\n        'Add one scripted \"value anchor\" before stating the investment: walk the patient through comfort, function, health, and confidence — every second of every day, for the rest of their life — before the number is said',\n        'Ask at the end of the value build, before stating price: \"On a scale of 1 to 10, how ready do you feel to move forward?\" Anything under 8 means the value conversation isn\\'t done'\n      ];\n      nlcaMod  = 'Module 2: 8-Step Consult Flow';\n      nlcaDesc = 'In NLCA, Stacy works through the sequencing with your TC until value lands before price — every time. The patient who hears the number and shuts down is almost always a sequencing problem. We work on it live until the conversation flows the way it should, and the number never catches anyone off guard.';\n    }\n    cards.push(card('critical', 'Case Loss Pattern', prob, impact, fix, nlcaMod, nlcaDesc));\n  } else if (SEV.block === 'warning') {\n    cards.push(card('warning', 'Case Loss Pattern',\n      'Cases that book but don\\'t show — or show without the financial readiness to decide — are a qualification problem, not a volume problem.',\n      `Every unqualified consultation that sits in your chair is a slot that could have gone to a viable case. The Three Cs — Cash, Credit, or Co-signer — are a filter, not a gatekeeping mechanism. Applying them at the lead call changes who shows up.`,\n      [\n        'Give the lead call a single goal: confirm the Three Cs and book the appointment — stop trying to educate or close on the call',\n        'Screen directly: \"To make sure we\\'re making the best use of your time at the consult, can I ask — are you in a position to move forward if this is a good fit today, or would there be a step before that?\"',\n        'Create appointment urgency with two specific slots: \"We have Tuesday at 2pm or Thursday at 4pm — which works better for you?\"'\n      ],\n      'Module 1: Foundations & Psychology',\n      'In NLCA, Stacy works with your team on the qualification layer — who should be in the chair, and how to make sure they show up ready to decide. Most practices find this changes the entire feel of their consultations before anything else in the process changes.'\n    ));\n  }\n\n  /* Marketing Spend */\n  if (SEV.mkt === 'warning') {\n    let prob, impact, fix, nlcaMod, nlcaDesc;\n    if (a.q5 === 'o15') {\n      prob     = 'You\\'re spending heavily on leads going into a process that can\\'t convert them at benchmark.';\n      impact   = `Stacy built $8.5M in annual revenue on a 5% marketing spend. The average full arch practice now spends 20%. The math: more leads into a leaky conversion process generates more lost opportunities — not more revenue. Every additional lead at your current close rate costs more than the last one.`;\n      fix      = [\n        'Hold ad spend for 60 days while the close rate is addressed — the revenue recovered from existing consultations will exceed what additional leads would generate at current conversion',\n        'Calculate cost per closed case: if it\\'s over $5,000, the problem is conversion, not lead volume',\n        'Set a marketing spend ceiling at 10% of gross collections and hold it there until close rate reaches 50%+'\n      ];\n      nlcaMod  = 'Module 1: Foundations & Psychology';\n      nlcaDesc = 'In NLCA, Stacy works through this math with your team directly. Most practices at this level find their current budget is already enough — what needs to change is what happens after the patient sits down. We work on the conversion side together until the spend you already have starts producing what it should.';\n    } else {\n      prob     = 'Without tracking marketing spend as a percentage of revenue, you can\\'t tell if the problem is leads or conversion.';\n      impact   = `This is the most common source of wrong-diagnosis in full arch practices. Practices assume they need more leads when the close rate is broken. Practices assume conversion needs work when they actually need volume. One number clarifies which lever to pull.`;\n      fix      = [\n        'Pull last 3 months of ad spend and agency fees, divide by revenue — that\\'s your marketing percentage. Under 5%: likely need volume. 5–15%: healthy. Over 15%: fix close rate first.',\n        'Track monthly and set a ceiling — most profitable full arch practices stay under 10%',\n        'Once you have the number, you can tell exactly which problem you have'\n      ];\n      nlcaMod  = 'Module 1: Foundations & Psychology';\n      nlcaDesc = 'In NLCA, Stacy helps you read the right diagnostic first — so you\\'re pulling the right lever. Most practices find the answer changes how they think about the whole business. We work through it together and build a clear picture of where the real opportunity is.';\n    }\n    cards.push(card('warning', 'Ad Spend Ratio', prob, impact, fix, nlcaMod, nlcaDesc));\n  }\n\n  /* ── Stacy's Take ── */\n  function buildStacyTake() {\n    let headline, body;\n    if (a.q3 === 'doctor-full') {\n      headline = 'The structural fix is the fastest fix.';\n      body = '\"My dad converted at 30%. I converted at 70%. Same patients. Same practice. Same leads. Different person in the room for the financial conversation.\" What your practice has right now isn\\'t a training problem — it\\'s a structure problem. Once you separate clinical and financial presentations, everything downstream gets easier because the dynamic in the room changes completely.';\n    } else if (SEV.rate === 'critical') {\n      headline = 'This is a sales process problem — not a lead problem.';\n      body = '\"Every single doc I talk to says the same thing: we just have the wrong leads. Then I get on their systems and listen to their consults and I say — doc, no. You don\\'t have the wrong leads. You don\\'t know how to handle them.\" At ' + Math.round(rate*100) + '% close rate, the gap isn\\'t outside the practice. It\\'s inside the consult room.';\n    } else if (a.q4 === 'financing') {\n      headline = 'Financing is almost never the real objection.';\n      body = '\"Nine out of ten times when they don\\'t get qualified or don\\'t try to find another way — it\\'s because they don\\'t see the value. If they want to do this bad enough, they will find a way to get the money.\" The patient who stopped after one decline wasn\\'t lost to financing. They were lost to uncertainty about the value.';\n    } else if (a.q4 === 'sameday') {\n      headline = 'Cost is only an issue in the absence of value.';\n      body = '\"Nine out of ten times, \\'I can\\'t afford it\\' means \\'I just don\\'t know if I want to afford it with you.\\' Patients don\\'t say no to implants. They say no to uncertainty — and uncertainty is eliminated by a really good conversation, not a lower price.\"';\n    } else if (a.q3 === 'doctor-led-fin') {\n      headline = 'The handoff is where the close lives or dies.';\n      body = '\"The doctor plays a very important part in the clinical presentation — which in my framework is totally separate from the sales presentation. It\\'s in a different room. When everyone\\'s doing these same-room frameworks, the TC never gets a clean moment to own the conversation. The handoff isn\\'t optional — it\\'s the mechanism.\"';\n    } else {\n      headline = 'The conversion is inside your practice — not in your ad budget.';\n      body = '\"The average full arch practice now spends 20% of gross collections on marketing. We built $8.5M on a 5% spend. The difference isn\\'t marketing — it\\'s what happens once the patient sits down.\" Your gap is recoverable with the consultations you\\'re already running.';\n    }\n    return `\u003Cdiv class=\"stacy-take\">\n      \u003Cdiv class=\"st-inner\">\n        \u003Cdiv class=\"st-header\">\n          \u003Cdiv class=\"st-avatar\">SF\u003C/div>\n          \u003Cdiv class=\"st-meta\">\n            \u003Cdiv class=\"st-name\">Stacy Farley\u003C/div>\n            \u003Cdiv class=\"st-role\">Founder, Full Arch Sales Experts · 70% close rate · 40–50 arches/month for 8 years\u003C/div>\n          \u003C/div>\n        \u003C/div>\n        \u003Cspan class=\"st-eyebrow\">Stacy's Take — Based on Your Results\u003C/span>\n        \u003Cdiv class=\"st-headline\">${headline}\u003C/div>\n        \u003Cdiv class=\"st-body\">\"${body}\"\u003C/div>\n      \u003C/div>\n    \u003C/div>`;\n  }\n\n  /* ── Testimonials (persona-matched) ── */\n  function buildTestimonials() {\n    const tJessica = `\u003Cdiv class=\"testimonial-card\">\n      \u003Cdiv class=\"t-header\">\u003Cdiv class=\"t-avatar\">JR\u003C/div>\u003Cdiv class=\"t-stars\">★★★★★\u003C/div>\u003C/div>\n      \u003Cp class=\"t-quote\">\"We went from closing about 30% of full arch consults to over 60% in 90 days. Stacy's system is the real deal — no fluff, just what works in the real world.\"\u003C/p>\n      \u003Cdiv class=\"t-footer\">\u003Cspan class=\"t-attr\">Jessica R. — Treatment Coordinator, Texas\u003C/span>\u003Cspan class=\"t-result\">↑ Doubled close rate in 90 days\u003C/span>\u003C/div>\n    \u003C/div>`;\n    const tMeng = `\u003Cdiv class=\"testimonial-card\">\n      \u003Cdiv class=\"t-header\">\u003Cdiv class=\"t-avatar\">DM\u003C/div>\u003Cdiv class=\"t-stars\">★★★★★\u003C/div>\u003C/div>\n      \u003Cp class=\"t-quote\">\"Within 6 months of working with Stacy, our implant center added nearly $1M in revenue. The consult process she teaches is unlike anything we had seen.\"\u003C/p>\n      \u003Cdiv class=\"t-footer\">\u003Cspan class=\"t-attr\">Dr. Meng — Practice Owner, Meng Dentistry\u003C/span>\u003Cspan class=\"t-result\">↑ $989K added in 6 months\u003C/span>\u003C/div>\n    \u003C/div>`;\n    const tMaria = `\u003Cdiv class=\"testimonial-card\">\n      \u003Cdiv class=\"t-header\">\u003Cdiv class=\"t-avatar\">ML\u003C/div>\u003Cdiv class=\"t-stars\">★★★★★\u003C/div>\u003C/div>\n      \u003Cp class=\"t-quote\">\"I finally stopped winging it. I went through Module 2 on a Tuesday and closed 3 full arches by Friday — cases I would have walked away from the week before.\"\u003C/p>\n      \u003Cdiv class=\"t-footer\">\u003Cspan class=\"t-attr\">Maria L. — Treatment Coordinator\u003C/span>\u003Cspan class=\"t-result\">↑ 3 full arches in first week\u003C/span>\u003C/div>\n    \u003C/div>`;\n    const order = (a.q3 === 'doctor-full' || a.q3 === 'doctor-led-fin')\n      ? [tMeng, tJessica, tMaria]\n      : [tJessica, tMeng, tMaria];\n    return `\u003Cdiv class=\"testimonials\">${order.join('')}\u003C/div>`;\n  }\n\n  function buildVideoTestimonials() {\n    const GCS = 'https://storage.googleapis.com/msgsndr/vdi6H8skwmbrWBAz1f6X/media/';\n    const videos = [\n      { id: '689ac6cf7b7578103e8e402c', name: 'Dr. Graham & Joe Ming', role: 'Surgical Prosthodontists · Missoula, MT', quote: '\"Helped us identify what we were doing right — and what we were doing wrong.\"' },\n      { id: '689ac6cf7b7578a4a68e4030', name: 'Dr. David', role: 'Full-Arch Dentist · San Diego, CA', quote: '\"It wasn\\'t uncommon for us to sell four to six arches in a day.\"' },\n      { id: '689ac6cf9a2be060e8d0f67d', name: 'Dr. Jim Keel', role: 'Owner · South Coast Dental', quote: '\"We\\'ve been able to close about four or five full-arch cases per week.\"' },\n      { id: '689ac6cf9a2be0d93fd0f67e', name: 'Amanda', role: 'Treatment Coordinator · Potomac Dental Center', quote: '\"Our sales have gone up, our show rate has gone up.\"' },\n      { id: '689ac6cfd757ed6545d608b1', name: 'Already', role: 'Founder · DDS Marketing', quote: '\"Closing 35–40 cases a month consistently, without heavy marketing spend.\"' },\n      { id: '689ac6cfd757ed9396d608b0', name: 'Emily Keel', role: 'Treatment Coordinator · South Coast Dental', quote: '\"In just a few short months we successfully closed several full-arch cases.\"' },\n      { id: '68b80b24f9afe98210f7adfc', name: 'Dr. Vera', role: 'Full-Arch Dentist · San Diego, CA', quote: '\"Stacy showed me the three core principles to a successful sale.\"' },\n      { id: '68e48b646a0a917293b9003e', name: 'Gary Bird', role: 'Owner · SMC National', quote: '\"She is the Michael Jordan of full-arch sales.\"' },\n    ];\n    const tiles = videos.map(v => `\n      \u003Cdiv class=\"vt-tile\">\n        \u003Cvideo class=\"vt-video\" src=\"${GCS}${v.id}.mp4\" poster=\"thumbs/${v.id}.jpg\" controls preload=\"none\" playsinline>\u003C/video>\n        \u003Cdiv class=\"vt-info\">\n          \u003Cp class=\"vt-quote\">${v.quote}\u003C/p>\n          \u003Cdiv class=\"vt-name\">${v.name}\u003C/div>\n          \u003Cdiv class=\"vt-role\">${v.role}\u003C/div>\n        \u003C/div>\n      \u003C/div>`).join('');\n    return `\n      \u003Cdiv class=\"video-testimonials\">\n        \u003Cdiv class=\"vt-header\">\n          \u003Cspan class=\"vt-eyebrow\">Video Testimonials\u003C/span>\n          \u003Cdiv class=\"vt-headline\">What Practitioners Are Saying\u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"vt-grid\">${tiles}\u003C/div>\n      \u003C/div>`;\n  }\n\n  /* ── Gap headline + CTA ── */\n  const gapDisplay  = isHighPerformer ? 'Already strong' : '$' + monthlyGap.toLocaleString();\n  const gapHeadline = isHighPerformer\n    ? `You're closing above average. Let's push you to \u003Cem>elite.\u003C/em>`\n    : `Your practice is leaving \u003Cem>$${monthlyGap.toLocaleString()}/mo\u003C/em> on the table.`;\n  const gapSub = isHighPerformer\n    ? `At ${Math.round(rate*100)}% you're ahead of the national 25% average — but Stacy's benchmark is 70%. The jump from where you are to 70% on ${vol} consultations is worth $${Math.round((0.70 - rate) * vol * caseVal).toLocaleString()}/month. That gap is all refinement: objection handling, value sequencing, and financing pivots.`\n    : `At your current ${Math.round(rate*100)}% close rate, every point you gain toward Stacy's 70% standard is worth $${(vol * 0.01 * caseVal).toLocaleString()}/month. That gap is almost never a marketing problem — it's a sales process problem.`;\n  const gapCTA = isHighPerformer\n    ? 'Join NLCA — push your close rate to 70%'\n    : `Join NLCA — start closing the $${monthlyGap.toLocaleString()}/mo gap`;\n\n  const flaggedCount = Object.values(SEV).filter(s => s !== 'ok').length;\n  const body = document.getElementById('resultsBody');\n\n  /* ── Low volume path ── */\n  if (isLowVol) {\n    body.innerHTML = `\n      \u003Cdiv class=\"low-intent-block\">\n        \u003Cspan class=\"li-eyebrow\">Your Results\u003C/span>\n        \u003Cdiv class=\"li-headline\">Right now, the lever is volume — not close rate.\u003C/div>\n        \u003Cp class=\"li-body\">With fewer than 5 full arch consultations per month, the math on case acceptance coaching is thin. The bigger move is getting more viable leads into the chair first.\u003Cbr>\u003Cbr>\n        Stacy defines a viable lead as someone with at least one of the Three Cs: \u003Cstrong>Cash, Credit, or a Co-signer.\u003C/strong> The lead call exists to filter for exactly that — so when you do sit across from someone, it's a conversation worth having.\u003Cbr>\u003Cbr>\n        Once you're running 8 to 10 qualified consultations a month, closing 40% more of them means $50,000+ in additional monthly revenue. That's when NLCA becomes the highest-leverage investment you can make.\u003Cbr>\u003Cbr>\n        \u003Cstrong>Fastest path to volume:\u003C/strong> Referral partnerships with local implant reps and oral surgeons, a structured follow-up sequence for leads who didn't book, and a reactivation campaign to your existing patient base for full arch evaluation offers.\u003C/p>\n      \u003C/div>\n      \u003Cdiv class=\"cta-section\">\u003Cdiv class=\"cta-section-content\">\n        \u003Ch2>Want the full framework when you're ready?\u003C/h2>\n        \u003Cp>Join the waitlist for NLCA. When you hit volume, you'll want this system ready to run.\u003C/p>\n        \u003Ca href=\"https://fullarchsalesexperts.com/nextlevel-124405\" class=\"cta-section-btn\" target=\"_blank\">\n          Learn About NLCA\n          \u003Csvg width=\"16\" height=\"16\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\"/>\u003C/svg>\n        \u003C/a>\n        \u003Cp class=\"cta-fine\">$295/month · Live with Stacy twice a month · No long-term contract\u003C/p>\n      \u003C/div>\u003C/div>`;\n    return;\n  }\n\n  /* ── Main results ── */\n  body.innerHTML = `\n    \u003C!-- RESULTS HEADER -->\n    \u003Cdiv class=\"results-header\">\n      \u003Cdiv class=\"rh-inner\">\n        \u003Cspan class=\"rh-eyebrow\">Your Full Arch Revenue Audit\u003C/span>\n        \u003Ch1 class=\"rh-title\">${gapHeadline}\u003C/h1>\n        \u003Cp class=\"rh-sub\">${gapSub}\u003C/p>\n        \u003Ca href=\"https://fullarchsalesexperts.com/nextlevel-124405\" target=\"_blank\" class=\"rh-cta-btn\">\n          ${gapCTA}\n          \u003Csvg width=\"16\" height=\"16\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\"/>\u003C/svg>\n        \u003C/a>\n      \u003C/div>\n    \u003C/div>\n\n    \u003C!-- SECTION ① PRACTICE PROFILE -->\n    \u003Cdiv class=\"report-section\">\n      \u003Cdiv class=\"section-num-row\">\n        \u003Cdiv class=\"section-num\">1\u003C/div>\n        \u003Cdiv class=\"section-label-tag\">Your Practice Profile\u003C/div>\n      \u003C/div>\n      \u003Ch2 class=\"section-heading\">Practice Diagnostic Metrics\u003C/h2>\n      \u003Cp class=\"section-intro\">Five areas benchmarked against Stacy's proven framework. Each bar shows how your practice stacks up — and where the biggest gaps live.\u003C/p>\n      ${buildTraitBars()}\n    \u003C/div>\n\n    \u003C!-- SECTION ② THE REVENUE GAP -->\n    \u003Cdiv class=\"report-section\">\n      \u003Cdiv class=\"section-num-row\">\n        \u003Cdiv class=\"section-num\">2\u003C/div>\n        \u003Cdiv class=\"section-label-tag\">The Revenue Gap\u003C/div>\n      \u003C/div>\n      \u003Ch2 class=\"section-heading\">The Math Behind Your Gap\u003C/h2>\n      \u003Cp class=\"section-intro\">Your numbers against Stacy's benchmark — showing exactly what better close rate performance is worth at your volume.\u003C/p>\n      \u003Cdiv class=\"math-block\">\n        \u003Cdiv class=\"math-rows\">\n          \u003Cdiv class=\"math-row\">\u003Cspan class=\"math-label\">Monthly full arch consultations\u003C/span>\u003Cspan class=\"math-value\">${vol}\u003C/span>\u003C/div>\n          \u003Cdiv class=\"math-row\">\u003Cspan class=\"math-label\">Your estimated close rate\u003C/span>\u003Cspan class=\"math-value\">${Math.round(rate * 100)}%\u003C/span>\u003C/div>\n          \u003Cdiv class=\"math-row\">\u003Cspan class=\"math-label\">Stacy's proven close rate benchmark\u003C/span>\u003Cspan class=\"math-value\">70%\u003C/span>\u003C/div>\n          \u003Cdiv class=\"math-row\">\u003Cspan class=\"math-label\">Average full arch case value\u003C/span>\u003Cspan class=\"math-value\">$25,000\u003C/span>\u003C/div>\n          \u003Cdiv class=\"math-row gap-row\">\u003Cspan class=\"math-label\">Monthly revenue gap\u003C/span>\u003Cspan class=\"math-value highlight\">${gapDisplay}\u003C/span>\u003C/div>\n          ${!isHighPerformer ? `\n          \u003Cdiv class=\"math-row\">\u003Cspan class=\"math-label\">Annual gap\u003C/span>\u003Cspan class=\"math-value\">$${annualGap.toLocaleString()}\u003C/span>\u003C/div>\n          \u003Cdiv class=\"math-row\">\u003Cspan class=\"math-label\">NLCA cost vs. monthly gap\u003C/span>\u003Cspan class=\"math-value\">$295 vs. $${monthlyGap.toLocaleString()}\u003C/span>\u003C/div>` : ''}\n        \u003C/div>\n        \u003Cp class=\"math-assumption\">Based on your answers. $25,000 used as a conservative full arch case value — actual values vary by market and treatment type.\u003C/p>\n      \u003C/div>\n    \u003C/div>\n\n    \u003C!-- SECTION ③ DIAGNOSTIC FINDINGS -->\n    \u003Cdiv class=\"report-section\">\n      \u003Cdiv class=\"section-num-row\">\n        \u003Cdiv class=\"section-num\">3\u003C/div>\n        \u003Cdiv class=\"section-label-tag\">Diagnostic Findings\u003C/div>\n      \u003C/div>\n      \u003Ch2 class=\"section-heading\">${flaggedCount > 0 ? flaggedCount + ' Area' + (flaggedCount > 1 ? 's' : '') + ' Need' + (flaggedCount === 1 ? 's' : '') + ' Attention' : 'Your Consult Process Is Tracking Well'}\u003C/h2>\n      \u003Cp class=\"section-intro\">${flaggedCount > 0 ? 'Each finding below maps to a specific breakdown in your consult process — with the root cause, revenue impact, and concrete fixes.' : 'Across all five areas your practice is benchmarking well. The opportunity now is refinement — pushing toward elite performance on objection handling and financing pivots.'}\u003C/p>\n      \u003Cdiv class=\"full-report-header\">\n        \u003Cdiv>\u003C/div>\n        \u003Cbutton class=\"pdf-btn\" onclick=\"window.print()\">\n          \u003Csvg width=\"14\" height=\"14\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z\"/>\u003C/svg>\n          Save as PDF\n        \u003C/button>\n      \u003C/div>\n      ${flaggedCount > 0\n        ? `\u003Cdiv class=\"section-cards-wrap\">${cards.join('')}\u003C/div>`\n        : ``\n      }\n    \u003C/div>\n\n    \u003C!-- SECTION ④ LEARNING PATH -->\n    \u003Cdiv class=\"full-report\" id=\"fullReport\">\n      ${buildLearningPath()}\n    \u003C/div>\n\n    \u003C!-- SOCIAL PROOF -->\n    \u003Cdiv class=\"social-proof-band\">\n      ${stacyPull(\n        'Patients don\\'t say no to implants. They say no to uncertainty — and uncertainty is eliminated by a really good conversation, not a lower price.',\n        'Stacy Farley'\n      )}\n\n      ${buildStacyTake()}\n    \u003C/div>\n\n    \u003Cdiv style=\"background:#fff; border-top: 1px solid var(--r-border); padding: 48px 48px;\">\n      \u003Cdiv class=\"section-num-row\" style=\"margin-bottom:20px;\">\n        \u003Cspan style=\"font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--r-text3);\">Practice Results\u003C/span>\n      \u003C/div>\n      ${buildTestimonials()}\n    \u003C/div>\n\n    ${buildVideoTestimonials()}\n\n    \u003Cdiv class=\"cta-section\">\n      \u003Cdiv class=\"cta-section-content\">\n        \u003Ch2>One closed arch case covers NLCA for the entire year.\u003C/h2>\n        \u003Cp>Live virtual training with Stacy twice a month — your whole team participates from inside your practice. Lead call scripts, objection frameworks, financing conversations, and the complete sales system Stacy used to close 40–50 arches a month for eight years. Sessions are recorded if you miss one.\u003C/p>\n        \u003Ca href=\"https://fullarchsalesexperts.com/nextlevel-124405\" target=\"_blank\" class=\"cta-section-btn\">\n          Join NLCA — $295/Month\n          \u003Csvg width=\"16\" height=\"16\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\u003Cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\"/>\u003C/svg>\n        \u003C/a>\n        \u003Cp class=\"cta-fine\">$295/month · Recordings sent after every session · No long-term contract\u003C/p>\n      \u003C/div>\n    \u003C/div>`;\n\n  wireEnterKeys();\n}\n\n/* ── FORM SUBMIT ── */\nasync function submitForm() {\n  const nameEl  = document.getElementById('rgName');\n  const emailEl = document.getElementById('rgEmail');\n  let valid = true;\n\n  const nameEmpty  = !nameEl.value.trim();\n  const emailEmpty = !emailEl.value.trim();\n  const emailBad   = !emailEmpty && !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(emailEl.value.trim());\n\n  document.getElementById('rgf-name').classList.toggle('has-error', nameEmpty);\n  if (nameEmpty) { shake(nameEl); valid = false; }\n  document.getElementById('rgf-email').classList.toggle('has-error', emailEmpty || emailBad);\n  if (emailEmpty || emailBad) {\n    document.querySelector('#rgf-email .rg-field-err').textContent = emailEmpty ? 'Required' : 'Enter a valid email';\n    shake(emailEl); valid = false;\n  }\n  const consent1 = document.getElementById('consent1');\n  const consent2 = document.getElementById('consent2');\n  if (!consent1.checked) {\n    document.getElementById('consent1-wrap').classList.add('has-error');\n    document.getElementById('consent1-err').style.display = 'block';\n    valid = false;\n  } else {\n    document.getElementById('consent1-wrap').classList.remove('has-error');\n    document.getElementById('consent1-err').style.display = 'none';\n  }\n  if (!consent2.checked) {\n    document.getElementById('consent2-wrap').classList.add('has-error');\n    document.getElementById('consent2-err').style.display = 'block';\n    valid = false;\n  } else {\n    document.getElementById('consent2-wrap').classList.remove('has-error');\n    document.getElementById('consent2-err').style.display = 'none';\n  }\n\n  if (!valid) return;\n\n  const a = state.answers;\n  /* Remap answers so report-ghl.html receives keys it expects:\n     new quiz:  q1=vol, q2=showup, q3=closeRate, q4=handoff, q5=marketing\n     ghl report expects: q1=vol, q2=closeRate, q3=handoff, q4=caseLoss, q5=marketing\n     q6 carries show-up for report_block2_v2.html                                  */\n  const reportAnswers = {\n    q1: a.q1,      // volume — unchanged\n    q2: a.q3,      // close rate (position 3 → key q2)\n    q3: a.q4,      // handoff  (position 4 → key q3)\n    q4: 'close',   // case loss dropped → safe neutral default\n    q5: a.q5,      // marketing — unchanged\n    q6: a.q2       // show-up stored separately for v2 report\n  };\n  const lead = {\n    name:     nameEl.value.trim(),\n    email:    emailEl.value.trim(),\n    phone:    (document.getElementById('rgPhone') || {}).value || '',\n    practice: (document.getElementById('rgPractice') || {}).value || '',\n    answers:  reportAnswers,\n    savedAt:  Date.now()\n  };\n  state.lead = lead;\n  try { localStorage.setItem('nlca_report', JSON.stringify(lead)); } catch(e) {}\n\n  /* Send lead + answers to n8n webhook */\n  submitToN8N(lead).catch(() => {});\n  submitToGHL(lead).catch(() => {});\n\n  /* Go to analyzing → results */\n  runAnalysis();\n}\n\nasync function submitToGHL(lead) {\n  if (!GHL_WEBHOOK_URL || GHL_WEBHOOK_URL === 'YOUR_GHL_WEBHOOK_URL_HERE') return;\n  const nameParts = lead.name.split(' ');\n  const payload = {\n    firstName:    nameParts[0] || '',\n    lastName:     nameParts.slice(1).join(' ') || '',\n    email:        lead.email,\n    phone:        lead.phone,\n    name:         lead.name,\n    source:       'NLCA Revenue Audit',\n    tags:         ['nlca-audit'],\n    customField: {\n      practice_name:           lead.practice,\n      consultations_per_month: lead.answers.q1,\n      close_rate:              lead.answers.q2,\n      financial_handoff:       lead.answers.q3,\n      case_loss_pattern:       lead.answers.q4,\n      marketing_spend:         lead.answers.q5\n    },\n    submittedAt: new Date().toISOString()\n  };\n  try {\n    await fetch(GHL_WEBHOOK_URL, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify(payload)\n    });\n  } catch(e) { console.warn('[NLCA] GHL webhook error:', e); }\n}\n\nasync function submitToN8N(lead) {\n  if (!N8N_WEBHOOK_URL || N8N_WEBHOOK_URL === 'YOUR_N8N_WEBHOOK_URL_HERE') return;\n  const nameParts = lead.name.split(' ');\n  /* labels keyed against REMAPPED lead.answers: q1=vol, q2=close, q3=handoff, q4='close' literal, q5=mkt, q6=show-up */\n  const Q1_LABEL = { '5-14': '5–14 consults/month', '15-29': '15–29 consults/month', '30-49': '30–49 consults/month', '50plus': '50+ consults/month' };\n  const Q2_LABEL = { 'u20': 'Under 20% close', '20-40': '20–40% close', '41-60': '41–60% close', '61plus': '61%+ close' };\n  const Q3_LABEL = { 'doctor-full': 'Doctor handles treatment + pricing together', 'doctor-led-fin': 'Doctor leads, hands off to staff mid-conversation', 'tc-no-script': 'TC handles finances — no set script', 'tc-scripted': 'TC follows a structured financial presentation' };\n  const Q5_LABEL = { 'u5': 'Under 5%', '5-15': '5–15%', 'o15': 'Over 15%' };\n  const Q6_LABEL = { 'u60': 'Under 60% show-up', '61-79': '61–79% show-up', '80plus': '80%+ show-up' };\n  const volMap  = { '5-14': 10, '15-29': 22, '30-49': 40, '50plus': 60 };\n  const rateMap = { 'u20': 0.15, '20-40': 0.30, '41-60': 0.50, '61plus': 0.65 };\n  const vol  = volMap[lead.answers.q1]  || 10;\n  const rate = rateMap[lead.answers.q2] || 0.30;\n  const monthlyGap = Math.round(Math.max(0, 0.70 - rate) * vol * 25000);\n  const payload = {\n    firstName:    nameParts[0] || '',\n    lastName:     nameParts.slice(1).join(' ') || '',\n    email:        lead.email,\n    phone:        lead.phone,\n    practiceName: lead.practice,\n    source:       'NLCA Revenue Audit',\n    tags:         ['nlca-audit'],\n    quiz: {\n      q1_consultations_raw:   lead.answers.q1,\n      q1_consultations:       Q1_LABEL[lead.answers.q1] || lead.answers.q1,\n      q2_close_rate_raw:      lead.answers.q2,\n      q2_close_rate:          Q2_LABEL[lead.answers.q2] || lead.answers.q2,\n      q3_financial_handoff_raw: lead.answers.q3,\n      q3_financial_handoff:   Q3_LABEL[lead.answers.q3] || lead.answers.q3,\n      q4_case_loss_raw:       lead.answers.q4,\n      q4_case_loss:           lead.answers.q4,\n      q6_show_up_raw:         lead.answers.q6,\n      q6_show_up:             Q6_LABEL[lead.answers.q6] || lead.answers.q6,\n      q5_marketing_spend_raw: lead.answers.q5,\n      q5_marketing_spend:     Q5_LABEL[lead.answers.q5] || lead.answers.q5\n    },\n    computed: {\n      monthlyConsultations: vol,\n      closeRatePct:         Math.round(rate * 100),\n      monthlyRevenueGap:    monthlyGap,\n      annualRevenueGap:     monthlyGap * 12\n    },\n    submittedAt: new Date().toISOString()\n  };\n  try {\n    await fetch(N8N_WEBHOOK_URL, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify(payload)\n    });\n  } catch(e) { console.warn('[NLCA] n8n webhook error:', e); }\n}\n\nfunction shake(el) {\n  el.classList.remove('shaking'); void el.offsetWidth; el.classList.add('shaking');\n  el.addEventListener('animationend', () => el.classList.remove('shaking'), { once: true });\n}\n\nfunction wireEnterKeys() {\n  ['rgName','rgEmail','rgPhone','rgPractice'].forEach((id, idx, arr) => {\n    const el = document.getElementById(id); if (!el) return;\n    el.addEventListener('keydown', e => {\n      if (e.key === 'Enter') {\n        e.preventDefault();\n        const next = document.getElementById(arr[idx + 1]);\n        if (next) next.focus(); else submitForm();\n      }\n    });\n  });\n}\n\nbuildQuestions();\n\n/* ── DEFENSIVE EVENT DELEGATION ──\n   Some Mac browsers + GHL CSP combos silently block inline onclick handlers.\n   This listens at the document level so clicks still fire even if inline handlers fail.\n   Each button is identified by class/data attributes so handlers route correctly. */\ndocument.addEventListener('click', function(e) {\n  /* Choice button */\n  var choiceBtn = e.target.closest('.choice-btn');\n  if (choiceBtn) {\n    var stepEl = choiceBtn.closest('[id^=\"choices-\"]');\n    if (stepEl) {\n      var step = parseInt(stepEl.id.replace('choices-', ''), 10);\n      var val = choiceBtn.getAttribute('data-val');\n      if (step && val) { pick(step, val, choiceBtn); }\n    }\n    return;\n  }\n  /* Next / Back buttons */\n  var nextBtn = e.target.closest('.btn-next');\n  if (nextBtn && !nextBtn.disabled) {\n    var nId = nextBtn.id || '';\n    var n = parseInt(nId.replace('nxt-', ''), 10);\n    if (n) { advance(n); }\n    return;\n  }\n  var backBtn = e.target.closest('.btn-back');\n  if (backBtn) {\n    var panel = backBtn.closest('[id^=\"step-\"]');\n    if (panel) {\n      var b = parseInt(panel.id.replace('step-', ''), 10);\n      if (b) { back(b); }\n    }\n    return;\n  }\n  /* Start assessment + submit */\n  if (e.target.closest('.sp-start-btn') || e.target.closest('.nav-cta-btn')) {\n    startAssessment();\n    return;\n  }\n  if (e.target.closest('.rg-submit')) {\n    e.preventDefault();\n    submitForm();\n    return;\n  }\n  /* Splash logo (return to splash) */\n  if (e.target.closest('.res-brand')) {\n    e.preventDefault();\n    showSplash();\n    return;\n  }\n});\n\n/* Slider input delegation — handles 'input' event from any .q-slider in case inline oninput is blocked */\ndocument.addEventListener('input', function(e) {\n  var slider = e.target.closest('.q-slider');\n  if (!slider) return;\n  var sId = slider.id || '';\n  var n = parseInt(sId.replace('sl-', ''), 10);\n  if (n) { sliderMove(n, slider); }\n});\n\n/* Also handle 'change' as a fallback for browsers/contexts where 'input' may be blocked */\ndocument.addEventListener('change', function(e) {\n  var slider = e.target.closest('.q-slider');\n  if (!slider) return;\n  var sId = slider.id || '';\n  var n = parseInt(sId.replace('sl-', ''), 10);\n  if (n) { sliderMove(n, slider); }\n});\n\n/* ── FOOTER injected into document.body to escape GHL container ── */\n(function(){\n  var s = document.createElement('style');\n  s.textContent =\n    '#nlca-footer{' +\n      'display:block!important;width:100%!important;' +\n      'text-align:center!important;padding:20px 24px 28px!important;' +\n      'font-size:11px!important;line-height:1.7!important;' +\n      'color:rgba(255,255,255,0.25)!important;background:#040417!important;' +\n      'border-top:1px solid rgba(255,255,255,0.07)!important;' +\n      'margin:0!important;margin-top:0!important;margin-bottom:0!important;' +\n      'box-sizing:border-box!important;}' +\n    '#nlca-footer a{color:rgba(255,255,255,0.25)!important;text-decoration:none!important;}' +\n    '#nlca-footer a:hover{color:rgba(255,255,255,0.5)!important;}' +\n    'body.results-active #nlca-footer{' +\n      'color:#9496B8!important;background:#F4F5FF!important;' +\n      'border-top:1px solid #E4E6F4!important;}' +\n    'body.results-active #nlca-footer a{color:#9496B8!important;}' +\n    'body.results-active #nlca-footer a:hover{color:#1667E8!important;}';\n  document.head.appendChild(s);\n\n  var f = document.createElement('footer');\n  f.id = 'nlca-footer';\n  f.innerHTML =\n    '\u003Cp>Full Arch Sales Experts &nbsp;&middot;&nbsp; ' +\n    '\u003Ca href=\"https://fullarchsalesexperts.com/nextlevel-124405\">fullarchsalesexperts.com\u003C/a>\u003C/p>' +\n    '\u003Cp>' +\n      '\u003Ca href=\"https://fullarchsalesexperts.com/privacy-policy-page\" target=\"_blank\" rel=\"noopener noreferrer\">Privacy Policy\u003C/a>' +\n      ' &nbsp;&middot;&nbsp; ' +\n      '\u003Ca href=\"https://fullarchsalesexperts.com/terms-of-use\" target=\"_blank\" rel=\"noopener noreferrer\">Terms of Use\u003C/a>' +\n    '\u003C/p>' +\n    '\u003Cp>&copy; 2026 Full Arch Sales Experts. All rights reserved.\u003C/p>';\n  document.body.appendChild(f);\n})();\n\n\u003C/script>\n\n\u003C!-- VISUAL EDITOR — local only, never commit to GitHub -->\n\u003Cscript>if(location.search.includes('edit')){const s=document.createElement('script');s.src='editor.js';document.body.appendChild(s);}\u003C/script>\n\u003C/body>\n\u003C/html>\n",{"value":95},[],"ccustom-code-XrPvXlJg70","custom-code","c-custom-code",{},[],[],{"author":103,"canonicalMeta":104,"customMeta":105,"description":106,"imageUrl":107,"keywords":108,"language":109,"title":110,"isPreviewUrl":25},"Stacy Farley",[],[],"Proven full-arch sales system. Train your team to increase case acceptance, close more implant cases, and grow practice revenue.","https://assets.cdn.filesafe.space/vdi6H8skwmbrWBAz1f6X/media/68f65bd1b00f750a426302ed.png","full arch implant objection handling\nhow to handle i need to think about it dental implants\ndental implant financing objection script\nspouse objection dental implants treatment coordinator\nfull arch case acceptance rate average\nwhy patients decline full arch implants\nfull arch dental patient says no objection response\nhow to close full arch implant cases\n\nCLUSTER 2 — BENCHMARKS & DATA\nfull arch implant close rate benchmark\naverage dental implant case acceptance rate\nhow many full arch consults convert\nfull arch implant revenue per case accepted\ndental implant conversion rate improvement\ndental case acceptance 654 percent increase study\n\nfull arch sales training for treatment coordinators\nhow to present full arch implants to patients\ndental treatment coordinator scripts full arch\ntraining staff to close implant cases\npatient coordinator implant consultation training\ndental implant consultation conversion training\nwhat do top treatment coordinators do differently implants\nfull arch implant sales training treatment coordinator\nfull arch sales framework treatment coordinator\n\n\nfull arch implant revenue per practice\nhow to grow full arch implant cases in dental practice\nfull arch vs single implant practice profitability\ndental practice full arch case development strategy\nbuilding full arch implant program dental office\nincreasing case acceptance high value dental treatment\nfull arch implant program roi dental practice\nfull arch implant sales coaching dental practice\nfull arch sales course for treatment coordinators\n\nCLUSTER 5 — BRANDED & AUTHORITY\nstacy farley dental sales\nfull arch dental sales coach\nfull arch revenue audit dental\nfull arch implant masterclass training\ncoachiq dental alternative full arch\nfull arch implant consultation conversion rate\nfull arch implant case closing techniques","en","Free Full Arch Revenue Audit — Find Out Where Your Cases Are Leaking.","fullarchsalesexperts.com","/ncla-quiz-funnel","ivUC7nXVvPgWFS1W3UpQ","NCLA Squeeze page","vdi6H8skwmbrWBAz1f6X",[117],{"id":118,"elements":119,"activeElementId":118},"hl_main_popup-FL1dO1Z8w2",[120],{"extra":121,"class":137,"styles":138,"customCss":141,"id":118,"child":142,"meta":143,"title":144,"tag":29},{"bgImage":122,"overlayColor":124,"left":126,"popupDisabled":128,"popupHide":129,"minWidth":130,"showPopupOnMouseOut":132,"customClass":134,"position":136},{"value":123},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop":32},{"value":125},"var(--overlay)",{"value":127,"unit":56},50,{"value":25},{"value":25},{"value":131},"medium-page",{"value":133,"delay":86},"exit",{"value":135},[],{"value":76},{},{"borderWidth":139},{"value":140},"10px",[],[],"hl_main_popup","Popup","https://stcdn.leadconnectorhq.com/funnel/icon/favicon.ico","DQvraiMOHHmAezeZddez","NCLA Quiz Funnel","c0792153-bbd9-45f8-9607-5bd1a1a913fd",[],null,["Reactive",152],{"$snuxt-i18n-meta":153,"$spreviewState":154,"$smetaPixelOptions":269},{},{"defaultSettings":155,"mobileDevice":25,"funnelId":146,"funnelDomain":111,"stepId":148,"locationId":115,"funnelPageId":113,"locationCode":239,"funnelNextStep":240,"fingerprint":29,"funnelNextPageId":241,"stripePublishableKey":242,"enablePaymentElement":25,"merchantLoginId":29,"paypalPublishableKey":29,"merchantAccountId":-1,"stripeAccountId":243,"isLivePaymentMode":32,"version":244,"funnelSteps":245,"cartItems":253,"funnelName":147,"orderFormVersion":83,"currency":254,"businessCurrency":254,"blogSlug":29,"domain":111,"pageUrl":112,"pageName":114,"pageSeo":255,"affiliateId":-1,"videoExistsInPage":25,"pageType":256,"contactId":-1,"email":-1,"phone":29,"categoryId":29,"blogSearchTerm":29,"categoryUrlSlug":29,"authorSlug":29,"tagSlug":29,"authorId":29,"defaultPaymentProvider":29,"productCollections":257,"ecomSelectedCollection":29,"imageOptimizationEnabled":32,"nmiMerchantGatewayId":29,"squareMerchantGatewayId":29,"mercadoPagoUserId":29,"fontsToLoad":258,"ecomProductId":29,"isGdprCompliant":25,"isOptimisePageLoad":32,"ecommercePage":86,"isBlogActive":25,"blogData":259,"blogPaths":-1,"blogId":146,"allowedCookies":260,"paymentProviderDetails":-1,"events":261,"searchTerm":29,"countryList":262,"pixelToInit":149,"formAction":29,"ecomProduct":263,"requireCreditCard":32,"haveBlogWidget":25,"isFacebookIAB":25,"userAgent":29,"companyId":264,"customerLoginToken":29,"cookieConsentList":265,"cookieConsentExpiry":266,"mediaFormats":267,"adyenMerchantGatewayId":29,"webinarProperties":150,"webinarSession":150,"userWebinarSession":150,"productDetailPageStyles":150,"geoCountry":150,"isCurrencyFormattingEnabled":25},{"typography":156,"background":177,"percentWidth":182,"offsetColor":216,"progressBarSize":229},{"fonts":157,"colors":168},{"headlineFont":158,"contentFont":164},{"id":159,"text":160,"value":161},"headlinefont","Headline Font",{"text":162,"value":163},"Inter","var(--inter)",{"id":165,"text":166,"value":167},"contentfont","Content Font",{"text":162,"value":163},{"textColor":169,"linkColor":173},{"value":170},{"label":171,"value":172},"var(--black)","#000000",{"value":174},{"label":175,"value":176},"var(--blue)","#188bf6",{"bgImage":178,"backgroundColor":180},{"value":179},{"url":29,"options":31},{"value":181},"var(--white)",[183,186,189,192,195,198,201,204,207,210,213],{"text":184,"value":185},"0 Percent","progress0",{"text":187,"value":188},"10 Percent","progress10",{"text":190,"value":191},"20 Percent","progress20",{"text":193,"value":194},"30 Percent","progress30",{"text":196,"value":197},"40 Percent","progress40",{"text":199,"value":200},"50 Percent","progress50",{"text":202,"value":203},"60 Percent","progress60",{"text":205,"value":206},"70 Percent","progress70",{"text":208,"value":209},"80 Percent","progress80",{"text":211,"value":212},"90 Percent","progress90",{"text":214,"value":215},"100 Percent","progress100",[217,220,223,226],{"text":218,"value":219},"White","progressbarOffsetWhite",{"text":221,"value":222},"Transparent White","progressbarOffsetTransparentWhite",{"text":224,"value":225},"Black","progressbarOffsetBlack",{"text":227,"value":228},"Transparent Black","progressbarOffsetTransparentBlack",[230,233,236],{"text":231,"value":232},"Small","progressbarSmall",{"text":234,"value":235},"Medium","progressbarMedium",{"text":237,"value":238},"Large","progressbarLarge","US","/result-page","ywRwhxFZ1ngSvI9MDO4H","pk_live_MtxwO3obi7pfD7UZlGkfR2yj","acct_1R1v2XHp74q70dkq",4,[246,250],{"url":247,"value":148,"type":248,"sequence":86,"name":249,"split":25},"/ncla-squeeze-page","optin_funnel_page","NCLA Squeeze page ",{"url":240,"value":251,"type":248,"sequence":83,"id":241,"name":252,"split":25},"b382914c-b1e7-4050-89ed-bba29cd4866d","Result Page",[],"USD",{"title":110,"description":106,"imageUrl":107},"funnel",[],[],{},[],[],[],{},"MAtctDG2M1cVuV6vHu9y",[],["Date","2026-06-16T02:20:35.811Z"],{"formats":268},[],{"pixelID":150,"disabled":25,"track":270,"version":271,"isEnabled":32,"pixelLoaded":25,"manualMode":32,"userData":150,"eventsQueue":272},"PageView","2.0",[],["Set"],["ShallowReactive",275],{"pageData":-1}]</script></body></html>