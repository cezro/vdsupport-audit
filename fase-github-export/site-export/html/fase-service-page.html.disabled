ePageLoad":32,"backgroundSettingsClass":31,"schemaMarkup":142,"isGeolocationNeeded":25},[6,10,40,61,87],{"id":7,"child":8},"hl_main",[9],"section-_9ZR-ADKoL",{"id":9,"type":11,"child":12,"class":14,"styles":17,"extra":20,"meta":11,"tagName":38,"title":39,"_id":9},"section",[13],"row-pvbEJ19u7z",{"width":15},{"value":16},"fullSection",{"borderWidth":18},{"value":19},"0px",{"sticky":21,"visibility":23,"bgImage":26,"allowRowMaxWidth":33,"customClass":34,"elementScreenshot":36},{"value":22},"noneSticky",{"value":24},{"hideDesktop":25,"hideMobile":25},false,{"value":27},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop":32},"image","","1","bgCover",true,{"value":25},{"value":35},[],{"value":37},[],"c-section","Section",{"id":13,"type":41,"child":42,"class":44,"styles":47,"extra":49,"tagName":59,"meta":41,"title":60},"row",[43],"col-4JoJkRdKXN",{"alignRow":45},{"value":46},"row-align-center",{"borderWidth":48},{"value":19},{"visibility":50,"bgImage":52,"rowWidth":54,"customClass":57},{"value":51},{"hideDesktop":25,"hideMobile":25},{"value":53},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop":32},{"value":55,"unit":56},100,"%",{"value":58},[],"c-row","1 Column Row",{"id":43,"type":62,"child":63,"class":65,"styles":66,"extra":68,"tagName":84,"meta":62,"title":85,"noOfColumns":86},"col",[64],"custom-code-Wc1SFX4rcd",{},{"borderWidth":67},{"value":19},{"visibility":69,"bgImage":71,"columnLayout":73,"justifyContentColumnLayout":75,"alignContentColumnLayout":77,"forceColumnLayoutForMobile":79,"customClass":80,"elementVersion":82},{"value":70},{"hideDesktop":25,"hideMobile":25},{"value":72},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop":32},{"value":74},"column",{"value":76},"center",{"value":78},"inherit",{"value":32},{"value":81},[],{"value":83},2,"c-column","1st Column",1,{"extra":88,"id":64,"meta":97,"tagName":98,"class":99},{"visibility":89,"customCode":91,"customClass":94,"nodeId":96},{"value":90},{"hideMobile":29,"hideDesktop":29},{"value":92},{"rawCustomCode":93},"\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\" />\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0\" />\n  \u003Cstyle>html{width:100%!important;}\u003C/style>\n  \u003Ctitle>Full Arch Sales Experts | Stacy Farley\u003C/title>\n  \u003Clink href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&family=Anton&display=swap\" rel=\"stylesheet\" />\n  \u003Cstyle>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    /* ── GHL full-width override ── */\n    html, body {\n      width: 100vw !important;\n      max-width: 100vw !important;\n      overflow-x: hidden !important;\n      margin: 0 !important;\n      padding: 0 !important;\n    }\n\n    /* Full-bleed breakout — escapes ANY GHL container regardless of its width */\n    #page-root {\n      width: 100vw !important;\n      max-width: 100vw !important;\n      position: relative !important;\n      left: 50% !important;\n      right: 50% !important;\n      margin-left: -50vw !important;\n      margin-right: -50vw !important;\n      overflow-x: hidden !important;\n    }\n\n    /* Nuke any GHL wrapper padding/margin that may persist */\n    #page-wrap, .page-wrap, .content-wrapper, .ghl-page,\n    [data-section], [data-element], .container-fluid {\n      max-width: none !important;\n      width: 100% !important;\n      padding-left: 0 !important;\n      padding-right: 0 !important;\n      margin-left: 0 !important;\n      margin-right: 0 !important;\n    }\n\n    :root {\n      --charcoal:    #040417;\n      --navy:        #0A0A28;\n      --navy2:       #10102E;\n      --azure:       #1667E8;\n      --azure-dark:  #0F4FB5;\n      --azure-light: #E8F0FD;\n      --gold:        #F0B429;\n      --white:       #FFFFFF;\n      --muted:       rgba(255,255,255,0.65);\n      --subtle:      rgba(255,255,255,0.08);\n    }\n\n    html { scroll-behavior: smooth; }\n\n    body {\n      font-family: 'Manrope', sans-serif;\n      background: var(--charcoal);\n      color: var(--white);\n      line-height: 1.7;\n    }\n\n    /* ─── UTILITY ─── */\n    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }\n\n    .btn-primary {\n      display: inline-block;\n      background: var(--azure);\n      color: #fff;\n      font-family: 'Manrope', sans-serif;\n      font-size: 17px;\n      font-weight: 700;\n      padding: 18px 36px;\n      border-radius: 6px;\n      border: none;\n      cursor: pointer;\n      text-decoration: none;\n      transition: background .2s, transform .1s;\n    }\n    .btn-primary:hover { background: var(--azure-dark); transform: scale(1.02); }\n\n    .btn-ghost {\n      display: inline-block;\n      background: transparent;\n      color: #fff;\n      font-family: 'Manrope', sans-serif;\n      font-size: 16px;\n      font-weight: 700;\n      padding: 16px 34px;\n      border-radius: 6px;\n      border: 2px solid rgba(255,255,255,0.8);\n      cursor: pointer;\n      text-decoration: none;\n      transition: background .2s, border-color .2s;\n    }\n    .btn-ghost:hover { background: rgba(255,255,255,0.08); border-color: #fff; }\n\n    .section-label {\n      font-size: 13px;\n      font-weight: 600;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      color: var(--gold);\n      margin-bottom: 14px;\n      display: block;\n    }\n\n    .section-header {\n      text-align: center;\n      max-width: 700px;\n      margin: 0 auto 56px;\n    }\n    .section-header h2 {\n      font-size: clamp(30px, 3.5vw, 44px);\n      font-weight: 800;\n      color: var(--white);\n      line-height: 1.18;\n      margin-bottom: 16px;\n    }\n    .section-header h2 em { color: var(--azure); font-style: normal; }\n    .section-header p { font-size: 17px; color: var(--muted); line-height: 1.75; }\n\n    /* ─── LOGO ─── */\n    .fase-logo { text-decoration: none; display: inline-block; }\n    .logo-mark {\n      background: #1D2027;\n      padding: 8px 16px 10px;\n      border-radius: 5px;\n      text-align: center;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 2px;\n    }\n    .logo-top {\n      font-family: 'Anton', sans-serif;\n      font-size: 21px;\n      color: #fff;\n      letter-spacing: 2.5px;\n      line-height: 1;\n      display: block;\n    }\n    .logo-bottom {\n      font-family: 'Anton', sans-serif;\n      font-size: 10.5px;\n      color: #fff;\n      letter-spacing: 3.5px;\n      line-height: 1;\n      display: block;\n    }\n\n    /* ─── NAV ─── */\n    nav {\n      background: #1D2027 !important;\n      backdrop-filter: blur(10px);\n      -webkit-backdrop-filter: blur(10px);\n      padding: 16px 0;\n      position: sticky;\n      top: 0;\n      z-index: 100;\n      width: 100% !important;\n      left: 0;\n      border-bottom: 1px solid rgba(255,255,255,0.06);\n    }\n    nav .container {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 24px;\n    }\n    .nav-links {\n      display: flex;\n      gap: 32px;\n      list-style: none;\n    }\n    .nav-links a {\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--muted);\n      text-decoration: none;\n      transition: color .2s;\n    }\n    .nav-links a:hover { color: var(--azure); }\n    .nav-cta { padding: 12px 24px; font-size: 14px; }\n\n    /* ─── HERO ─── */\n    #hero {\n      background: linear-gradient(160deg, var(--charcoal) 0%, var(--navy) 100%);\n      padding: 100px 0 90px;\n      overflow: hidden;\n      position: relative;\n    }\n    #hero::after {\n      content: '';\n      position: absolute;\n      top: -100px; right: -100px;\n      width: 600px; height: 600px;\n      background: radial-gradient(circle, rgba(22,103,232,0.12) 0%, transparent 65%);\n      pointer-events: none;\n    }\n    #hero::before {\n      content: '';\n      position: absolute;\n      bottom: -80px; left: -80px;\n      width: 400px; height: 400px;\n      background: radial-gradient(circle, rgba(240,180,41,0.06) 0%, transparent 65%);\n      pointer-events: none;\n    }\n    .hero-inner {\n      display: grid;\n      grid-template-columns: 1fr 400px;\n      gap: 64px;\n      align-items: center;\n      position: relative;\n      z-index: 1;\n    }\n    .hero-eyebrow {\n      font-size: 13px;\n      font-weight: 600;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      color: var(--gold);\n      margin-bottom: 20px;\n      display: flex;\n      align-items: center;\n      gap: 10px;\n    }\n    .hero-eyebrow::before {\n      content: '';\n      display: inline-block;\n      width: 28px; height: 2px;\n      background: var(--gold);\n    }\n    .hero-h1 {\n      font-size: clamp(40px, 5vw, 66px);\n      font-weight: 900;\n      color: var(--white);\n      line-height: 1.08;\n      margin-bottom: 24px;\n      letter-spacing: -0.5px;\n    }\n    .hero-h1 em { color: var(--azure); font-style: normal; }\n    .hero-sub {\n      font-size: 18px;\n      color: var(--muted);\n      max-width: 540px;\n      margin-bottom: 40px;\n      line-height: 1.75;\n    }\n    .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }\n\n    /* Right panel */\n    .hero-panel {\n      background: var(--navy2);\n      border: 1px solid rgba(22,103,232,0.25);\n      border-radius: 16px;\n      padding: 40px 36px;\n      position: relative;\n    }\n    .hero-panel-label {\n      font-size: 11px;\n      font-weight: 700;\n      letter-spacing: 2.5px;\n      text-transform: uppercase;\n      color: var(--azure);\n      margin-bottom: 8px;\n    }\n    .hero-panel h3 {\n      font-size: 22px;\n      font-weight: 800;\n      color: #fff;\n      margin-bottom: 24px;\n      line-height: 1.3;\n    }\n    .hero-stat-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 12px;\n      margin-bottom: 28px;\n    }\n    .hero-stat {\n      background: rgba(22,103,232,0.10);\n      border: 1px solid rgba(22,103,232,0.18);\n      border-radius: 8px;\n      padding: 16px 14px;\n      text-align: center;\n    }\n    .hero-stat-num {\n      font-size: 32px;\n      font-weight: 900;\n      color: var(--azure);\n      display: block;\n      line-height: 1;\n      margin-bottom: 4px;\n    }\n    .hero-stat-lbl {\n      font-size: 11px;\n      font-weight: 500;\n      color: var(--muted);\n    }\n    .hero-panel .btn-primary { width: 100%; text-align: center; }\n\n    /* ─── TICKER ─── */\n    #ticker {\n      background: var(--charcoal);\n      border-top: 1px solid rgba(255,255,255,0.06);\n      border-bottom: 1px solid rgba(255,255,255,0.06);\n      padding: 18px 0;\n      overflow: hidden;\n    }\n    .ticker-track {\n      display: flex;\n      gap: 0;\n      animation: ticker-scroll 30s linear infinite;\n      white-space: nowrap;\n    }\n    @keyframes ticker-scroll {\n      0% { transform: translateX(0); }\n      100% { transform: translateX(-50%); }\n    }\n    .ticker-item {\n      display: inline-flex;\n      align-items: center;\n      gap: 10px;\n      padding: 0 40px;\n      font-size: 14px;\n      font-weight: 500;\n      color: var(--muted);\n    }\n    .ticker-star { color: var(--gold); font-size: 14px; letter-spacing: 1px; }\n\n    /* ─── LOGOS ─── */\n    #logos {\n      background: var(--navy);\n      padding: 40px 0;\n    }\n    .logo-inner {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      gap: 48px;\n      flex-wrap: wrap;\n    }\n    .logo-label {\n      font-size: 11px;\n      font-weight: 600;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      color: rgba(255,255,255,0.25);\n    }\n    .logo-pill {\n      font-size: 12px;\n      font-weight: 700;\n      letter-spacing: 1.5px;\n      text-transform: uppercase;\n      color: rgba(255,255,255,0.35);\n      padding: 8px 20px;\n      border: 1px solid rgba(255,255,255,0.10);\n      border-radius: 40px;\n    }\n\n    /* ─── STATS ─── */\n    #stats {\n      background: var(--navy);\n      padding: 80px 0;\n    }\n    .stats-grid {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr);\n      gap: 20px;\n    }\n    .stat-card {\n      background: var(--navy2);\n      border: 1px solid rgba(255,255,255,0.07);\n      border-radius: 12px;\n      padding: 32px 24px;\n      text-align: center;\n      transition: border-color .2s;\n    }\n    .stat-card:hover { border-color: rgba(22,103,232,0.4); }\n    .stat-num {\n      font-size: 56px;\n      font-weight: 900;\n      color: var(--azure);\n      line-height: 1;\n      margin-bottom: 8px;\n    }\n    .stat-label {\n      font-size: 15px;\n      font-weight: 700;\n      color: #fff;\n      margin-bottom: 6px;\n    }\n    .stat-context { font-size: 12px; color: rgba(255,255,255,0.4); }\n\n    /* ─── ABOUT ─── */\n    #about {\n      background: var(--charcoal);\n      padding: 90px 0;\n    }\n    .about-inner {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 72px;\n      align-items: center;\n    }\n    .about-left h2 {\n      font-size: clamp(30px, 3.5vw, 44px);\n      font-weight: 800;\n      color: #fff;\n      line-height: 1.18;\n      margin-bottom: 24px;\n    }\n    .about-left h2 em { color: var(--azure); font-style: normal; }\n    .about-left p {\n      font-size: 17px;\n      color: var(--muted);\n      line-height: 1.78;\n      margin-bottom: 20px;\n    }\n    .about-creds {\n      margin: 28px 0;\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n    .about-cred {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n      font-size: 15px;\n      font-weight: 600;\n      color: rgba(255,255,255,0.85);\n    }\n    .cred-icon {\n      width: 28px; height: 28px;\n      background: rgba(22,103,232,0.15);\n      border-radius: 50%;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 13px;\n      color: var(--gold);\n      flex-shrink: 0;\n    }\n    .about-photo {\n      background: var(--navy2);\n      border: 1px solid rgba(22,103,232,0.2);\n      border-radius: 20px;\n      aspect-ratio: 4/5;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-size: 14px;\n      color: rgba(255,255,255,0.25);\n      text-align: center;\n      padding: 24px;\n    }\n\n    /* ─── SERVICES ─── */\n    #services {\n      background: var(--navy);\n      padding: 90px 0;\n    }\n    .services-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 24px;\n    }\n    .scard {\n      background: var(--navy2);\n      border: 1px solid rgba(255,255,255,0.07);\n      border-radius: 14px;\n      padding: 36px 30px;\n      transition: border-color .2s, transform .2s;\n      position: relative;\n      overflow: hidden;\n    }\n    .scard:hover { border-color: rgba(22,103,232,0.4); transform: translateY(-4px); }\n    .scard.featured {\n      border-color: rgba(22,103,232,0.5);\n      background: linear-gradient(145deg, #0d0d30 0%, #0a0a28 100%);\n    }\n    .scard.featured::before {\n      content: 'FLAGSHIP';\n      position: absolute;\n      top: 16px; right: -30px;\n      background: var(--azure);\n      color: #fff;\n      font-size: 9px;\n      font-weight: 800;\n      letter-spacing: 1.5px;\n      padding: 5px 44px;\n      transform: rotate(45deg);\n    }\n    .scard-icon {\n      font-size: 28px;\n      margin-bottom: 18px;\n      display: block;\n    }\n    .scard-tag {\n      font-size: 11px;\n      font-weight: 700;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      color: var(--azure);\n      margin-bottom: 10px;\n      display: block;\n    }\n    .scard h3 {\n      font-size: 20px;\n      font-weight: 800;\n      color: #fff;\n      margin-bottom: 12px;\n      line-height: 1.3;\n    }\n    .scard p {\n      font-size: 14px;\n      color: var(--muted);\n      line-height: 1.7;\n      margin-bottom: 18px;\n    }\n    .scard-price {\n      font-size: 26px;\n      font-weight: 900;\n      color: var(--azure);\n      margin-bottom: 18px;\n    }\n    .scard-price sub { font-size: 14px; font-weight: 600; color: var(--muted); }\n    .scard-bullets {\n      list-style: none;\n      margin-bottom: 22px;\n    }\n    .scard-bullets li {\n      font-size: 13px;\n      color: rgba(255,255,255,0.70);\n      padding: 5px 0 5px 20px;\n      position: relative;\n    }\n    .scard-bullets li::before {\n      content: '✓';\n      position: absolute; left: 0;\n      color: var(--azure);\n      font-weight: 700;\n    }\n    .scard-link {\n      font-size: 14px;\n      font-weight: 700;\n      color: var(--azure);\n      text-decoration: none;\n      letter-spacing: 0.3px;\n    }\n    .scard-link:hover { text-decoration: underline; }\n    .scard .btn-primary { font-size: 14px; padding: 12px 22px; }\n\n    /* ─── NLCA FEATURE ─── */\n    #nlca {\n      background: var(--charcoal);\n      padding: 90px 0;\n    }\n    .nlca-inner {\n      background: var(--navy2);\n      border: 1px solid rgba(22,103,232,0.30);\n      border-radius: 20px;\n      padding: 60px 56px;\n      display: grid;\n      grid-template-columns: 1fr 360px;\n      gap: 60px;\n      align-items: center;\n    }\n    .nlca-left h2 {\n      font-size: clamp(28px, 3vw, 40px);\n      font-weight: 900;\n      color: #fff;\n      line-height: 1.18;\n      margin-bottom: 18px;\n    }\n    .nlca-left h2 em { color: var(--azure); font-style: normal; }\n    .nlca-left p {\n      font-size: 16px;\n      color: var(--muted);\n      line-height: 1.75;\n      margin-bottom: 28px;\n    }\n    .nlca-modules {\n      display: flex;\n      flex-direction: column;\n      gap: 10px;\n      margin-bottom: 32px;\n    }\n    .nlca-module {\n      display: flex;\n      align-items: flex-start;\n      gap: 14px;\n      font-size: 14px;\n      color: rgba(255,255,255,0.80);\n    }\n    .module-num {\n      font-size: 12px;\n      font-weight: 800;\n      color: var(--azure);\n      background: rgba(22,103,232,0.12);\n      border-radius: 4px;\n      padding: 3px 8px;\n      flex-shrink: 0;\n      margin-top: 1px;\n    }\n    .nlca-pricing-card {\n      background: var(--navy);\n      border: 1px solid rgba(22,103,232,0.25);\n      border-radius: 14px;\n      padding: 36px 32px;\n      text-align: center;\n    }\n    .nlca-pricing-card h4 {\n      font-size: 16px;\n      font-weight: 700;\n      color: rgba(255,255,255,0.7);\n      margin-bottom: 24px;\n    }\n    .nlca-price-row {\n      display: flex;\n      flex-direction: column;\n      gap: 16px;\n      margin-bottom: 28px;\n    }\n    .nlca-price {\n      padding: 20px;\n      border-radius: 10px;\n      border: 1px solid rgba(255,255,255,0.08);\n    }\n    .nlca-price.recommended {\n      border-color: rgba(22,103,232,0.5);\n      background: rgba(22,103,232,0.08);\n      position: relative;\n    }\n    .nlca-price.recommended::before {\n      content: 'BEST VALUE';\n      position: absolute;\n      top: -10px; left: 50%;\n      transform: translateX(-50%);\n      background: var(--azure);\n      color: #fff;\n      font-size: 9px;\n      font-weight: 800;\n      letter-spacing: 1.5px;\n      padding: 3px 12px;\n      border-radius: 20px;\n    }\n    .nlca-price-amount {\n      font-size: 36px;\n      font-weight: 900;\n      color: var(--white);\n      line-height: 1;\n      margin-bottom: 4px;\n    }\n    .nlca-price-period {\n      font-size: 13px;\n      color: var(--muted);\n    }\n    .nlca-price-save {\n      font-size: 12px;\n      color: var(--gold);\n      font-weight: 700;\n      margin-top: 4px;\n    }\n    .nlca-pricing-card .btn-primary { width: 100%; text-align: center; margin-bottom: 12px; }\n    .nlca-pricing-card .btn-ghost { width: 100%; text-align: center; font-size: 14px; padding: 13px 20px; }\n\n    /* ─── TRAINING METHODS ─── */\n    #training {\n      background: var(--navy);\n      padding: 90px 0;\n    }\n    .training-grid {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr);\n      gap: 20px;\n    }\n    .tcard {\n      background: var(--navy2);\n      border: 1px solid rgba(255,255,255,0.06);\n      border-radius: 12px;\n      padding: 32px 24px;\n      text-align: center;\n      transition: border-color .2s;\n    }\n    .tcard:hover { border-color: rgba(22,103,232,0.3); }\n    .tcard-icon { font-size: 32px; margin-bottom: 16px; display: block; }\n    .tcard h3 { font-size: 17px; font-weight: 800; color: #fff; margin-bottom: 10px; }\n    .tcard p { font-size: 13px; color: var(--muted); line-height: 1.65; }\n\n    /* ─── MODULES ─── */\n    #modules {\n      background: var(--charcoal);\n      padding: 90px 0;\n    }\n    .modules-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 20px;\n    }\n    .mcard {\n      background: var(--navy2);\n      border: 1px solid rgba(255,255,255,0.06);\n      border-left: 3px solid var(--azure);\n      border-radius: 12px;\n      padding: 30px 26px;\n      transition: transform .2s;\n    }\n    .mcard:hover { transform: translateY(-3px); }\n    .mcard-num {\n      font-size: 42px;\n      font-weight: 900;\n      color: rgba(22,103,232,0.20);\n      line-height: 1;\n      margin-bottom: 4px;\n    }\n    .mcard h3 { font-size: 18px; font-weight: 800; color: #fff; margin-bottom: 10px; }\n    .mcard p { font-size: 13px; color: var(--muted); line-height: 1.65; }\n    .modules-mid-cta { text-align: center; grid-column: 1 / -1; padding: 8px 0; }\n\n    /* ─── PAIN ─── */\n    #pain {\n      background: var(--navy);\n      padding: 90px 0;\n    }\n    .pain-grid {\n      display: grid;\n      grid-template-columns: repeat(5, 1fr);\n      gap: 16px;\n      margin-bottom: 52px;\n    }\n    .pain-card {\n      background: var(--navy2);\n      border: 1px solid rgba(255,255,255,0.06);\n      border-radius: 12px;\n      padding: 28px 18px;\n      text-align: center;\n      transition: border-color .2s;\n    }\n    .pain-card:hover { border-color: rgba(22,103,232,0.35); }\n    .pain-icon { font-size: 26px; margin-bottom: 10px; display: block; }\n    .pain-card p { font-size: 14px; font-weight: 600; color: #fff; line-height: 1.4; }\n    .pain-bridge {\n      max-width: 700px;\n      margin: 0 auto;\n      text-align: center;\n    }\n    .pain-quote {\n      font-size: 19px;\n      color: var(--muted);\n      line-height: 1.75;\n      font-style: italic;\n      margin-bottom: 10px;\n    }\n    .pain-quote strong { color: #fff; font-style: normal; }\n    .pain-attr { font-size: 13px; font-weight: 700; color: var(--azure); margin-bottom: 32px; display: block; }\n\n    /* ─── TESTIMONIALS ─── */\n    #testimonials {\n      background: var(--charcoal);\n      padding: 90px 0;\n    }\n    .testi-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 20px;\n    }\n    .tc {\n      background: var(--navy2);\n      border: 1px solid rgba(255,255,255,0.06);\n      border-radius: 14px;\n      padding: 32px 28px;\n    }\n    .tc-stars { color: var(--gold); font-size: 15px; letter-spacing: 2px; margin-bottom: 14px; }\n    .tc-quote { font-size: 14px; color: var(--muted); line-height: 1.72; font-style: italic; margin-bottom: 22px; }\n    .tc-author { display: flex; align-items: center; gap: 12px; }\n    .tc-avatar {\n      width: 42px; height: 42px;\n      border-radius: 50%;\n      background: rgba(22,103,232,0.15);\n      border: 1px solid rgba(22,103,232,0.3);\n      display: flex; align-items: center; justify-content: center;\n      font-size: 15px; font-weight: 800; color: var(--azure);\n      flex-shrink: 0;\n    }\n    .tc-name { font-size: 14px; font-weight: 700; color: #fff; }\n    .tc-role { font-size: 12px; color: rgba(255,255,255,0.4); }\n\n    .stat-banner {\n      background: var(--azure);\n      border-radius: 14px;\n      padding: 44px 48px;\n      text-align: center;\n      margin-top: 36px;\n    }\n    .stat-banner-num {\n      font-size: 76px;\n      font-weight: 900;\n      color: #fff;\n      line-height: 1;\n    }\n    .stat-banner-label {\n      font-size: 18px;\n      color: rgba(255,255,255,0.85);\n      margin-top: 8px;\n    }\n\n    /* ─── OPT-IN ─── */\n    #optin {\n      background: var(--navy);\n      padding: 90px 0;\n    }\n    .optin-wrap {\n      max-width: 680px;\n      margin: 0 auto;\n      background: var(--navy2);\n      border: 1px solid rgba(22,103,232,0.3);\n      border-radius: 20px;\n      padding: 56px 52px;\n      text-align: center;\n    }\n    .optin-wrap h2 {\n      font-size: clamp(24px, 3vw, 36px);\n      font-weight: 900;\n      color: #fff;\n      line-height: 1.2;\n      margin-bottom: 14px;\n    }\n    .optin-wrap > p {\n      font-size: 16px;\n      color: var(--muted);\n      line-height: 1.7;\n      margin-bottom: 36px;\n    }\n    .optin-form {\n      display: flex;\n      flex-direction: column;\n      gap: 16px;\n      text-align: left;\n    }\n    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\n    .form-group { display: flex; flex-direction: column; gap: 7px; }\n    .form-group label {\n      font-size: 13px;\n      font-weight: 700;\n      color: rgba(255,255,255,0.70);\n      letter-spacing: 0.3px;\n    }\n    .form-group input,\n    .form-group select {\n      padding: 14px 18px;\n      border: 1.5px solid rgba(255,255,255,0.10);\n      border-radius: 6px;\n      font-family: 'Manrope', sans-serif;\n      font-size: 15px;\n      color: #fff;\n      background: rgba(255,255,255,0.05);\n      outline: none;\n      transition: border-color .2s;\n      -webkit-appearance: none;\n    }\n    .form-group input:focus,\n    .form-group select:focus { border-color: var(--azure); }\n    .form-group input::placeholder { color: rgba(255,255,255,0.25); }\n    .form-group select option { background: var(--navy2); color: #fff; }\n    .optin-form .btn-primary { width: 100%; text-align: center; font-size: 17px; padding: 20px; margin-top: 4px; }\n    .form-privacy { font-size: 12px; color: rgba(255,255,255,0.30); text-align: center; margin-top: 10px; }\n\n    /* ─── PRICING ─── */\n    #pricing {\n      background: var(--charcoal);\n      padding: 90px 0;\n    }\n    .pricing-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 24px;\n      max-width: 820px;\n      margin: 0 auto;\n    }\n    .pc {\n      background: var(--navy2);\n      border: 1px solid rgba(255,255,255,0.07);\n      border-radius: 16px;\n      padding: 44px 40px;\n      text-align: center;\n      transition: border-color .2s;\n    }\n    .pc.active {\n      border-color: rgba(22,103,232,0.5);\n      position: relative;\n    }\n    .pc.active::before {\n      content: 'MOST POPULAR';\n      position: absolute;\n      top: -12px; left: 50%;\n      transform: translateX(-50%);\n      background: var(--azure);\n      color: #fff;\n      font-size: 10px;\n      font-weight: 800;\n      letter-spacing: 1.5px;\n      padding: 4px 16px;\n      border-radius: 20px;\n    }\n    .pc-name { font-size: 18px; font-weight: 800; color: #fff; margin-bottom: 6px; }\n    .pc-sub { font-size: 13px; color: var(--muted); margin-bottom: 24px; }\n    .pc-price {\n      font-size: 58px;\n      font-weight: 900;\n      color: var(--white);\n      line-height: 1;\n      margin-bottom: 6px;\n    }\n    .pc-price span { font-size: 26px; vertical-align: top; line-height: 2.1; }\n    .pc-period { font-size: 14px; color: var(--muted); margin-bottom: 6px; }\n    .pc-save { font-size: 13px; color: var(--gold); font-weight: 700; margin-bottom: 28px; min-height: 20px; }\n    .pc-includes {\n      list-style: none;\n      text-align: left;\n      background: rgba(255,255,255,0.04);\n      border-radius: 8px;\n      padding: 20px 22px;\n      margin-bottom: 28px;\n    }\n    .pc-includes li {\n      font-size: 14px;\n      color: rgba(255,255,255,0.75);\n      padding: 6px 0 6px 22px;\n      position: relative;\n    }\n    .pc-includes li::before {\n      content: '✓';\n      position: absolute; left: 0;\n      color: var(--azure);\n      font-weight: 700;\n    }\n    .pc .btn-primary { width: 100%; font-size: 16px; }\n    .pc-guarantee {\n      font-size: 12px;\n      color: rgba(255,255,255,0.30);\n      margin-top: 16px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      gap: 6px;\n    }\n\n    /* ─── FINAL CTA ─── */\n    #final-cta {\n      background: var(--azure);\n      padding: 90px 0;\n      text-align: center;\n      position: relative;\n      overflow: hidden;\n    }\n    #final-cta::before {\n      content: '';\n      position: absolute;\n      top: 50%; left: 50%;\n      transform: translate(-50%, -50%);\n      width: 700px; height: 700px;\n      background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 65%);\n      pointer-events: none;\n    }\n    #final-cta h2 {\n      font-size: clamp(30px, 4vw, 50px);\n      font-weight: 900;\n      color: #fff;\n      line-height: 1.15;\n      margin-bottom: 20px;\n      position: relative;\n    }\n    #final-cta p {\n      font-size: 18px;\n      color: rgba(255,255,255,0.80);\n      max-width: 540px;\n      margin: 0 auto 40px;\n      line-height: 1.7;\n      position: relative;\n    }\n    .final-ctas {\n      display: flex;\n      gap: 16px;\n      justify-content: center;\n      flex-wrap: wrap;\n      position: relative;\n    }\n    #final-cta .btn-primary {\n      background: #fff;\n      color: var(--azure);\n    }\n    #final-cta .btn-primary:hover { background: rgba(255,255,255,0.92); }\n    #final-cta .btn-ghost {\n      border-color: rgba(255,255,255,0.7);\n      color: #fff;\n    }\n\n    /* ─── FOOTER ─── */\n    footer {\n      background: var(--charcoal);\n      border-top: 1px solid rgba(255,255,255,0.06);\n      padding: 36px 0;\n      text-align: center;\n    }\n    footer p { font-size: 13px; color: rgba(255,255,255,0.25); }\n    footer a { color: rgba(255,255,255,0.40); text-decoration: none; }\n    footer a:hover { color: var(--azure); }\n\n    /* ─── HAMBURGER ─── */\n    .hamburger {\n      display: none;\n      flex-direction: column;\n      gap: 5px;\n      cursor: pointer;\n      background: none;\n      border: none;\n      padding: 4px;\n    }\n    .hamburger span {\n      display: block;\n      width: 24px;\n      height: 2px;\n      background: #fff;\n      border-radius: 2px;\n      transition: all .3s;\n    }\n    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }\n    .hamburger.open span:nth-child(2) { opacity: 0; }\n    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }\n    .mobile-menu {\n      display: none;\n      position: fixed;\n      inset: 0;\n      background: #1D2027;\n      z-index: 99;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      gap: 32px;\n    }\n    .mobile-menu.open { display: flex; }\n    .mobile-menu a {\n      font-size: 22px;\n      font-weight: 700;\n      color: #fff;\n      text-decoration: none;\n      letter-spacing: 1px;\n    }\n    .mobile-menu a:hover { color: var(--azure); }\n\n    /* ─── RESPONSIVE: TABLET ─── */\n    @media (max-width: 960px) {\n      .hero-inner { grid-template-columns: 1fr; }\n      .hero-panel { display: none; }\n      .stats-grid { grid-template-columns: repeat(2, 1fr); }\n      .about-inner { grid-template-columns: 1fr; }\n      .about-photo { display: none; }\n      .services-grid { grid-template-columns: 1fr 1fr; }\n      .training-grid { grid-template-columns: 1fr 1fr; }\n      .modules-grid { grid-template-columns: 1fr 1fr; }\n      .pain-grid { grid-template-columns: 1fr 1fr; }\n      .testi-grid { grid-template-columns: 1fr; }\n      .nlca-inner { grid-template-columns: 1fr; padding: 40px 32px; }\n    }\n    /* ─── PLAN SELECTOR ─── */\n    .plan-option {\n      cursor: pointer;\n      position: relative;\n      transition: border-color .2s, background .2s, transform .15s;\n      border: 2px solid rgba(255,255,255,0.08) !important;\n      user-select: none;\n    }\n    .plan-option:hover { border-color: rgba(22,103,232,0.5) !important; transform: translateY(-2px); }\n    .plan-option.selected {\n      border-color: var(--azure) !important;\n      background: rgba(22,103,232,0.12) !important;\n    }\n    .plan-check {\n      position: absolute;\n      top: 10px; right: 12px;\n      width: 20px; height: 20px;\n      border-radius: 50%;\n      background: rgba(255,255,255,0.08);\n      border: 2px solid rgba(255,255,255,0.2);\n      display: flex; align-items: center; justify-content: center;\n      font-size: 10px;\n      color: transparent;\n      transition: all .2s;\n    }\n    .plan-option.selected .plan-check {\n      background: var(--azure);\n      border-color: var(--azure);\n      color: #fff;\n    }\n\n    /* ─── MODAL ─── */\n    .modal-overlay {\n      display: none;\n      position: fixed;\n      inset: 0;\n      background: rgba(4,4,23,0.88);\n      backdrop-filter: blur(8px);\n      z-index: 1000;\n      align-items: center;\n      justify-content: center;\n      padding: 24px;\n    }\n    .modal-overlay.open { display: flex; }\n    .modal-box {\n      background: var(--navy2);\n      border: 1px solid rgba(22,103,232,0.35);\n      border-radius: 20px;\n      padding: 48px 44px;\n      max-width: 520px;\n      width: 100%;\n      position: relative;\n      animation: modalIn .25s ease;\n    }\n    @keyframes modalIn {\n      from { opacity: 0; transform: translateY(20px) scale(0.97); }\n      to   { opacity: 1; transform: translateY(0) scale(1); }\n    }\n    .modal-close {\n      position: absolute;\n      top: 16px; right: 20px;\n      background: none;\n      border: none;\n      color: rgba(255,255,255,0.4);\n      font-size: 22px;\n      cursor: pointer;\n      line-height: 1;\n      transition: color .2s;\n    }\n    .modal-close:hover { color: #fff; }\n    .modal-tag {\n      font-size: 11px;\n      font-weight: 700;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      color: var(--azure);\n      margin-bottom: 12px;\n    }\n    .modal-box h3 {\n      font-size: 26px;\n      font-weight: 900;\n      color: #fff;\n      margin-bottom: 8px;\n      line-height: 1.2;\n    }\n    .modal-price-display {\n      font-size: 44px;\n      font-weight: 900;\n      color: var(--azure);\n      line-height: 1;\n      margin: 18px 0 4px;\n    }\n    .modal-price-sub { font-size: 14px; color: var(--muted); margin-bottom: 6px; }\n    .modal-save { font-size: 13px; color: var(--gold); font-weight: 700; margin-bottom: 24px; min-height: 18px; }\n    .modal-includes {\n      list-style: none;\n      background: rgba(255,255,255,0.04);\n      border-radius: 10px;\n      padding: 18px 20px;\n      margin-bottom: 28px;\n    }\n    .modal-includes li {\n      font-size: 14px;\n      color: rgba(255,255,255,0.78);\n      padding: 5px 0 5px 22px;\n      position: relative;\n    }\n    .modal-includes li::before {\n      content: '✓';\n      position: absolute; left: 0;\n      color: var(--azure);\n      font-weight: 700;\n    }\n    .modal-box .btn-primary { width: 100%; text-align: center; font-size: 17px; padding: 18px; }\n    .modal-guarantee { font-size: 12px; color: rgba(255,255,255,0.3); text-align: center; margin-top: 12px; }\n\n    /* Discovery modal form */\n    .modal-form { display: flex; flex-direction: column; gap: 14px; margin-top: 24px; }\n    .modal-form input, .modal-form select {\n      padding: 13px 16px;\n      border: 1.5px solid rgba(255,255,255,0.10);\n      border-radius: 6px;\n      font-family: 'Manrope', sans-serif;\n      font-size: 15px;\n      color: #fff;\n      background: rgba(255,255,255,0.05);\n      outline: none;\n      transition: border-color .2s;\n      -webkit-appearance: none;\n    }\n    .modal-form input:focus, .modal-form select:focus { border-color: var(--azure); }\n    .modal-form input::placeholder { color: rgba(255,255,255,0.25); }\n    .modal-form select option { background: var(--navy2); }\n\n    /* ─── RESPONSIVE: MOBILE ─── */\n    @media (max-width: 620px) {\n      /* Nav */\n      .nav-links { display: none; }\n      .nav-cta { display: none; }\n      .hamburger { display: flex; }\n\n      /* Hero */\n      #hero { padding: 60px 0 50px; }\n      .hero-h1 { font-size: 36px; }\n      .hero-sub { font-size: 16px; }\n      .hero-ctas { flex-direction: column; gap: 12px; }\n      .hero-ctas a { width: 100%; text-align: center; }\n\n      /* Sections */\n      section, #ticker, #logos, footer { padding-left: 0 !important; padding-right: 0 !important; }\n      #stats, #about, #services, #nlca, #training, #modules, #pain, #testimonials, #optin, #pricing, #final-cta { padding: 56px 0; }\n\n      /* Grids */\n      .services-grid { grid-template-columns: 1fr; }\n      .training-grid { grid-template-columns: 1fr; }\n      .modules-grid { grid-template-columns: 1fr; }\n      .pain-grid { grid-template-columns: 1fr 1fr; }\n      .stats-grid { grid-template-columns: 1fr 1fr; }\n      .pricing-grid { grid-template-columns: 1fr; }\n      .testi-grid { grid-template-columns: 1fr; }\n\n      /* NLCA */\n      .nlca-inner { padding: 28px 20px; gap: 32px; }\n      .nlca-pricing-card { padding: 24px 20px; }\n      .nlca-price-row { gap: 10px; }\n      .nlca-price-amount { font-size: 28px; }\n\n      /* Forms */\n      .form-row { grid-template-columns: 1fr; }\n      .optin-wrap { padding: 28px 20px; }\n\n      /* Pricing */\n      .pc { padding: 32px 24px; }\n      .pc-price { font-size: 44px; }\n\n      /* Modals */\n      .modal-box { padding: 32px 20px; }\n      .modal-price-display { font-size: 36px; }\n\n      /* Final CTA */\n      #final-cta { padding: 60px 0; }\n      .final-ctas { flex-direction: column; align-items: center; }\n      .final-ctas a { width: 100%; max-width: 320px; text-align: center; }\n\n      /* Stat banner */\n      .stat-banner { padding: 32px 24px; }\n      .stat-banner-num { font-size: 56px; }\n\n      /* Section headers */\n      .section-header { margin-bottom: 36px; }\n\n      /* Pain bridge */\n      .pain-quote { font-size: 16px; }\n    }\n  \u003C/style>\n\u003C/head>\n\u003Cbody>\n\u003Cdiv id=\"page-root\">\n\n  \u003C!-- NAV -->\n  \u003Cnav>\n    \u003Cdiv class=\"container\">\n      \u003C!-- Logo -->\n      \u003Ca href=\"#\" class=\"fase-logo\">\n        \u003Cimg src=\"https://assets.cdn.filesafe.space/vdi6H8skwmbrWBAz1f6X/media/69cf03afbbe1310051fedf42.jpg\" alt=\"Full Arch Sales Experts\" style=\"height:52px;width:auto;display:block;\" />\n      \u003C/a>\n      \u003Cul class=\"nav-links\">\n        \u003Cli>\u003Ca href=\"#services\">Services\u003C/a>\u003C/li>\n        \u003Cli>\u003Ca href=\"#nlca\">NLCA\u003C/a>\u003C/li>\n        \u003Cli>\u003Ca href=\"#modules\">Framework\u003C/a>\u003C/li>\n        \u003Cli>\u003Ca href=\"#pricing\">Pricing\u003C/a>\u003C/li>\n      \u003C/ul>\n      \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary nav-cta\">GET THE FRAMEWORK\u003C/a>\n      \u003Cbutton class=\"hamburger\" id=\"hamburger\" onclick=\"toggleMenu()\" aria-label=\"Menu\">\n        \u003Cspan>\u003C/span>\u003Cspan>\u003C/span>\u003Cspan>\u003C/span>\n      \u003C/button>\n    \u003C/div>\n  \u003C/nav>\n\n  \u003C!-- Mobile menu -->\n  \u003Cdiv class=\"mobile-menu\" id=\"mobileMenu\">\n    \u003Ca href=\"#services\" onclick=\"toggleMenu()\">Services\u003C/a>\n    \u003Ca href=\"#nlca\" onclick=\"toggleMenu()\">NLCA\u003C/a>\n    \u003Ca href=\"#modules\" onclick=\"toggleMenu()\">Framework\u003C/a>\n    \u003Ca href=\"#pricing\" onclick=\"toggleMenu()\">Pricing\u003C/a>\n    \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\" onclick=\"toggleMenu()\" style=\"margin-top:8px;\">GET THE FRAMEWORK\u003C/a>\n  \u003C/div>\n\n  \u003C!-- HERO -->\n  \u003Csection id=\"hero\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"hero-inner\">\n        \u003Cdiv>\n          \u003Cp class=\"hero-eyebrow\">Stacy Farley · Full Arch Sales Experts\u003C/p>\n          \u003Ch1 class=\"hero-h1\">\n            Close \u003Cem>70%+\u003C/em> of Your\u003Cbr>Full-Arch Consults.\u003Cbr>Every Time.\n          \u003C/h1>\n          \u003Cp class=\"hero-sub\">\n            Stop leaving full-arch cases on the table. The exact sales system I used to build an $8M implant center — closing 40–50 arches per month — is now available for your practice.\n          \u003C/p>\n          \u003Cdiv class=\"hero-ctas\">\n            \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\">GET THE FRAMEWORK\u003C/a>\n            \u003Ca href=\"#nlca\" class=\"btn-ghost\">EXPLORE NLCA MEMBERSHIP\u003C/a>\n          \u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"hero-panel\">\n          \u003Cp class=\"hero-panel-label\">Proven by the Numbers\u003C/p>\n          \u003Ch3>What the Framework Delivers\u003C/h3>\n          \u003Cdiv class=\"hero-stat-grid\">\n            \u003Cdiv class=\"hero-stat\">\n              \u003Cspan class=\"hero-stat-num\">70%+\u003C/span>\n              \u003Cspan class=\"hero-stat-lbl\">Close Rate\u003C/span>\n            \u003C/div>\n            \u003Cdiv class=\"hero-stat\">\n              \u003Cspan class=\"hero-stat-num\">50+\u003C/span>\n              \u003Cspan class=\"hero-stat-lbl\">Arches/Month\u003C/span>\n            \u003C/div>\n            \u003Cdiv class=\"hero-stat\">\n              \u003Cspan class=\"hero-stat-num\">5%\u003C/span>\n              \u003Cspan class=\"hero-stat-lbl\">Mktg Spend\u003C/span>\n            \u003C/div>\n            \u003Cdiv class=\"hero-stat\">\n              \u003Cspan class=\"hero-stat-num\">20+\u003C/span>\n              \u003Cspan class=\"hero-stat-lbl\">Yrs in Sales\u003C/span>\n            \u003C/div>\n          \u003C/div>\n          \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\">GET INSTANT ACCESS\u003C/a>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- TICKER -->\n  \u003Cdiv id=\"ticker\">\n    \u003Cdiv class=\"ticker-track\">\n      \u003C!-- Set 1 -->\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"From interested to enrolled — every time.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"Stop leaving full-arch cases on the table.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"Master the psychology of a yes.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"The only membership built for full-arch sales.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"Next-level case acceptance — not a course. A transformation.\"\u003C/span>\n      \u003C!-- Set 2 (duplicate for seamless loop) -->\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"From interested to enrolled — every time.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"Stop leaving full-arch cases on the table.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"Master the psychology of a yes.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"The only membership built for full-arch sales.\"\u003C/span>\n      \u003Cspan class=\"ticker-item\">\u003Cspan class=\"ticker-star\">★★★★★\u003C/span> \"Next-level case acceptance — not a course. A transformation.\"\u003C/span>\n    \u003C/div>\n  \u003C/div>\n\n  \u003C!-- LOGOS -->\n  \u003Csection id=\"logos\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"logo-inner\">\n        \u003Cspan class=\"logo-label\">Trusted Training Partner\u003C/span>\n        \u003Cspan class=\"logo-pill\">BioHorizons\u003C/span>\n        \u003Cspan class=\"logo-pill\">Neodent\u003C/span>\n        \u003Cspan class=\"logo-pill\">SIN\u003C/span>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- STATS -->\n  \u003Csection id=\"stats\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"section-header\">\n        \u003Cspan class=\"section-label\">By the Numbers\u003C/span>\n        \u003Ch2>Results That Speak \u003Cem>for Themselves\u003C/em>\u003C/h2>\n        \u003Cp>Stacy didn't build theory. She built the largest single-owned implant center in the country — and every number below came from her own practice.\u003C/p>\n      \u003C/div>\n      \u003Cdiv class=\"stats-grid\">\n        \u003Cdiv class=\"stat-card\">\n          \u003Cdiv class=\"stat-num\">70%+\u003C/div>\n          \u003Cdiv class=\"stat-label\">Close Rate\u003C/div>\n          \u003Cdiv class=\"stat-context\">vs. 20–30% industry average\u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"stat-card\">\n          \u003Cdiv class=\"stat-num\">50+\u003C/div>\n          \u003Cdiv class=\"stat-label\">Arches Per Month\u003C/div>\n          \u003Cdiv class=\"stat-context\">Consistently, at Stacy's practice\u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"stat-card\">\n          \u003Cdiv class=\"stat-num\">5%\u003C/div>\n          \u003Cdiv class=\"stat-label\">Marketing Spend\u003C/div>\n          \u003Cdiv class=\"stat-context\">vs. 10–15% industry standard\u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"stat-card\">\n          \u003Cdiv class=\"stat-num\">20+\u003C/div>\n          \u003Cdiv class=\"stat-label\">Years in Sales\u003C/div>\n          \u003Cdiv class=\"stat-context\">Sales &amp; leadership experience\u003C/div>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- ABOUT -->\n  \u003Csection id=\"about\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"about-inner\">\n        \u003Cdiv class=\"about-left\">\n          \u003Cspan class=\"section-label\">Who Is Stacy Farley?\u003C/span>\n          \u003Ch2>I Built the Largest Single-Owned Implant Center in the Country. \u003Cem>Then I Taught Everyone Else How.\u003C/em>\u003C/h2>\n          \u003Cp>I'm Stacy Farley. I spent 20+ years in sales and leadership — including 8 years leading full arch sales at New Day Smile — building a practice that generates $8 million a year — closing 40 to 50 arches every month with a close rate above 70% and only 5% of revenue going to marketing.\u003C/p>\n          \u003Cp>I didn't do it with a massive ad budget or a lucky market. I did it with a repeatable, tested sales framework — one I now teach to practice owners, DSO ops leaders, and treatment coordinators who are tired of leaving arches on the table.\u003C/p>\n          \u003Cdiv class=\"about-creds\">\n            \u003Cdiv class=\"about-cred\">\u003Cdiv class=\"cred-icon\">★\u003C/div> $8M/year practice revenue at peak\u003C/div>\n            \u003Cdiv class=\"about-cred\">\u003Cdiv class=\"cred-icon\">★\u003C/div> 40–50 arches per month, consistently\u003C/div>\n            \u003Cdiv class=\"about-cred\">\u003Cdiv class=\"cred-icon\">★\u003C/div> 70%+ close rate vs. 20–30% industry average\u003C/div>\n            \u003Cdiv class=\"about-cred\">\u003Cdiv class=\"cred-icon\">★\u003C/div> 20+ years in sales &amp; leadership\u003C/div>\n            \u003Cdiv class=\"about-cred\">\u003Cdiv class=\"cred-icon\">★\u003C/div> Largest single-owned implant center in the country\u003C/div>\n          \u003C/div>\n          \u003Ca href=\"#services\" class=\"btn-primary\">SEE ALL SERVICES\u003C/a>\n        \u003C/div>\n        \u003Cdiv class=\"about-photo\">\n          📸 Stacy Farley\u003Cbr>Founder, Full Arch Sales Experts\u003Cbr>\n          \u003Csmall style=\"display:block;margin-top:8px;font-size:12px;\">[Replace with Stacy's headshot]\u003C/small>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- SERVICES -->\n  \u003Csection id=\"services\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"section-header\">\n        \u003Cspan class=\"section-label\">All Services\u003C/span>\n        \u003Ch2>Every Way to Work With \u003Cem>Stacy\u003C/em>\u003C/h2>\n        \u003Cp>From the flagship Masterclass to live membership coaching, classroom training, and AI-powered ongoing support — here's every path to closing more full-arch cases.\u003C/p>\n      \u003C/div>\n      \u003Cdiv class=\"services-grid\">\n\n        \u003C!-- Masterclass (featured) -->\n        \u003Cdiv class=\"scard featured\">\n          \u003Cspan class=\"scard-icon\">🎓\u003C/span>\n          \u003Cspan class=\"scard-tag\">Online · Self-Paced · Flagship\u003C/span>\n          \u003Ch3>Full-Arch Sales Masterclass\u003C/h3>\n          \u003Cp>32 straight-to-the-point video lessons covering every stage of the full-arch sales process — from the lead call to the close, on demand, for your whole team.\u003C/p>\n          \u003Cdiv class=\"scard-price\">$4,000 \u003Csub>one-time\u003C/sub>\u003C/div>\n          \u003Cul class=\"scard-bullets\">\n            \u003Cli>32 straight-to-the-point video lessons\u003C/li>\n            \u003Cli>Lead call, sales &amp; close scripts\u003C/li>\n            \u003Cli>Objection handling cheat sheets\u003C/li>\n            \u003C/ul>\n          \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\">GET INSTANT ACCESS\u003C/a>\n        \u003C/div>\n\n        \u003C!-- NLCA -->\n        \u003Cdiv class=\"scard\">\n          \u003Cspan class=\"scard-icon\">📈\u003C/span>\n          \u003Cspan class=\"scard-tag\">Live Membership · Monthly\u003C/span>\n          \u003Ch3>Next Level Case Acceptance (NLCA)\u003C/h3>\n          \u003Cp>The live monthly training program for dental teams who want to close more full arch cases — with a proven system, real coaching, and zero guesswork.\u003C/p>\n          \u003Cdiv class=\"scard-price\">$295\u003Csub>/mo\u003C/sub>\u003C/div>\n          \u003Cul class=\"scard-bullets\">\n            \u003Cli>Live training with Stacy\u003C/li>\n            \u003Cli>Real consult role-plays &amp; objection handling drills\u003C/li>\n            \u003Cli>Downloadable scripts, checklists &amp; templates\u003C/li>\n            \u003Cli>Hot seat Q&amp;A on your actual cases\u003C/li>\n            \u003Cli>Session recording + growing resource library\u003C/li>\n            \u003Cli>Private community for accountability &amp; questions\u003C/li>\n            \u003Cli>Annual option: $2,950/yr — save $590\u003C/li>\n          \u003C/ul>\n          \u003Ca href=\"#nlca\" class=\"btn-primary\">JOIN NLCA\u003C/a>\n        \u003C/div>\n\n        \u003C!-- Discovery Call -->\n        \u003Cdiv class=\"scard\">\n          \u003Cspan class=\"scard-icon\">📞\u003C/span>\n          \u003Cspan class=\"scard-tag\">High-Touch · Free\u003C/span>\n          \u003Ch3>Discovery Call\u003C/h3>\n          \u003Cp>Not sure which program is right for your practice? Book a discovery call with the FASE team for a personalized recommendation based on your current case volume and close rate.\u003C/p>\n          \u003Cul class=\"scard-bullets\">\n            \u003Cli>1-on-1 with a FASE specialist\u003C/li>\n            \u003Cli>Custom program recommendation\u003C/li>\n            \u003Cli>No pressure — just a clear diagnosis\u003C/li>\n          \u003C/ul>\n          \u003Ca href=\"https://fullarchsalesexperts.com/booking\" target=\"_blank\" class=\"scard-link\">BOOK A DISCOVERY CALL →\u003C/a>\n        \u003C/div>\n\n\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- NLCA DEEP DIVE -->\n  \u003Csection id=\"nlca\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"nlca-inner\">\n        \u003Cdiv class=\"nlca-left\">\n          \u003Cspan class=\"section-label\">Featured Program\u003C/span>\n          \u003Ch2>Next Level Case Acceptance — \u003Cem>The Membership Built for Full-Arch Sales\u003C/em>\u003C/h2>\n          \u003Cp>NLCA is the live monthly training program for dental teams who want to close more full arch cases — with a proven system, real coaching, and zero guesswork. Not pre-recorded. Not theory. The exact system that drove 40–50 arches a month.\u003C/p>\n          \u003Cdiv class=\"nlca-modules\">\n            \u003Cdiv class=\"nlca-module\">\u003Cspan class=\"module-num\">01\u003C/span> The 8-Step Consult Framework — the step-by-step structure that creates a predictable, high-converting consultation\u003C/div>\n            \u003Cdiv class=\"nlca-module\">\u003Cspan class=\"module-num\">02\u003C/span> Mastering Objections — real scripts for \"I need to think about it\" and \"it's too expensive\"\u003C/div>\n            \u003Cdiv class=\"nlca-module\">\u003Cspan class=\"module-num\">03\u003C/span> Building Value Before Price — make price irrelevant before you ever present it\u003C/div>\n            \u003Cdiv class=\"nlca-module\">\u003Cspan class=\"module-num\">04\u003C/span> Financing as a Close Tool — use financing strategically without cutting your margins\u003C/div>\n            \u003Cdiv class=\"nlca-module\">\u003Cspan class=\"module-num\">05\u003C/span> The 2-Phase Consult System — doctor presents clinically, TC closes emotionally\u003C/div>\n            \u003Cdiv class=\"nlca-module\">\u003Cspan class=\"module-num\">06\u003C/span> Follow-Up That Converts — the exact cadence and messaging that brings undecided patients back to yes\u003C/div>\n          \u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"nlca-pricing-card\">\n          \u003Ch4>Choose Your Plan\u003C/h4>\n          \u003Cdiv class=\"nlca-price-row\">\n            \u003C!-- Monthly option -->\n            \u003Cdiv class=\"nlca-price plan-option\" data-plan=\"monthly\" onclick=\"selectPlan('monthly')\">\n              \u003Cdiv class=\"plan-check\">✓\u003C/div>\n              \u003Cdiv class=\"nlca-price-amount\">$295\u003C/div>\n              \u003Cdiv class=\"nlca-price-period\">per month\u003C/div>\n              \u003Cdiv class=\"nlca-price-save\">&nbsp;\u003C/div>\n            \u003C/div>\n            \u003C!-- Annual option -->\n            \u003Cdiv class=\"nlca-price recommended plan-option selected\" data-plan=\"annual\" onclick=\"selectPlan('annual')\">\n              \u003Cdiv class=\"plan-check\">✓\u003C/div>\n              \u003Cdiv class=\"nlca-price-amount\">$2,950\u003C/div>\n              \u003Cdiv class=\"nlca-price-period\">per year\u003C/div>\n              \u003Cdiv class=\"nlca-price-save\">Save $590 vs monthly\u003C/div>\n            \u003C/div>\n          \u003C/div>\n          \u003Cbutton class=\"btn-primary\" onclick=\"openPlanModal()\" style=\"width:100%;text-align:center;cursor:pointer;\">JOIN NOW\u003C/button>\n          \u003Cbutton class=\"btn-ghost\" onclick=\"openDiscoveryModal()\" style=\"width:100%;text-align:center;cursor:pointer;margin-top:12px;\">BOOK A DISCOVERY CALL\u003C/button>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- TRAINING METHODS -->\n  \u003Csection id=\"training\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"section-header\">\n        \u003Cspan class=\"section-label\">How the Training Works\u003C/span>\n        \u003Ch2>Four Ways Stacy \u003Cem>Delivers the Framework\u003C/em>\u003C/h2>\n        \u003Cp>Every format is designed for dental operators — not passive learners. You implement while you learn.\u003C/p>\n      \u003C/div>\n      \u003Cdiv class=\"training-grid\">\n        \u003Cdiv class=\"tcard\">\n          \u003Cspan class=\"tcard-icon\">🏫\u003C/span>\n          \u003Ch3>Classroom Training\u003C/h3>\n          \u003Cp>Live, in-person sessions at your practice. Stacy's team drills your TCs and staff with real scenarios.\u003C/p>\n        \u003C/div>\n        \u003Cdiv class=\"tcard\">\n          \u003Cspan class=\"tcard-icon\">⚙️\u003C/span>\n          \u003Ch3>Full-Arch Operations Set-Up\u003C/h3>\n          \u003Cp>Everything your practice needs to launch and manage the non-clinical side of full-arch dentistry — from operations to consult flow.\u003C/p>\n        \u003C/div>\n        \u003Cdiv class=\"tcard\">\n          \u003Cspan class=\"tcard-icon\">💻\u003C/span>\n          \u003Ch3>Online Masterclass\u003C/h3>\n          \u003Cp>32 video lessons. The complete framework on demand — rewatch every script as many times as needed.\u003C/p>\n        \u003C/div>\n        \u003Cdiv class=\"tcard\">\n          \u003Cspan class=\"tcard-icon\">🤖\u003C/span>\n          \u003Ch3>Ongoing Sales Coaching\u003C/h3>\n          \u003Cp>We don't disappear after the first training. Get access to real-time coaching and CoachIQ — our AI-powered tool that tracks calls and shows your team how to improve, fast.\u003C/p>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- MODULES -->\n  \u003Csection id=\"modules\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"section-header\">\n        \u003Cspan class=\"section-label\">The Full-Arch Sales Framework\u003C/span>\n        \u003Ch2>4 Modules. \u003Cem>Every Stage of the Sale.\u003C/em>\u003C/h2>\n        \u003Cp>The Masterclass follows Stacy's exact sequence — from the first phone call to a signed treatment plan. Nothing skipped. Nothing generic.\u003C/p>\n      \u003C/div>\n      \u003Cdiv class=\"modules-grid\">\n        \u003Cdiv class=\"mcard\">\n          \u003Cdiv class=\"mcard-num\">01\u003C/div>\n          \u003Ch3>Lead Call\u003C/h3>\n          \u003Cp>The core principles behind taking lead calls effectively — from preparation to pricing discussions. Build a strong first impression that converts inquiries into booked consultations.\u003C/p>\n        \u003C/div>\n        \u003Cdiv class=\"mcard\">\n          \u003Cdiv class=\"mcard-num\">02\u003C/div>\n          \u003Ch3>Clinical Presentation\u003C/h3>\n          \u003Cp>How to present cases, maintain professionalism, and guide patients through informed decisions — so the clinical conversation builds trust and sets up the sales discussion naturally.\u003C/p>\n        \u003C/div>\n        \u003Cdiv class=\"mcard\">\n          \u003Cdiv class=\"mcard-num\">03\u003C/div>\n          \u003Ch3>The Foundation of Sales\u003C/h3>\n          \u003Cp>The mental and strategic foundation for full arch sales — shifting from transactional selling to value-driven persuasion so your entire team operates with the right mindset and confidence.\u003C/p>\n        \u003C/div>\n        \u003Cdiv class=\"modules-mid-cta\">\n          \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\">GET THE FRAMEWORK\u003C/a>\n        \u003C/div>\n        \u003Cdiv class=\"mcard\">\n          \u003Cdiv class=\"mcard-num\">04\u003C/div>\n          \u003Ch3>Sales Presentation\u003C/h3>\n          \u003Cp>The step-by-step process for presenting, handling objections, and closing with clarity — guiding patients from curiosity to commitment without pressure, confusion, or hesitation.\u003C/p>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- PAIN -->\n  \u003Csection id=\"pain\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"section-header\">\n        \u003Cspan class=\"section-label\">Sound Familiar?\u003C/span>\n        \u003Ch2>The Hidden Gaps \u003Cem>Costing You Cases\u003C/em> Every Month\u003C/h2>\n      \u003C/div>\n      \u003Cdiv class=\"pain-grid\">\n        \u003Cdiv class=\"pain-card\">\u003Cspan class=\"pain-icon\">📉\u003C/span>\u003Cp>Struggling to close cases?\u003C/p>\u003C/div>\n        \u003Cdiv class=\"pain-card\">\u003Cspan class=\"pain-icon\">🧑‍💼\u003C/span>\u003Cp>Staff not fully trained?\u003C/p>\u003C/div>\n        \u003Cdiv class=\"pain-card\">\u003Cspan class=\"pain-icon\">💰\u003C/span>\u003Cp>Patients hesitant about cost?\u003C/p>\u003C/div>\n        \u003Cdiv class=\"pain-card\">\u003Cspan class=\"pain-icon\">🏆\u003C/span>\u003Cp>Lost in the competition?\u003C/p>\u003C/div>\n        \u003Cdiv class=\"pain-card\">\u003Cspan class=\"pain-icon\">😤\u003C/span>\u003Cp>Frustrated and defeated?\u003C/p>\u003C/div>\n      \u003C/div>\n      \u003Cdiv class=\"pain-bridge\">\n        \u003Cp class=\"pain-quote\">\"I've felt every single one of these. That's exactly why I built the framework — because none of these are permanent. They're \u003Cstrong>process problems, not people problems.\u003C/strong> Fix the process and your numbers change.\"\u003C/p>\n        \u003Cspan class=\"pain-attr\">— Stacy Farley, Founder · Full Arch Sales Experts\u003C/span>\n        \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\">GET THE FRAMEWORK\u003C/a>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- TESTIMONIALS -->\n  \u003Csection id=\"testimonials\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"section-header\">\n        \u003Cspan class=\"section-label\">Real Results. Real Names.\u003C/span>\n        \u003Ch2>What Practice Owners \u003Cem>Are Saying\u003C/em>\u003C/h2>\n        \u003Cp>Video testimonials from doctors and DSO leaders who implemented the Full-Arch Sales Framework.\u003C/p>\n      \u003C/div>\n      \u003Cdiv class=\"testi-grid\">\n        \u003Cdiv class=\"tc\">\n          \u003Cdiv class=\"tc-stars\">★★★★★\u003C/div>\n          \u003Cp class=\"tc-quote\">\"We went from closing about 30% of full arch consults to over 60% in 90 days. Stacy's system is the real deal — no fluff, just what works in the real world.\"\u003C/p>\n          \u003Cdiv style=\"font-size:11px;font-weight:700;color:var(--azure);margin-bottom:14px;letter-spacing:1px;\">↑ CONVERSION RATE DOUBLED IN 90 DAYS\u003C/div>\n          \u003Cdiv class=\"tc-author\">\n            \u003Cdiv class=\"tc-avatar\">JR\u003C/div>\n            \u003Cdiv>\u003Cdiv class=\"tc-name\">Jessica R.\u003C/div>\u003Cdiv class=\"tc-role\">Treatment Coordinator · Texas\u003C/div>\u003C/div>\n          \u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"tc\">\n          \u003Cdiv class=\"tc-stars\">★★★★★\u003C/div>\n          \u003Cp class=\"tc-quote\">\"Within 6 months of working with Stacy, our implant center added nearly $1M in revenue. The consult process she teaches is unlike anything we had seen.\"\u003C/p>\n          \u003Cdiv style=\"font-size:11px;font-weight:700;color:var(--azure);margin-bottom:14px;letter-spacing:1px;\">↑ $989K REVENUE ADDED IN 6 MONTHS\u003C/div>\n          \u003Cdiv class=\"tc-author\">\n            \u003Cdiv class=\"tc-avatar\">DM\u003C/div>\n            \u003Cdiv>\u003Cdiv class=\"tc-name\">Dr. Meng\u003C/div>\u003Cdiv class=\"tc-role\">Practice Owner · Meng Dentistry\u003C/div>\u003C/div>\n          \u003C/div>\n        \u003C/div>\n        \u003Cdiv class=\"tc\">\n          \u003Cdiv class=\"tc-stars\">★★★★★\u003C/div>\n          \u003Cp class=\"tc-quote\">\"I finally stopped winging it. The 8-step framework gave me structure I could actually practice and repeat. My confidence and close rate both went through the roof.\"\u003C/p>\n          \u003Cdiv style=\"font-size:11px;font-weight:700;color:var(--azure);margin-bottom:14px;letter-spacing:1px;\">↑ 3 FULL ARCHES CLOSED IN FIRST WEEK\u003C/div>\n          \u003Cdiv class=\"tc-author\">\n            \u003Cdiv class=\"tc-avatar\">ML\u003C/div>\n            \u003Cdiv>\u003Cdiv class=\"tc-name\">Maria L.\u003C/div>\u003Cdiv class=\"tc-role\">New Patient Specialist · Florida\u003C/div>\u003C/div>\n          \u003C/div>\n        \u003C/div>\n      \u003C/div>\n      \u003Cdiv class=\"stat-banner\">\n        \u003Cdiv class=\"stat-banner-num\">654%\u003C/div>\n        \u003Cdiv class=\"stat-banner-label\">Year-over-year improvement in full-arch case volume — reported by a FASE client practice\u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- PRICING -->\n  \u003Csection id=\"pricing\">\n    \u003Cdiv class=\"container\">\n      \u003Cdiv class=\"section-header\">\n        \u003Cspan class=\"section-label\">Investment\u003C/span>\n        \u003Ch2>Choose Your \u003Cem>Path to 70%+\u003C/em>\u003C/h2>\n        \u003Cp>Whether you want the complete self-paced framework or live monthly coaching — there's a FASE program built for your practice.\u003C/p>\n      \u003C/div>\n      \u003Cdiv class=\"pricing-grid\">\n        \u003C!-- Masterclass -->\n        \u003Cdiv class=\"pc active\">\n          \u003Cdiv class=\"pc-name\">Full-Arch Sales Masterclass\u003C/div>\n          \u003Cdiv class=\"pc-sub\">Complete framework · Lifetime access\u003C/div>\n          \u003Cdiv class=\"pc-price\">\u003Cspan>$\u003C/span>4,000\u003C/div>\n          \u003Cdiv class=\"pc-period\">one-time investment\u003C/div>\n          \u003Cdiv class=\"pc-save\">&nbsp;\u003C/div>\n          \u003Cul class=\"pc-includes\">\n            \u003Cli>32 on-demand video lessons\u003C/li>\n            \u003Cli>Step-by-step full-arch sales training\u003C/li>\n            \u003Cli>Lead call, sales &amp; close scripts\u003C/li>\n            \u003Cli>Objection handling cheat sheets\u003C/li>\n            \u003Cli>Downloadable guides, cheat sheets &amp; templates\u003C/li>\n            \u003Cli>Progress tracking for your team\u003C/li>\n            \u003Cli>Access on desktop, tablet &amp; mobile\u003C/li>\n          \u003C/ul>\n          \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\">GET INSTANT ACCESS\u003C/a>\n        \u003C/div>\n        \u003C!-- NLCA Annual -->\n        \u003Cdiv class=\"pc\">\n          \u003Cdiv class=\"pc-name\">NLCA Membership\u003C/div>\n          \u003Cdiv class=\"pc-sub\">Live coaching · Monthly or annual\u003C/div>\n          \u003Cdiv class=\"pc-price\">\u003Cspan>$\u003C/span>295\u003C/div>\n          \u003Cdiv class=\"pc-period\">per month\u003C/div>\n          \u003Cdiv class=\"pc-save\">or $2,950/yr — save $590\u003C/div>\n          \u003Cul class=\"pc-includes\">\n            \u003Cli>Live training with Stacy\u003C/li>\n            \u003Cli>Access to all past session recordings\u003C/li>\n            \u003Cli>Downloadable scripts, guides &amp; tools\u003C/li>\n            \u003Cli>Cancel anytime — no long-term contracts\u003C/li>\n            \u003Cli>One seat per practice — whole team can attend\u003C/li>\n          \u003C/ul>\n          \u003Ca href=\"#nlca\" class=\"btn-primary\">JOIN NLCA\u003C/a>\n          \u003Cp class=\"pc-guarantee\">\u003Cspan>🔄\u003C/span> Cancel or pause any time\u003C/p>\n          \u003Cp style=\"font-size:12px;color:rgba(255,255,255,0.30);margin-top:10px;text-align:center;\">One seat per practice — whole team can attend · Immediate access after registration\u003C/p>\n        \u003C/div>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- FINAL CTA -->\n  \u003Csection id=\"final-cta\">\n    \u003Cdiv class=\"container\">\n      \u003Ch2>Stop Leaving Arches on the Table.\u003Cbr>Start Closing at 70%+.\u003C/h2>\n      \u003Cp>Every month without the framework is another month of cases that could have closed. The practice you want to build already has a blueprint — it's Stacy's.\u003C/p>\n      \u003Cdiv class=\"final-ctas\">\n        \u003Ca href=\"https://fullarchsalesexperts.com/course-641943\" target=\"_blank\" class=\"btn-primary\">GET THE FRAMEWORK\u003C/a>\n        \u003Ca href=\"https://fullarchsalesexperts.com/booking\" target=\"_blank\" class=\"btn-ghost\">BOOK A DISCOVERY CALL\u003C/a>\n      \u003C/div>\n    \u003C/div>\n  \u003C/section>\n\n  \u003C!-- FOOTER -->\n  \u003Cfooter>\n    \u003Cdiv class=\"container\">\n      \u003Cp style=\"margin-bottom:10px;\">\n        \u003Ca href=\"#\">Privacy Policy\u003C/a>&nbsp;·&nbsp;\n        \u003Ca href=\"#\">Terms\u003C/a>&nbsp;·&nbsp;\n        \u003Ca href=\"mailto:hello@fullarchsalesexperts.com\">hello@fullarchsalesexperts.com\u003C/a>&nbsp;·&nbsp;\n        \u003Ca href=\"https://fullarchsalesexperts.com\">fullarchsalesexperts.com\u003C/a>\n      \u003C/p>\n      \u003Cp>© 2026 Full Arch Sales Experts · Stacy Farley · All rights reserved.\u003C/p>\n    \u003C/div>\n  \u003C/footer>\n\n  \u003C!-- JOIN NOW MODAL -->\n  \u003Cdiv class=\"modal-overlay\" id=\"planModal\" onclick=\"closeOnOverlay(event, 'planModal')\">\n    \u003Cdiv class=\"modal-box\">\n      \u003Cbutton class=\"modal-close\" onclick=\"closeModal('planModal')\">✕\u003C/button>\n      \u003Cdiv class=\"modal-tag\" id=\"modalTag\">NLCA Membership · Annual\u003C/div>\n      \u003Ch3 id=\"modalTitle\">Join Next Level Case Acceptance\u003C/h3>\n      \u003Cdiv class=\"modal-price-display\" id=\"modalPrice\">$2,950\u003C/div>\n      \u003Cdiv class=\"modal-price-sub\" id=\"modalPeriodSub\">billed annually\u003C/div>\n      \u003Cdiv class=\"modal-save\" id=\"modalSaveNote\">Save 2 months free vs monthly\u003C/div>\n      \u003Cul class=\"modal-includes\" id=\"modalIncludes\">\n        \u003Cli>Live training with Stacy\u003C/li>\n        \u003Cli>Real consult role-plays &amp; objection drills\u003C/li>\n        \u003Cli>Scripts, templates &amp; tools to use next day\u003C/li>\n        \u003Cli>Hot seat Q&amp;A on your actual cases\u003C/li>\n        \u003Cli>Session recordings + growing resource library\u003C/li>\n        \u003Cli id=\"modalExtraItem\">Locked-in rate for 12 months\u003C/li>\n      \u003C/ul>\n      \u003Cbutton class=\"btn-primary\" onclick=\"proceedToCheckout()\">COMPLETE ENROLLMENT\u003C/button>\n      \u003Cp class=\"modal-guarantee\" id=\"modalGuarantee\">🛡️ 30-day money-back guarantee · No questions asked\u003C/p>\n    \u003C/div>\n  \u003C/div>\n\n  \u003C!-- DISCOVERY CALL MODAL -->\n  \u003Cdiv class=\"modal-overlay\" id=\"discoveryModal\" onclick=\"closeOnOverlay(event, 'discoveryModal')\">\n    \u003Cdiv class=\"modal-box\">\n      \u003Cbutton class=\"modal-close\" onclick=\"closeModal('discoveryModal')\">✕\u003C/button>\n      \u003Cdiv class=\"modal-tag\">Free · No Pressure\u003C/div>\n      \u003Ch3>Book a Discovery Call\u003C/h3>\n      \u003Cp style=\"font-size:15px;color:var(--muted);line-height:1.7;margin:12px 0 4px;\">Tell us a bit about your practice and a FASE specialist will reach out to book a time that works for you.\u003C/p>\n      \u003Cform class=\"modal-form\" onsubmit=\"handleDiscoverySubmit(event)\">\n        \u003Cinput type=\"text\" placeholder=\"Your name\" required />\n        \u003Cinput type=\"email\" placeholder=\"Business email\" required />\n        \u003Cinput type=\"text\" placeholder=\"Practice name\" />\n        \u003Cselect required>\n          \u003Coption value=\"\" disabled selected>Your role\u003C/option>\n          \u003Coption>Practice Owner\u003C/option>\n          \u003Coption>DSO Ops Director\u003C/option>\n          \u003Coption>Treatment Coordinator\u003C/option>\n          \u003Coption>Office Manager\u003C/option>\n          \u003Coption>Other\u003C/option>\n        \u003C/select>\n        \u003Cinput type=\"text\" placeholder=\"Approx. monthly full-arch consults\" />\n        \u003Cbutton type=\"button\" onclick=\"window.open('https://fullarchsalesexperts.com/booking','_blank')\" class=\"btn-primary\">REQUEST MY DISCOVERY CALL\u003C/button>\n      \u003C/form>\n      \u003Cp class=\"modal-guarantee\">🔒 We never share your info. No spam, ever.\u003C/p>\n    \u003C/div>\n  \u003C/div>\n\n  \u003Cscript>\n    // ── Plan selection ──\n    let selectedPlan = 'annual';\n\n    function selectPlan(plan) {\n      selectedPlan = plan;\n      document.querySelectorAll('.plan-option').forEach(el => {\n        el.classList.toggle('selected', el.dataset.plan === plan);\n      });\n    }\n\n    // ── Open JOIN NOW modal with correct plan content ──\n    const planData = {\n      monthly: {\n        tag: 'NLCA Membership · Monthly',\n        title: 'Join Next Level Case Acceptance',\n        price: '$295',\n        period: 'billed monthly · cancel anytime',\n        save: '',\n        extraItem: 'Cancel anytime — no contracts',\n        checkout: 'https://link.fastpaydirect.com/payment-link/69c59f67c6a0e600f4d05b91'\n      },\n      annual: {\n        tag: 'NLCA Membership · Annual',\n        title: 'Join Next Level Case Acceptance',\n        price: '$2,950',\n        period: 'billed annually',\n        save: 'Save $590 vs monthly',\n        extraItem: 'Locked-in rate for 12 months',\n        checkout: 'https://link.fastpaydirect.com/payment-link/69c5a02ac6a0e600f4d05b94'\n      }\n    };\n\n    function openPlanModal() {\n      const d = planData[selectedPlan];\n      document.getElementById('modalTag').textContent = d.tag;\n      document.getElementById('modalTitle').textContent = d.title;\n      document.getElementById('modalPrice').textContent = d.price;\n      document.getElementById('modalPeriodSub').textContent = d.period;\n      document.getElementById('modalSaveNote').textContent = d.save;\n      document.getElementById('modalExtraItem').textContent = d.extraItem;\n      document.getElementById('planModal').classList.add('open');\n      document.body.style.overflow = 'hidden';\n    }\n\n    function proceedToCheckout() {\n      const url = planData[selectedPlan].checkout;\n      window.open(url, '_blank');\n    }\n\n    // ── Open Discovery Call modal ──\n    function openDiscoveryModal() {\n      document.getElementById('discoveryModal').classList.add('open');\n      document.body.style.overflow = 'hidden';\n    }\n\n    function handleDiscoverySubmit(e) {\n      e.preventDefault();\n      const btn = e.target.querySelector('button[type=\"submit\"]');\n      btn.textContent = '✓ REQUEST RECEIVED — WE\\'LL BE IN TOUCH';\n      btn.style.background = '#0F4FB5';\n      btn.disabled = true;\n      // Wire to your GHL webhook here\n    }\n\n    // ── Close modals ──\n    function closeModal(id) {\n      document.getElementById(id).classList.remove('open');\n      document.body.style.overflow = '';\n    }\n    function closeOnOverlay(e, id) {\n      if (e.target === document.getElementById(id)) closeModal(id);\n    }\n    document.addEventListener('keydown', e => {\n      if (e.key === 'Escape') {\n        closeModal('planModal');\n        closeModal('discoveryModal');\n      }\n    });\n\n    // ── Opt-in form ──\n    function handleSubmit(e) {\n      e.preventDefault();\n      const btn = e.target.querySelector('button[type=\"submit\"]');\n      btn.textContent = '✓ CHECK YOUR INBOX';\n      btn.style.background = '#0F4FB5';\n      btn.disabled = true;\n      // Wire to your GHL webhook URL here\n    }\n\n    // ── Mobile menu ──\n    function toggleMenu() {\n      const btn = document.getElementById('hamburger');\n      const menu = document.getElementById('mobileMenu');\n      btn.classList.toggle('open');\n      menu.classList.toggle('open');\n      document.body.style.overflow = menu.classList.contains('open') ? 'hidden' : '';\n    }\n\n    // ── Full-width: break out of any GHL parent container ──\n    (function() {\n      function forceFullWidth() {\n        // Walk all ancestors of body and strip width constraints\n        var el = document.body;\n        while (el) {\n          el.style.setProperty('max-width', 'none', 'important');\n          el.style.setProperty('padding-left', '0', 'important');\n          el.style.setProperty('padding-right', '0', 'important');\n          el.style.setProperty('margin-left', '0', 'important');\n          el.style.setProperty('margin-right', '0', 'important');\n          el.style.setProperty('width', '100%', 'important');\n          el = el.parentElement;\n        }\n        // Also force the page root breakout\n        var root = document.getElementById('page-root');\n        if (root) {\n          root.style.setProperty('width', '100vw', 'important');\n          root.style.setProperty('max-width', '100vw', 'important');\n          root.style.setProperty('position', 'relative', 'important');\n          root.style.setProperty('left', '50%', 'important');\n          root.style.setProperty('margin-left', '-50vw', 'important');\n          root.style.setProperty('margin-right', '-50vw', 'important');\n        }\n      }\n      forceFullWidth();\n      window.addEventListener('load', forceFullWidth);\n      // Run again after a short delay for GHL's lazy-loaded layout\n      setTimeout(forceFullWidth, 300);\n      setTimeout(forceFullWidth, 800);\n    })();\n\n    // ── Smooth scroll ──\n    document.querySelectorAll('a[href^=\"#\"]').forEach(a => {\n      a.addEventListener('click', e => {\n        const target = document.querySelector(a.getAttribute('href'));\n        if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }\n      });\n    });\n  \u003C/script>\n\n\u003C/div>\u003C!-- /#page-root -->\n\u003C/body>\n\u003C/html>",{"value":95},[],"ccustom-code-Wc1SFX4rcd","custom-code","c-custom-code",{},[],[],{"title":29,"description":29,"author":29,"imageUrl":29,"isPreviewUrl":25},"fullarchsalesexperts.com","/fase-service-page","J2yA0XPfIPdMO2CIEXVJ","Face Service Page","vdi6H8skwmbrWBAz1f6X",[109],{"id":110,"elements":111,"activeElementId":110},"hl_main_popup-mzNGBkF8ce",[112],{"extra":113,"class":129,"styles":130,"customCss":133,"id":110,"child":134,"meta":135,"title":136,"tag":29},{"bgImage":114,"overlayColor":116,"left":118,"popupDisabled":120,"popupHide":121,"minWidth":122,"showPopupOnMouseOut":124,"customClass":126,"position":128},{"value":115},{"mediaType":28,"url":29,"opacity":30,"options":31,"svgCode":29,"videoUrl":29,"videoThumbnail":29,"videoLoop"