  <!-- ==========================================
       SECTION 6: MINI BIO / EXPERT POSITIONING
       ========================================== -->
  <section class="bio">
    <div class="container">
      <div class="bio__grid">
        <!-- Replace src with actual headshot -->
        <img src="https://assets.cdn.filesafe.space/vdi6H8skwmbrWBAz1f6X/media/69ca96fd2155b06299754f90.jpg" alt="Stacy Farley, Full Arch Sales Experts founder" class="bio__headshot">
        <div>
          <p class="bio__eyebrow">Meet Stacy Farley</p>
          <p class="bio__text">Stacy practices what she preaches. She averaged 50 arches a month and achieved a 70% closing rate &mdash; setting a new industry standard far surpassing the 25% average conversion rate. Her former office averaged $800,000 to $1,000,000 monthly in collections on just a 5% marketing spend, while the industry average is 20%. Today she teaches dental teams the exact framework that built the nation&rsquo;s largest full-arch implant center.</p>
          <a href="#[GHL_BOOKING_LINK]" class="bio__cta">
            Book a discovery call with Stacy&rsquo;s team
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

